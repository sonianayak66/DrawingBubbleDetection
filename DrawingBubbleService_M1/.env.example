# Bubble Detection Service — environment template.
# Copy to .env and replace the placeholder before starting the service.
# main.py refuses to boot if BUBBLE_API_KEY still contains any of the
# placeholder tokens (change-this-key, change-me-to, your-key-here).

BUBBLE_API_KEY=change-this-key


# Optional: enable Real-ESRGAN super-resolution preprocessing for
# cluttered drawings. Off by default; flip to 1/true/yes to opt in.
# BUBBLE_ENABLE_REALESRGAN=0
