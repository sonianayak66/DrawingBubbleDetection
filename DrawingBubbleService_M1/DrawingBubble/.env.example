# ─────────────────────────────────────────────────────────────────────────────
# DrawingBubbleService — Environment Variables
#
# 1. Copy this file to .env
#    Windows:  copy .env.example .env
#    Linux:    cp .env.example .env
#
# 2. Set a strong random key for BUBBLE_API_KEY
#    Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED — API authentication key (any strong random string)
BUBBLE_API_KEY=mysecretkey123

# OPTIONAL — OCR engine preference: "rapid" (default) or "auto"
OCR_ENGINE=rapid

# OPTIONAL — Pre-downloaded RapidOCR model directory (offline use)
# If blank, models are downloaded on first run (requires internet)
# RAPIDOCR_MODEL_DIR=C:\models\rapidocr
