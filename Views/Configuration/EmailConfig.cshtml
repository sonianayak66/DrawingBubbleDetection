@model MPCRS.ViewModels.EmailConfigVM
@using MPCRS.Utilities
@{
    ViewData["Title"] = "EmailConfig";
    //Layout = null;
  //  var Permission_Write = UserData.IsAuthorized(User, Constants.UserPermissions.Projects_Write);
   
}
@using (Html.BeginForm("EmailConfig", "Configuration", FormMethod.Post, new { onsubmit = "return SaveConfiginfo(this)" }))
{
<div class="col-12">
    <form id="CreateEmailConfig" class="needs-validation" novalidate="novalidate">
       

        <hr />
        <input asp-for="Sl_No" type="hidden" value="@Model.Sl_No" />
        <div class="form-group row">
            <div class="col-6">
                <div class="form-floating mb-3">
                    <input class="form-control" asp-for="MailID" type="text">
                    <label asp-for="MailID"></label>
                    <span asp-validation-for="MailID" class="text-danger"></span>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="col-6">
                <div class="form-floating mb-3">
                    <input class="form-control" asp-for="Password" type="text">
                    <label asp-for="Password"></label>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="col-6">
                <div class="form-floating mb-3">
                    <input class="form-control" asp-for="SMTP_HostName" type="text">
                    <label asp-for="SMTP_HostName"></label>
                    <span asp-validation-for="SMTP_HostName" class="text-danger"></span>
                </div>
            </div>
        </div>
       
       

        <div class="form-group row">
            <div class="col-md-6">
                <div class="form-floating mb-2">
                    <input class="form-control" asp-for="SMTP_Port" type="text">
                    <label asp-for="SMTP_Port"></label>
                    <span asp-validation-for="SMTP_Port" class="text-danger"></span>
                </div>
            </div>
        </div>


        <div class="form-group row">
            <div class="col-md-6">
                <div class="form-floating mb-2">
                    <select class="form-control" asp-for="SSL" name="SSL">
                        
                        <option value="YES">YES</option>
                        <option value="NO">NO</option>
                    </select>
                    <label asp-for="SSL"></label>
                </div>
            </div>
            </div>

      
        <div class="row">
           
            <div class="col-6 pull-right">     
                    <button type="submit" class="btn btn-primary float-end" style="margin-right:10px;" onsubmit="Save()" >Save</button>               
            </div>


        </div>

    </form>
    </div>
    }
  
