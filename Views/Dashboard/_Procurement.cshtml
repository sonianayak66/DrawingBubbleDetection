<!-- Modal: Untracked Demands Detail -->
<!-- ============================================ -->
<div class="modal fade" id="untrackedDemandsModal" tabindex="-1" aria-labelledby="untrackedDemandsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header" style="background: linear-gradient(135deg, #6c757d 0%, #495057 100%); color: white;">
                <h5 class="modal-title" id="untrackedDemandsModalLabel">
                    <i class="uil uil-eye-slash"></i> Untracked Demands (Without Milestones)
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="background-color: #f8f9fa;">

                <!-- Summary Cards -->
                <div class="row mb-4 g-3">
                    <div class="col-md-3">
                        <div class="dashboard-summary-card" style="border-left: 4px solid #dc3545;">
                            <div class="summary-label">
                                <i class="uil uil-exclamation-triangle text-danger"></i> OVERDUE & INCOMPLETE
                            </div>
                            <div class="summary-value text-danger">@Model.UntrackedDemands.OverdueIncomplete</div>
                            <div class="summary-subtext">Demands past planned date</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="dashboard-summary-card" style="border-left: 4px solid #ffc107;">
                            <div class="summary-label">
                                <i class="uil uil-clock text-warning"></i> DUE SOON
                            </div>
                            <div class="summary-value text-warning">@Model.UntrackedDemands.DueSoon</div>
                            <div class="summary-subtext">Due within 7 days</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="dashboard-summary-card" style="border-left: 4px solid #28a745;">
                            <div class="summary-label">
                                <i class="uil uil-check-circle text-success"></i> COMPLETED
                            </div>
                            <div class="summary-value text-success">@Model.UntrackedDemands.CompletedUntracked</div>
                            <div class="summary-subtext">Finished, untracked</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="dashboard-summary-card" style="border-left: 4px solid #17a2b8;">
                            <div class="summary-label">
                                <i class="uil uil-rupee-sign text-info"></i> TOTAL VALUE
                            </div>
                            <div class="summary-value text-info">₹@((Model.UntrackedDemands.TotalUntrackedValue / 10000000).ToString("N2")) Cr</div>
                            <div class="summary-subtext">Untracked value</div>
                        </div>
                    </div>
                </div>

                <div class="alert alert-light border">
                    <i class="uil uil-info-circle text-primary"></i>
                    <strong>Note:</strong> These demands do not have milestone tracking. Monitor planned dates and receipt status manually.
                </div>

                <!-- Data Table -->
                @if (Model.UntrackedDemandsList != null && Model.UntrackedDemandsList.Any())
                {
                    <div class="table-card">
                        <div class="table-responsive">
                            <table class="table table-sm table-hover table-bordered mb-0">
                                <thead style="background-color: #495057; color: white;">
                                    <tr>
                                        <th>MMG File No</th>
                                        <th>Description</th>
                                        <th>Planned Date</th>
                                        <th>Days</th>
                                        <th class="text-end">Ordered</th>
                                        <th class="text-end">Received</th>
                                        <th class="text-end">Balance</th>
                                        <th class="text-end">Progress</th>
                                        <th>Vendor</th>
                                        <th>Status</th>
                                        <th class="text-end">Value</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.UntrackedDemandsList)
                                    {
                                        var statusClass = item.TrackingStatus == "Overdue" ? "table-danger" :
                                        item.TrackingStatus == "Due Soon" ? "table-warning" :
                                        item.TrackingStatus == "Complete" ? "table-success" : "";

                                        var statusBadge = item.TrackingStatus == "Overdue" ? "bg-danger" :
                                        item.TrackingStatus == "Due Soon" ? "bg-warning" :
                                        item.TrackingStatus == "Complete" ? "bg-success" : "bg-info";

                                        <tr class="@statusClass">
                                            <td><strong>@item.MMG_File_No</strong></td>
                                            <td>@item.Item_Description</td>
                                            <td>@(item.Planned_Date_of_receipt?.ToString("dd-MMM-yyyy") ?? "-")</td>
                                            <td>
                                                @if (item.TrackingStatus == "Overdue")
                                                {
                                                    <span class="badge bg-danger">@item.DaysFromPlanned days overdue</span>
                                                }
                                                else if (item.TrackingStatus == "Due Soon")
                                                {
                                                    <span class="badge bg-warning">@item.DaysFromPlanned days left</span>
                                                }
                                                else if (item.TrackingStatus == "Complete")
                                                {
                                                    <span class="text-muted">Completed</span>
                                                }
                                                else
                                                {
                                                    <span>@item.DaysFromPlanned days</span>
                                                }
                                            </td>
                                            <td class="text-end">@item.TotalOrdered.ToString("N1")</td>
                                            <td class="text-end">@item.TotalReceived.ToString("N1")</td>
                                            <td class="text-end">@item.TotalBalance.ToString("N1")</td>
                                            <td class="text-end">
                                                <div class="progress" style="height: 20px;">
                                                    <div class="progress-bar @(item.FulfillmentPercentage >= 100 ? "bg-success" : item.FulfillmentPercentage >= 75 ? "bg-info" : "bg-warning")"
