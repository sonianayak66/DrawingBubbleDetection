<!-- JAVASCRIPT FOR CHARTS AND INTERACTIONS -->
<!-- ============================================ -->
<script>
    // Initialize Procurement Status Chart
    $(document).ready(function() {
        // Fix: Move procurement modals to body so they're not inside transformed container (Firefox fix)
        $('#procurement-section .modal').each(function () {
            $(this).appendTo('body');
        });
        // Prepare data from C# model
        var procurementStatusData = @Html.Raw(Json.Serialize(Model.ProcurementByStatus));

        // Check if data exists
        if (procurementStatusData && procurementStatusData.length > 0) {
            // Call the function from dashboard.js
            initProcurementStatusChart('procurementStatusChart', procurementStatusData);
        } else {
            console.warn('No procurement status data available for chart');
            // Optionally show a message in the chart area
            $('#procurementStatusChart').parent().html(
                '<div class="alert alert-info m-3">' +
                '<i class="uil uil-info-circle"></i> No status data available' +
                '</div>'
            );
        }

         var topVendorsData = @Html.Raw(Json.Serialize(Model.TopVendors));
         console.log(topVendorsData);

        if (topVendorsData && topVendorsData.length > 0) {
            initTopVendorsChart('topVendorsChart', topVendorsData);
        } else {
            console.warn('No top vendors data available');
            $('#topVendorsChart').parent().html(
                '<div class="alert alert-info m-3">' +
                '<i class="uil uil-info-circle"></i> No vendor data available' +
                '</div>'
            );
        }
    });
</script>