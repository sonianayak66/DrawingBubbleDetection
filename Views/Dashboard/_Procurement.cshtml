<!-- Modal 1: Urgent Actions Detail - PROFESSIONAL DESIGN -->
<div class="modal fade" id="urgentActionsModal" tabindex="-1" aria-labelledby="urgentActionsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                <h5 class="modal-title" id="urgentActionsModalLabel">
                    <i class="uil uil-exclamation-triangle"></i> Urgent Actions - Detailed Breakdown
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="background-color: #f8f9fa;">
                <!-- Summary Cards - PROFESSIONAL STYLE -->
                <div class="row g-2 mb-3">
                    <div class="col-md-4">
                        <div class="dashboard-summary-card compact" style="border-left: 4px solid #ffc107;">
                            <div class="summary-label mb-1">
                                <i class="uil uil-calendar-alt text-warning me-1"></i> DUE THIS WEEK
                            </div>

                            <div class="d-flex align-items-baseline gap-2">
                                <div class="summary-value">@Model.UrgentActions.DemandsDueIn7Days</div>
                                <div class="summary-subtext mb-0">Demands </div>
                            </div>

                            <div class="summary-footer mt-1">
                                <small class="text-muted">₹@((Model.UrgentActions.ValueDueIn7Days / 10000000).ToString("N2")) Cr</small>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="dashboard-summary-card compact" style="border-left: 4px solid #dc3545;">
                            <div class="summary-label mb-1">
                                <i class="uil uil-exclamation-octagon text-danger me-1"></i> ALREADY OVERDUE
                            </div>

                            <div class="d-flex align-items-baseline gap-2">
                                <div class="summary-value text-danger">@Model.UrgentActions.DemandsOverdue</div>
                                <div class="summary-subtext mb-0">Demands</div>
                            </div>

                            <div class="summary-footer mt-1">
                                <small class="text-muted">₹@((Model.UrgentActions.ValueOverdue / 10000000).ToString("N2")) Cr</small>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="dashboard-summary-card compact" style="border-left: 4px solid #6c757d;">
                            <div class="summary-label mb-1">
                                <i class="uil uil-analytics text-secondary me-1"></i> TOTAL EXPOSURE
                            </div>

                            <div class="d-flex align-items-baseline gap-2">
                                <div class="summary-value">@Model.UrgentActions.TotalUrgentDemands</div>
                                <div class="summary-subtext mb-0">Total Demands</div>
                            </div>

                            <div class="summary-footer mt-1">
                                <small class="text-muted">₹@((Model.UrgentActions.TotalValueAtRisk / 10000000).ToString("N2")) Cr</small>
                            </div>
                        </div>
                    </div>
                </div>


                @* <div class="alert alert-light border" style="background-color: white;">
                    <i class="uil uil-info-circle text-primary"></i>
                    <strong>Note:</strong> Each demand may have multiple milestone deliveries. Counts above show unique demands requiring action.
                </div> *@

                <!-- Tab Navigation - PROFESSIONAL STYLE -->
                <ul class="nav nav-tabs nav-tabs-custom mb-3" id="urgentActionsTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="dueThisWeek-tab" data-bs-toggle="tab" data-bs-target="#dueThisWeek" type="button" role="tab">
                            <i class="uil uil-calendar-alt"></i> Due This Week 
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="overdue-tab" data-bs-toggle="tab" data-bs-target="#overdue" type="button" role="tab">
                            <i class="uil uil-exclamation-triangle"></i> Already Overdue (@Model.UrgentActions.DemandsOverdue)
                        </button>
                    </li>
                </ul>

                <!-- Tab Content -->
                <div class="tab-content" id="urgentActionsTabContent">
                    <!-- Due This Week Tab -->
                    <div class="tab-pane fade show active" id="dueThisWeek" role="tabpanel">
                        @if (Model.ImmediateAttention != null && Model.ImmediateAttention.Any(x => x.DaysUntilDue > 0))
                        {
                            <div class="table-card">
                                <div class="table-responsive">
                                    <table class="table table-sm table-hover table-bordered mb-0">
                                        <thead style="background-color: #495057; color: white;">
                                            <tr>
                                                <th>MMG File No</th>
                                                <th>Milestone</th>
                                                <th>Due Date</th>
                                                <th>Days Until</th>
                                                @* <th class="text-end">Qty Required</th>
                                                <th class="text-end">Received</th>
                                                <th class="text-end">Progress</th> *@
                                                <th>Vendor</th>
                                                @* <th class="text-end">Value</th> *@
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in Model.ImmediateAttention.Where(x => x.DaysUntilDue > 0).OrderBy(x => x.DaysUntilDue))
                                            {
                                                var progressPct = item.QtyRequired > 0 ? (item.QtyReceived / item.QtyRequired * 100) : 0;
                                                var rowClass = item.DaysUntilDue <= 3 ? "table-row-urgent" : "";

                                                // NULL-SAFE status class determination
                                                var badgeClass = "badge-warning-soft"; // default
                                                if (!string.IsNullOrEmpty(item.Status))
                                                {
                                                    if (item.Status.Contains(">30")) badgeClass = "badge-urgent";
                                                    else if (item.Status.Contains("15-30")) badgeClass = "badge-urgent";
                                                    else if (item.Status.Contains("<15")) badgeClass = "badge-warning-soft";
                                                }

                                                <tr class="@rowClass">
                                                    <td><strong>@item.MMG_File_No</strong></td>
                                                    <td>@item.MilestoneName</td>
                                                    <td>@(item.DueDate?.ToString("dd-MMM-yyyy") ?? "-")</td>
                                                    <td>
                                                        <span class="badge @(item.DaysUntilDue <= 3 ? "badge-urgent" : "badge-warning-soft")">
                                                            @item.DaysUntilDue days
                                                        </span>
                                                    </td>
                                                    @* <td class="text-end">@item.QtyRequired.ToString("N1")</td>
                                                    <td class="text-end">@item.QtyReceived.ToString("N1")</td>
                                                    <td class="text-end">
                                                        <div class="progress" style="height: 20px; background-color: #e9ecef;">
                                                            <div class="progress-bar @(progressPct < 50 ? "bg-danger" : progressPct < 80 ? "bg-warning" : "bg-success")"
                                                                 role="progressbar"
                                                                 style="width: @progressPct.ToString("N0")%"
                                                                 aria-valuenow="@progressPct" aria-valuemin="0" aria-valuemax="100">
                                                                <small class="fw-bold">@progressPct.ToString("N0")%</small>
                                                            </div>
                                                        </div>
                                                    </td> *@
                                                    <td><small>@(item.Vendor_Name ?? "-")</small></td>
                                                    @* <td class="text-end"><small>₹@((item.EstimatedCost / 10000000).ToString("N2")) Cr</small></td> *@
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-success border"
                                 style="background-color: #d1e7dd; color: #0f5132;">
                                No milestones due in the next 7 days.
                            </div>

                        }
                    </div>

                    <!-- Overdue Tab -->
                    <div class="tab-pane fade" id="overdue" role="tabpanel">
                        @if (Model.ImmediateAttention != null && Model.ImmediateAttention.Any(x => x.DaysUntilDue < 0))
                        {
                            <div class="table-card">
                                <div class="table-responsive">
                                    <table class="table table-sm table-hover table-bordered mb-0">
                                        <thead style="background-color: #dc3545; color: white;">
                                            <tr>
                                                <th>MMG File No</th>
                                                <th>Milestone</th>
                                                <th>Was Due On</th>
                                                <th>Days Overdue</th>
                                                @* <th class="text-end">Qty Required</th>
                                                <th class="text-end">Received</th>
                                                <th class="text-end">Progress</th> *@
                                                <th>Vendor</th>
                                                @* <th class="text-end">Value</th> *@
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in Model.ImmediateAttention.Where(x => x.DaysUntilDue < 0).OrderBy(x => x.DaysUntilDue))
                                            {
                                                var progressPct = item.QtyRequired > 0 ? (item.QtyReceived / item.QtyRequired * 100) : 0;
                                                var severityClass = Math.Abs(item.DaysUntilDue) > 30 ? "table-danger" :
                                                 Math.Abs(item.DaysUntilDue) > 15 ? "table-warning" : "";

                                                <tr class="@severityClass">
                                                    <td>
                                                        <strong style="cursor: pointer;"
                                                            onclick="window.open('/DemandManagement/DemandTree?id=@item.DemandDbkey', '_blank')"
                                                                title="Click to view demand details">
                                                                @item.MMG_File_No
                                                        </strong>
                                                    </td>
                                                  
                                                    <td>@item.MilestoneName</td>
                                                    <td>@(item.DueDate?.ToString("dd-MMM-yyyy"))</td>
                                                    <td>
                                                        <span class="badge badge-danger-soft">
                                                            @Math.Abs(item.DaysUntilDue) days
                                                        </span>
                                                    </td>
                                                    @* <td class="text-end">@item.QtyRequired.ToString("N1")</td>
                                                    <td class="text-end">@item.QtyReceived.ToString("N1")</td>
                                                    <td class="text-end">
                                                        <div class="progress" style="height: 20px; background-color: #e9ecef;">
                                                            <div class="progress-bar bg-danger"
                                                                 role="progressbar"
                                                                 style="width: @progressPct.ToString("N0")%"
                                                                 aria-valuenow="@progressPct" aria-valuemin="0" aria-valuemax="100">
                                                                <small class="fw-bold text-white">@progressPct.ToString("N0")%</small>
                                                            </div>
                                                        </div>
                                                    </td> *@
                                                    <td><small>@item.Vendor_Name</small></td>
                                                    @* <td class="text-end"><small>₹@((item.EstimatedCost / 10000000).ToString("N2")) Cr</small></td> *@
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-success border" style="background-color: #d1e7dd; color: #0f5132;">
                                <i class="uil uil-check-circle"></i> No overdue milestones. Excellent!
                            </div>
                        }
                    </div>
                </div>
            </div>
            @* <div class="modal-footer" style="background-color: #f8f9fa;">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary">
                    <i class="uil uil-file-download-alt"></i> Export to Excel
                </button>
            </div> *@
        </div>
    </div>
</div>

<!-- Modal 2: Vendor Accountability Detail - PROFESSIONAL -->
<div class="modal fade" id="vendorAccountabilityModal" tabindex="-1" aria-labelledby="vendorAccountabilityModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white;">
                <h5 class="modal-title" id="vendorAccountabilityModalLabel">
                    <i class="uil uil-user-times"></i> Vendor Accountability - Performance Analysis
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="background-color: #f8f9fa;">
                <!-- Summary Cards -->
                <div class="row mb-4 g-3">
                    <div class="col-md-4">
                        <div class="dashboard-summary-card" style="border-left: 4px solid #ffc107;">
                            <div class="summary-label">
                                <i class="uil uil-users-alt text-warning"></i> VENDORS BEHIND SCHEDULE
                            </div>
                            <div class="summary-value text-warning">@Model.VendorAccountability.VendorsBehindSchedule</div>
                              @* <div class="summary-subtext">Out of @Model.VendorPerformanceScorecard.Count total vendors</div> *@
                            @* <div class="summary-footer">
                                <small class="text-muted">@((Model.VendorAccountability.VendorsBehindSchedule * 100.0 / Model.VendorPerformanceScorecard.Count).ToString("N1"))% of vendors</small>
                            </div> *@
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="dashboard-summary-card" style="border-left: 4px solid #dc3545;">
                            <div class="summary-label">
                                <i class="uil uil-exclamation-triangle text-danger"></i> OVERDUE MILESTONES
                            </div>
                            <div class="summary-value text-danger">@Model.VendorAccountability.TotalOverdueMilestones</div>
                            @* <div class="summary-subtext">Across all vendors</div> *@
                        @*     <div class="summary-footer">
                                <small class="text-muted">Immediate action required</small>
                            </div>*@
                        </div> 
                    </div> 
                </div>
                 

                <!-- Vendor Performance Table -->
                <div class="table-card"> 

                    <div class="table-responsive">
                        <table class="table table-sm table-hover table-bordered mb-0" id="vendorPerformanceTable">
                            <thead style="background-color: #495057; color: white;">
                                <tr>
                                    <th>Vendor Name</th>
                                    <th class="text-center">Total<br />Milestones</th>
                                    <th class="text-center">Completed<br />On-Time</th>
                                    <th class="text-center">Currently<br />Overdue</th>
                                    <th class="text-end">Completion<br />Rate</th>
                                    <th class="text-end p-2">Avg Delay<br />(days)</th> 
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var vendor in Model.VendorPerformanceScorecard)
                                {
                                   
                                    var completionColor = vendor.CompletionRate >= 90 ? "text-success" :
                                    vendor.CompletionRate >= 75 ? "text-info" :
                                    vendor.CompletionRate >= 60 ? "text-warning" : "text-danger";

                                    var delayColor = vendor.AvgDelayDays <= 15 ? "text-success" :
                                    vendor.AvgDelayDays <= 30 ? "text-warning" : "text-danger";

                                    <tr class="">
                                        <td><strong>@vendor.Vendor_Name</strong></td>
                                        <td class="text-center">@vendor.TotalMilestones</td>
                                        <td class="text-center text-success fw-bold">@vendor.CompletedOnTime</td>
                                        <td class="text-center">
                                            @if (vendor.OverdueCount > 0)
                                            {
                                                <span class="text-danger fw-bold">@vendor.OverdueCount</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">0</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <span class="@completionColor fw-bold">@vendor.CompletionRate.ToString("N1")%</span>
                                        </td>
                                        <td class="text-end">
                                            @if (vendor.AvgDelayDays > 0)
                                            {
                                                <span class="@delayColor fw-bold">@vendor.AvgDelayDays.ToString("N0")</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td> 
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
              
            </div>
          
        </div>
    </div>
</div>

  
