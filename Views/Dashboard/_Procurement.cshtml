</style>
<!-- ============================================ -->
<!-- SECTION 1: KPI CARDS (4 Cards) - COMPACT & UNIFORM -->
<!-- ============================================ -->
<div class="row mb-3 g-2">
    <!-- Card 1: Urgent Actions - CLEAR LABELS -->
    <div class="col-12 col-sm-6 col-lg-3">
        <div class="dashboard-kpi-card border-danger clickable h-100"
             data-bs-toggle="modal"
             data-bs-target="#urgentActionsModal"
             style="position: relative; overflow: hidden; cursor: pointer;">
            <!-- Background Icon (Faded) -->
            <i class="uil uil-exclamation-triangle kpi-bg-icon" style="color: #dc3545;"></i>

            <!-- Content -->
            <div class="kpi-content">
                <div class="kpi-label">URGENT ACTIONS REQUIRED</div>
                <div class="kpi-value text-danger">@Model.UrgentActions.TotalUrgentDemands</div>
                <div class="kpi-sublabel">Demands Need Attention</div>

                <div class="kpi-detail-row">
                    <span class="kpi-text">Due This Week:</span>
                    <span class="kpi-value-sm text-warning">@Model.UrgentActions.DemandsDueIn7Days</span>
                </div>

                <div class="kpi-detail-row">
                    <span class="kpi-text">Already Overdue:</span>
                    <span class="kpi-value-sm text-danger">@Model.UrgentActions.DemandsOverdue</span>
                </div>

                <div class="kpi-highlight-compact">
                    ₹@((Model.UrgentActions.TotalValueAtRisk / 10000000).ToString("N2")) Cr at Risk
                </div>

                <div class="kpi-action-hint">
                    <i class="uil uil-mouse-alt"></i> Click for details
                </div>
            </div>
        </div>
    </div>

    <!-- Card 2: Vendor Accountability -->
    <div class="col-12 col-sm-6 col-lg-3">
        <div class="dashboard-kpi-card border-warning clickable h-100"
             data-bs-toggle="modal"
             data-bs-target="#vendorAccountabilityModal"
             style="position: relative; overflow: hidden; cursor: pointer;">
            <!-- Background Icon (Faded) -->
            <i class="uil uil-user-times kpi-bg-icon" style="color: #ffc107;"></i>

            <!-- Content -->
            <div class="kpi-content">
                <div class="kpi-label">VENDOR ACCOUNTABILITY</div>
                <div class="kpi-value text-warning">@Model.VendorAccountability.VendorsBehindSchedule  <span class="kpi-text">Vendors</span></div>

                <div class="kpi-detail-row">
                    <span class="kpi-text">Overdue Milestones:</span>
                    <span class="kpi-value-sm text-danger">@Model.VendorAccountability.TotalOverdueMilestones</span>  
                </div>

                <div class="kpi-detail-row">
                    <span class="kpi-text">Avg Delay:</span>
                    <span class="kpi-value-sm">@Model.VendorAccountability.AvgDelayDays.ToString("N0") days</span>   
                </div>

                <div class="kpi-action-hint">
                    <i class="uil uil-mouse-alt"></i> Click for details
                </div>
            </div>
        </div>
    </div>

    <!-- Card 3: Material Production Capacity -->
    <div class="col-12 col-sm-6 col-lg-3">
        <div class="dashboard-kpi-card border-info clickable h-100" 
             onclick="window.open('/Report/ProductionPlanningReport', '_blank')"
             style="position: relative; overflow: hidden; cursor: pointer;">
            <!-- Background Icon (Faded) -->
            <i class="uil uil-box kpi-bg-icon" style="color: #17a2b8;"></i>

            <!-- Content -->
            <div class="kpi-content">
                <div class="kpi-label">MATERIAL PRODUCTION CAPACITY</div>
                <div class="kpi-value text-info">@Model.MaterialFlow.MinEnginesCanProduce</div>
                <div class="kpi-sublabel">Engines Can Be Produced</div>

                <div class="kpi-detail-row">
                    <span class="kpi-text">Target:</span>
                    <span class="kpi-value-sm">@Model.MaterialFlow.TargetEngineCount engines</span>
                </div>

                <div class="kpi-detail-row">
                    <span class="kpi-text">In Shortage:</span>
                    <span class="kpi-value-sm text-danger">@Model.MaterialFlow.MaterialsInShortage materials</span>
                </div>

                <div class="kpi-detail-row">
                    <span class="kpi-text">Sufficient:</span>
                    <span class="kpi-value-sm text-success">@Model.MaterialFlow.MaterialsSufficient materials</span>
                </div>

                @* @if (Model.MaterialFlow.CriticalMaterials > 0)
                {
                    <div class="kpi-highlight-compact" style="background-color: #dc3545; color: white;">
                        <i class="uil uil-exclamation-triangle"></i> @Model.MaterialFlow.CriticalMaterials Critical Materials
                    </div>
                }
                else
                {
                    <div class="kpi-highlight-compact">
                        <i class="uil uil-check-circle"></i> All materials available
                    </div>
                } *@

                <div class="kpi-action-hint">
                    <i class="uil uil-mouse-alt"></i> Click for detailed report
                </div>
            </div>
        </div>
    </div>

    <!-- Card 4: Untracked Demands (Without Milestones) -->
    <div class="col-12 col-sm-6 col-lg-3">
        <div class="dashboard-kpi-card border-secondary clickable h-100"
             data-bs-toggle="modal"
             data-bs-target="#untrackedDemandsModal"
             style="position: relative; overflow: hidden; cursor: pointer;">
            <!-- Background Icon (Faded) -->
            <i class="uil uil-eye-slash kpi-bg-icon" style="color: #6c757d;"></i>

            <!-- Content -->
            <div class="kpi-content">
                <div class="kpi-label">UNTRACKED DEMANDS</div>
                <div class="kpi-value text-secondary">@Model.UntrackedDemands.TotalUntrackedDemands</div>
                <div class="kpi-sublabel">Without Milestone Tracking</div>

                <div class="kpi-detail-row">
                    <span class="kpi-text">Overdue & Incomplete:</span>
                    <span class="kpi-value-sm text-danger">@Model.UntrackedDemands.OverdueIncomplete</span>
                </div>

                <div class="kpi-detail-row">
                    <span class="kpi-text">Due Soon:</span>
                    <span class="kpi-value-sm text-warning">@Model.UntrackedDemands.DueSoon</span>
                </div>

                <div class="kpi-highlight-compact">
                    ₹@((Model.UntrackedDemands.TotalUntrackedValue / 10000000).ToString("N2")) Cr Untracked Value
                </div>

                <div class="kpi-action-hint">
                    <i class="uil uil-mouse-alt"></i> Click for details
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ============================================ -->
<!-- SECTION 2: CHARTS (2 Charts Side by Side) -->
<!-- ============================================ -->
<div class="row mb-3">
    <!-- Chart 1: Material Health Distribution -->
    <div class="col-12 col-md-5">
        <div class="compact-card">
            <div class="compact-card-header">
                <h6 class="mb-0">Active Demands by Status</h6>
                <small class="text-muted">Distribution of @Model.ProcurementByStatus.Sum(x => x.DemandCount) active demands</small>
            </div>
            <div class="compact-card-body">
                <canvas id="procurementStatusChart" style="max-height: 170px;"></canvas>
            </div>
        </div>  
    </div>

    <!-- Chart 2: Top 5 At-Risk Demands -->
    <div class="col-12 col-md-7">
        <div class="compact-card">
            <div class="compact-card-header">
                <h6 class="mb-0">Top Vendors by Order Value</h6>
                <small class="text-muted">Top 5 vendors by total active orders</small>
            </div>
            <div class="compact-card-body">
                <canvas id="topVendorsChart" style="max-height: 200px;"></canvas>
            </div>
        </div>
    </div>
</div>


  
<!-- Table 6: Cost Variance Analysis - OPTIMIZED -->
@if (Model.CostVarianceAnalysis != null && Model.CostVarianceAnalysis.Any())
{
    <div class="row mb-3">
        <div class="col-12">
            <div class="compact-card">
                <div class="compact-card-header d-flex justify-content-between align-items-center clickable"
                     data-bs-toggle="collapse"
                     data-bs-target="#costVarianceTable">
                    <h6 class="mb-0">
                        <i class="uil uil-angle-down collapse-icon"></i>
                        💰 Cost Variance Analysis (@Model.CostVarianceAnalysis.Count demands)
                    </h6>
                    <small class="text-muted">
                        @{
                            var overBudget = Model.CostVarianceAnalysis.Count(x => x.Variance > 0);
                            var underBudget = Model.CostVarianceAnalysis.Count(x => x.Variance < 0);
                        }
                        <span class="text-danger">▲ @overBudget</span> |
                        <span class="text-success">▼ @underBudget</span>
                    </small>
                </div>
                <div class="collapse" id="costVarianceTable">
                    <div class="compact-card-body-table">
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 10%;">MMG File</th>
                                        <th style="width: 30%;">Description</th>
                                        <th style="width: 25%;" class="text-center">Cost Comparison</th>
                                        <th style="width: 12%;" class="text-center">Variance</th>
                                        <th style="width: 23%;">Vendor</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.CostVarianceAnalysis)
                                    {
                                        var varianceClass = item.Variance > 0 ? "text-danger" :
                                        item.Variance < 0 ? "text-success" : "text-muted";
                                        var varianceBadge = item.Variance > 0 ? "bg-danger" :
                                        item.Variance < 0 ? "bg-success" : "bg-secondary";
                                        var varianceIcon = item.Variance > 0 ? "↑" :
                                        item.Variance < 0 ? "↓" : "=";

                                        // Truncate description if too long
                                        var shortDesc = item.Item_Description != null && item.Item_Description.Length > 50
                                        ? item.Item_Description.Substring(0, 47) + "..."
                                        : item.Item_Description;

                                        // Calculate percentage of actual vs estimated for progress bar
                                        var costRatio = item.EstimatedCost > 0
                                        ? (double)(item.ActualCost / item.EstimatedCost * 100)
                                        : 0;
                                        var progressBarClass = costRatio > 100 ? "bg-danger" : "bg-success";

                                        <tr>
                                            <td><strong class="text-primary">@item.MMG_File_No</strong></td>
                                            <td>
                                                <small title="@item.Item_Description">@shortDesc</small>
                                            </td>
                                            <td>
                                                <div style="font-size: 0.85rem;">
                                                    <div class="d-flex justify-content-between mb-1">
                                                        <span class="text-muted" style="font-size: 0.75rem;">Est:</span>
                                                        <strong>₹@((item.EstimatedCost / 10000000).ToString("N2")) Cr</strong>
                                                    </div>
                                                    <div class="d-flex justify-content-between">
                                                        <span class="text-muted" style="font-size: 0.75rem;">Act:</span>
                                                        <strong class="@varianceClass">₹@((item.ActualCost / 10000000).ToString("N2")) Cr</strong>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge @varianceBadge" style="font-size: 0.85rem; min-width: 65px;">
                                                    @varianceIcon @Math.Abs(item.VariancePercent).ToString("N1")%
                                                </span>
                                            </td>
                                            <td>
                                                <small class="text-muted">
                                                    @if (item.Vendor_Name != null && item.Vendor_Name.Length > 30)
                                                    {
                                                        <span title="@item.Vendor_Name">@item.Vendor_Name.Substring(0, 27)...</span>
                                                    }
                                                    else
                                                    {
                                                        @item.Vendor_Name
                                                    }
                                                </small>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Summary Footer -->
                        @* <div class="p-3 bg-light border-top">
                            <div class="row text-center">
                                <div class="col-4">
                                    <small class="text-muted d-block">Total Estimated</small>
                                    <strong>₹@((Model.CostVarianceAnalysis.Sum(x => x.EstimatedCost) / 10000000).ToString("N2")) Cr</strong>
                                </div>
                                <div class="col-4">
                                    <small class="text-muted d-block">Total Actual</small>
                                    <strong>₹@((Model.CostVarianceAnalysis.Sum(x => x.ActualCost) / 10000000).ToString("N2")) Cr</strong>
                                </div>
                                <div class="col-4">
                                    <small class="text-muted d-block">Total Variance</small>
                                    <strong class="@(Model.CostVarianceAnalysis.Sum(x => x.Variance) > 0 ? "text-danger" : "text-success")">
                                        ₹@((Model.CostVarianceAnalysis.Sum(x => x.Variance) / 10000000).ToString("N2")) Cr
                                    </strong>
                                </div>
                            </div>
                        </div> *@
                    </div>
                </div>
            </div>
        </div>
    </div>
}



<!-- ============================================ -->
<!-- SECTION 3: ORDER TYPE CARDS (Casting, Forging, Pyro) -->
<!-- ============================================ -->
<div class="row mb-3 g-2">
    <!-- Card 1: Casting -->
    <div class="col-12 col-sm-6 col-lg-4">
        <div class="dashboard-kpi-card border-info clickable"
             data-bs-toggle="modal"
             data-bs-target="#castingModal"
             style="position: relative; overflow: hidden; cursor: pointer;">
            <!-- Background Icon (Faded) -->
            <i class="uil uil-wrench kpi-bg-icon" style="color: #17a2b8;"></i>

            <!-- Content -->
            <div class="kpi-content">
                <div class="kpi-label">CASTING</div>
                <div class="kpi-value text-info">@Model.CastingMetrics.TotalEnginesPossible</div>
                <div class="kpi-sublabel">Engines Possible</div>

                <div class="kpi-detail-row">
                    <span class="kpi-text">Material Issued:</span>
                    <span class="kpi-value-sm text-warning">@Model.CastingMetrics.TotalIssuedQty</span>
                </div>

                <div class="kpi-detail-row">
                    <span class="kpi-text">Available:</span>
                    <span class="kpi-value-sm text-success">@Model.CastingMetrics.TotalAvailableQty</span>
                </div>

                <div class="kpi-highlight-compact">
                    @Model.CastingMetrics.TotalParts Parts Tracked
                </div>

                @if (!string.IsNullOrEmpty(Model.CastingMetrics.BottleneckPart))
                {
                    <div class="kpi-sublabel mt-1" style="color: #dc3545; font-weight: 600;">
                        <i class="uil uil-exclamation-triangle"></i> Bottleneck: @Model.CastingMetrics.BottleneckPart
                    </div>
                }

                <div class="kpi-action-hint">
                    <i class="uil uil-mouse-alt"></i> Click for details
                </div>
            </div>
        </div>
    </div>

    <!-- Card 2: Forging -->
