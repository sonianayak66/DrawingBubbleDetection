				],
				"columns": [
					// { "data": "demand_No" },
					{ "data": "mmG_File_No" },
					{ "data": "receipt_No" },
					{
						"data": null,
						render: function (data) {
							return '<span>' + moment(data.receipt_Date).format('DD-MMM-YY') + '</span> '
						}
					},
					{
						"data": null,
						render: function (data) {
							return '<span class="float-end" style="margin-right:8px" >' + data.description + '-' + data.item_Code + '</span> '
						}
					},
					{
						"data": null,
						render: function (data) {
							return '<span class="float-end" style="margin-right:8px" >' + data.orderedQty.toLocaleString('en') + '</span> '
						}
					},
					{
						"data": null,
						render: function (data) {
							return '<span class="float-end" style="margin-right:8px"> ' + data.receiptQty.toLocaleString('en') + '</span> '
						}
					},
					{
						"data": null,
						render: function (data) {
							return '<input type="button" class="btn btn-default btn-small" style="cursor:pointer; color:blue" value="More Info" onclick="getSplitInfoDisplayDialog(' + data.receipt_dbkey + ')" /> '
						}
					}
				],
				buttons: [
					'excel'
				]
			});
			BoiDataTbl.draw();
		}

		//----------LRU---------------
		var lruDataTbl;
		var lru = "LRU";
		function getLRUTable() {
			var demandDbkey = $("#Demands").val();
			//console.log(demandDbkey);
			$.ajax({
				url: '/DemandManagement/GetPartsData?id=' + demandDbkey + '&partsType=' + lru,
				type: 'GET',
				success: function (data) {
					//console.log(data);
					tableData = data;
					applyLRUDatatable(tableData);
				}
			});
		}

		function applyLRUDatatable(tableData) {

			try {
				lruDataTbl.destroy();
			} catch (e) {
				//console.log(e);
			}

			lruDataTbl = $("#LRUtbl").DataTable({
				ajax: function (dataSent, callback, settings) {
					callback({ data: tableData });
				},
				responsive: true,
				paging: false,
				scrollY: 510,
				dom: 'Bfrtip',
				order: [
					[0, 'asc'],
					[3, 'desc']

				],
				"columns": [
					// { "data": "demand_No" },
					{ "data": "mmG_File_No" },
					{ "data": "receipt_No" },
					{
						"data": null,
						render: function (data) {
							return '<span>' + moment(data.receipt_Date).format('DD-MMM-YY') + '</span> '
						}
					},
					{
						"data": null,
						render: function (data) {
							return '<span class="float-end" style="margin-right:8px" >' + data.description + '-' + data.item_Code + '</span> '
						}
					},
					{
						"data": null,
						render: function (data) {
							return '<span class="float-end" style="margin-right:8px" >' + data.orderedQty.toLocaleString('en') + '</span> '
						}
					},
					{
						"data": null,
						render: function (data) {
							return '<span class="float-end" style="margin-right:8px"> ' + data.receiptQty.toLocaleString('en') + '</span> '
						}
					},
					{
						"data": null,
						render: function (data) {
							return '<input type="button" class="btn btn-default btn-small" style="cursor:pointer; color:blue" value="More Info" onclick="getSplitInfoDisplayDialog(' + data.receipt_dbkey + ')" /> '
						}
					}
				],
				buttons: [
