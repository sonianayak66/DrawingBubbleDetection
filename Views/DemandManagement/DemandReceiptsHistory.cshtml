				]
			});
			lruDataTbl.draw();

		}


		function getSplitInfoDisplayDialog(receipt_dbkey) {

			var urlinput = "/DemandManagement/ReceiptItemSplits?Id=" + receipt_dbkey;
			$.get(urlinput).done(function (response) {
				bootbox.dialog({
					title: "Split Info",
					message: response,
					size: 'extra-large',
					closeButton: true,
					className: 'custom-modal',
				});
				//new Choices('.ItemDbKey', {
				//    searchEnabled: true,
				//});

			});

		}

	
	</script>

}




