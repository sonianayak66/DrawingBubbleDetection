@model MPCRS.ViewModels.ProcurementStatusIndicator
@using MPCRS.Utilities
@{
    Layout = null;
    var DemandWriteAccess = UserData.IsAuthorized(User, Constants.UserPermissions.Demand_Write);
}
<style>
    .hori-timeline .events {
        border-top: 3px solid #e9ecef;
    }

        .hori-timeline .events .event-list {
            display: block;
            position: relative;
            text-align: center;
            padding-top: 70px;
            margin-right: 0;
        }

            .hori-timeline .events .event-list:before {
                content: "";
                position: absolute;
                height: 36px;
                border-right: 2px dashed #dee2e6;
                top: 0;
            }

            .hori-timeline .events .event-list .event-date {
                position: absolute;
                top: 38px;
                left: 0;
                right: 0;
                width: 80px;
                margin: 0 auto;
                border-radius: 4px;
                padding: 2px 4px;
                font-size:12px;
                font-weight:bold;
            }

    @@media (min-width: 1140px) {
        .hori-timeline .events .event-list {
            display: inline-block;
            width: 6.2%;
            padding-top: 20px;
            vertical-align: top;
        }

            .hori-timeline .events .event-list .event-date {
                top: -12px;
            }
    }

    .bg-soft-primary {
        background-color: rgba(64,144,203,.3) !important;
    }

    .bg-soft-success {
        background-color: rgba(71,189,154,.3) !important;
    }

    .bg-soft-danger {
        background-color: rgba(231,76,94,.3) !important;
    }

    .bg-soft-warning {
        background-color: rgba(249,213,112,.3) !important;
    }

    .card {
        border: none;
        margin-bottom: 18px;
        -webkit-box-shadow: 0 0 13px 0 rgba(236,236,241,.44);
        box-shadow: 0 0 13px 0 rgba(236,236,241,.44);
    }
</style>
 
<div class="card">

    @{
        string displayName = Model.DemandData.Demand_No + ":" + Model.DemandData.Item_Description;

        if (Model.DemandData.IsShortClosure == true)
        {
            displayName = displayName + " (Short Closed)";
        }
    }

        <div class="col-12 row">
            <div class="col-11">
                <h5 style="margin-top:15px!important">Procurement Timeline -  @displayName</h5>
            </div>
            <div class="col-1">
            <input type="button" class="float-end btn btn-secondary btn-sm" onclick="goToListTab()" value="Back" />
            </div>
        </div>

 
  

    <div class="card-body" style="padding-bottom:5px!important">
        <div class="hori-timeline" dir="ltr">
            <ul class="list-inline events" style="margin-bottom:5px!important">
                @{
                    int i = 0;
                    foreach (var History in Model.DemandHistory.OrderBy(x => x.ActionDate))
                    {
                        var displayDate = "";
                        string userName = MPCRS.Utilities.MPGlobals.GetOnedata("SELECT [UserName] FROM [dbo].[Users] WHERE [UserDbkey] = " + History.Updated_By);

                        displayDate = DateTime.Parse(History.ActionDate.ToString()).ToString("dd-MM-yy");

                        <li class="list-inline-item event-list">
                            <div>
                                @{
                                    if (DemandWriteAccess)
                                    {
                                        <div onclick="EditDemandHistory(@History.Demand_Procurement_History_Key)" style="cursor:pointer" class="event-date bg-soft-primary text-primary">@displayDate</div>
                                    }
                                    else
                                    {
                                        <div style="cursor:pointer" class="event-date bg-soft-primary text-primary">@displayDate</div>
                                    }
                                }
                               

                                @if (History.Do_Review == true)
                                {
                                    <p>@History.ActionStatus   (DO Review)</p>
                                }
                                else
                                {
                                    <p style="font-size:smaller;margin-bottom:5px">@History.ActionStatus</p>
                                }
                            </div>
                        </li>
                    }
                }

            </ul>
        </div>
    </div> 
</div>
<!-- end card -->
