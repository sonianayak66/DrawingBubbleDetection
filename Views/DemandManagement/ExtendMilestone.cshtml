@model List<MPCRS.Models.Procurement_Milestone>
@using MPCRS.Utilities;
@{
    Layout = null;
}
<div>
    <input type="hidden" id="UserID" value="@ViewBag.UserID" />
    <table class="table table-bordered table-hover rounded" id="MileStoneListTbl">
        <thead>
            <tr>
                @if (ViewBag.MilestoneID == 0)
                {
                    <th style="padding-left:10px">
                        <input type="checkbox" title="extend demand" id="SelectAllCheckbox" onchange="selectAllCheckboxes(this)" />
                    </th>
                }
                <th>MileStone</th>
                <th>Due Date</th>
            </tr>
        </thead>
        <tbody>
            @{
                if (ViewBag.MilestoneID == 0)
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td style="padding-left:10px">
                                <input type="checkbox" title="extend demand" class="milestone-checkbox" data-milestonedbkey="@item.MilestoneID" />
                            </td>
                            <td>@item.MilestoneName</td>
                            <td class="due-date">@MPGlobals.GetFormattedDate(item.CurrentDueDate)</td>
                        </tr>
                    }
                }
                else
                {
                    var Milestone = Model.Select(x => new { x.MilestoneID, x.MilestoneName, x.CurrentDueDate }).
                    Where(x => x.MilestoneID == ViewBag.MilestoneID).FirstOrDefault();
                    <tr>
                        <td hidden>
                            <input type="checkbox" checked title="extend demand" class="milestone-checkbox" data-milestonedbkey="@Milestone.MilestoneID" />
                        </td>
                        <td class="p-2">@Milestone.MilestoneName</td>
                        <td class="due-date">@MPGlobals.GetFormattedDate(Milestone.CurrentDueDate)</td>
                    </tr>

                }
            }

        </tbody>
    </table>
    <div class="card border">
        <div class="card-body d-flex align-items-center">
            <label for="ExtendedDate" class="form-label me-3">Extend to :</label>
            <input type="date" id="ExtendedDate" class="form-control" style="max-width: 150px;">
            <input type="button" class="btn btn-primary ms-auto" value="Submit" onclick="saveExtendedMileStone()" />
        </div>
    </div>
</div>