			function SubmitUserFolderAccess() {

		bootbox.confirm({
			title: "Confirm Access Changes",
			message: `
			<div style="text-align:left;">
			  <p><b>Please confirm before saving.</b></p>
			  <p>Changes will apply to the selected folder and all its subfolders.</p>
			  <p>If the user doesn't have access to a parent folder, it may still appear for navigation, but its contents will not be visible.</p>
			</div>
			`,
			buttons: {
				confirm: {
					label: "Yes, Save",
					className: "btn-primary"
				},
				cancel: {
					label: "Cancel",
					className: "btn-secondary"
				}	
			},
			callback: function (result) {
				if (!result) return;

				var accessarray = [];
				var table = document.getElementById("AccessRightTable");
				var rows_ = table.getElementsByTagName("tr");

				var useracess_data = document.getElementsByClassName("accessdataclss");
				var user_readaccess = document.getElementsByClassName("user_readaccess");
				var user_writeaccess = document.getElementsByClassName("user_writeaccess");
				var user_downloadaccess = document.getElementsByClassName("user_downloadaccess");

				for (var i = 0; i < rows_.length; i++) {
					var items = {};
					items.doc_config_dbkey = useracess_data[i].getAttribute('data-configdbkey');
					items.UserDbkey = useracess_data[i].getAttribute('data-UserDbkey');
					items.Document_Dbkey = useracess_data[i].getAttribute('data-folerid');
					items.ReadAccess = user_readaccess[i].checked;
					items.WriteAccess = user_writeaccess[i].checked;
					items.DownloadAccess = user_downloadaccess[i].checked;
					accessarray.push(items);
				}

				$.ajax({
					type: "POST",
					url: '/DocManager/SaveAccessDetail',
					async: false,
					data: {
						usraccessdata: JSON.stringify(accessarray),
					},
					cache: false,
					success: function (data) {
						bootbox.alert({
							message: "Saved Successfully"
						});
					},
					error: function () {
						bootbox.alert({
							message: "An error occurred while saving access details."
						});
					}
				});
			}
		});
	}

		$(document).on("change", ".user_writeaccess", function () {
			if (this.checked) {
				// find the corresponding read checkbox in the same row and check it
				$(this).closest("tr").find(".user_readaccess").prop("checked", true);
			}
		});



	</script>
