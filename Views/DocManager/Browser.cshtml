	<script>
		// ===== Reusable Tag/Pill Input =====
		// Parses a comma-separated string into pills, syncs back to a hidden input.
		function initTagInput(containerId, inputId, hiddenId, existingValue) {
			var container = document.getElementById(containerId);
			var input = document.getElementById(inputId);
			var hidden = document.getElementById(hiddenId);
			if (!container || !input || !hidden) return;

			// Parse existing comma-separated tags
			var tags = (existingValue || '').split(',').map(function (t) { return t.trim(); }).filter(function (t) { return t.length > 0; });

			function syncHidden() {
				hidden.value = tags.join(', ');
			}

			function createPill(text) {
				var pill = document.createElement('span');
				pill.className = 'tag-pill';
				pill.innerHTML = '<span class="tag-text">' + escapeHtml(text) + '</span><span class="tag-remove" title="Remove">&times;</span>';
				pill.querySelector('.tag-remove').addEventListener('click', function (e) {
					e.stopPropagation();
					var idx = tags.indexOf(text);
					if (idx > -1) tags.splice(idx, 1);
					pill.remove();
					syncHidden();
				});
				// Insert before the input
				container.insertBefore(pill, input);
			}

			function escapeHtml(str) {
				var div = document.createElement('div');
				div.textContent = str;
				return div.innerHTML;
			}

			function addTag(text) {
				text = text.trim();
				if (text.length === 0) return;
				// Avoid duplicates (case-insensitive)
				for (var i = 0; i < tags.length; i++) {
					if (tags[i].toLowerCase() === text.toLowerCase()) return;
				}
				tags.push(text);
				createPill(text);
				syncHidden();
			}

			// Render existing tags as pills
			for (var i = 0; i < tags.length; i++) {
				createPill(tags[i]);
			}

			// Handle key events: Enter, comma, Tab to add; Backspace to remove last
			input.addEventListener('keydown', function (e) {
				if (e.key === 'Enter' || e.key === ',') {
					e.preventDefault();
					addTag(input.value.replace(/,/g, ''));
					input.value = '';
				} else if (e.key === 'Backspace' && input.value === '' && tags.length > 0) {
					// Remove last tag
					var lastTag = tags.pop();
					var pills = container.querySelectorAll('.tag-pill');
					if (pills.length > 0) pills[pills.length - 1].remove();
					syncHidden();
				}
			});

			// Also handle paste — split by commas
			input.addEventListener('paste', function (e) {
				e.preventDefault();
				var pasted = (e.clipboardData || window.clipboardData).getData('text');
				var parts = pasted.split(',');
				for (var i = 0; i < parts.length; i++) {
					addTag(parts[i]);
				}
			});

			// Handle blur — add any remaining text as a tag
			input.addEventListener('blur', function () {
				if (input.value.trim().length > 0) {
					addTag(input.value);
					input.value = '';
				}
			});
		}

