		function SaveJsonform(id, parent, fromnode, tonode) {
    bootbox.confirm('Move <b>' + fromnode + '</b> to <b>' + tonode + '</b>?',
        function (result) {
            if (result) {
                $.ajax({
                    type: "POST",
                    url: '/DocManager/DndDocFolder?id=' + id + '&parent=' + parent,
                    dataType: 'json',
                    cache: false,
                    success: function (data) {
                        if (data.success) {
                            // Build success message
                            var itemTypeText = data.itemType === 'File' ? 'file' : 'folder';
                            var successMsg = 'Successfully moved ' + itemTypeText + ' <b>"' + data.itemName + '"</b> from <b>"' + data.sourceFolder + '"</b> to <b>"' + data.destinationFolder + '"</b>';
                            
                            bootbox.alert(successMsg); 
                           
                            // Load files for the destination folder to show updated contents
                            LoadFiles(parent, tonode);
                            
                            // Update localStorage to track the new parent as selected node
                            localStorage['select_node'] = parent + "#" + tonode;
                            
                        } else {
                            // ❌ MOVE FAILED - Refresh tree to restore original position
                            bootbox.alert({
                                message: 'Move failed: ' + data.msg,
                                callback: function () {
                                    // Refresh only the tree, not entire page
                                    $('#jstree').jstree(true).refresh();
                                }
                            });
                        }
                    },
                    error: function (xhr, status, error) {
                        // ❌ ERROR - Refresh tree to restore original position
                        bootbox.alert({
                            message: 'Error moving item: ' + error,
                            callback: function () {
                                $('#jstree').jstree(true).refresh();
                            }
                        });
                    }
                });
            } else {
                // ❌ USER CANCELLED - Refresh tree to restore original position
                $('#jstree').jstree(true).refresh();
            }
        });
}


		function LoadFiles(folderid, foldername) {
			document.getElementById("SearchTagsMain").placeholder = "Search " + foldername + " folder";
			document.getElementById("activenodeid").value = folderid;
			$('#Div_Load_Files').html('');
			$.ajax({
				url: '/DocManager/GetFilesList?folderid=' + folderid,
				dataType: 'html',
				success: function (data) {
					$('#Div_Load_Files').html(data);
					var Windowheight = window.innerHeight;
					var x = $("#tbl_files").position();
					var tableHeight = (Windowheight - x.top) * 0.75;

					// Initialize DataTable with pagination
					$('#tbl_files').DataTable({
						"dom": "lifrtp",
						// paging: false,           
						// pageLength: 50,         
					 // 	scrollY: tableHeight + 'px',
						// scrollCollapse: true,   
						// lengthMenu: [[25, 50, 100, -1], [25, 50, 100, "All"]],  
					});
				}
			});
		}

		function LoadFilesByFilter() {
			var searchtag = document.getElementById("SearchTagsMain").value;
			var parentid = document.getElementById("activenodeid").value;
			if (searchtag.length >= 1) {
				$('#Div_Load_Files').html('');
				$.ajax({
					url: '/DocManager/GetFilesList?searchtags=' + searchtag + '&parentid=' + parentid,
					dataType: 'html',
					success: function (data) {
						$('#Div_Load_Files').html(data);
						var Windowheight = window.innerHeight;
						var x = $("#tbl_files").position();
						var tableHeight = (Windowheight - x.top) * 0.75;

						if ($.fn.DataTable.isDataTable('#tbl_files')) {
							$('#tbl_files').DataTable().destroy();
						}

						// Initialize DataTable with pagination
						$('#tbl_files').DataTable({
							"dom": "lifrtp",
							paging: true,           // ✅ Enable paging
							pageLength: 50,         // ✅ Show 50 rows per page
							scrollY: tableHeight + 'px',
							scrollCollapse: true,
							lengthMenu: [[25, 50, 100, -1], [25, 50, 100, "All"]],
							drawCallback: function () {
								highlightSearchText(searchtag);
							}
						});

						setTimeout(function () {
							highlightSearchText(searchtag);
						}, 100);
					}
				});
			} else {
				alert("Please search with 3 or more character");
			}
		}
		function escapeRegExp(string) {
			return string.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
		}

				function removeHighlight() {
			$('#tbl_files tbody .search-highlight').each(function () {
				$(this).replaceWith($(this).text());
			});
		}

		function highlightSearchText(searchText) {
			if (!searchText || searchText.trim() === '') return;

			removeHighlight();

			var regex = new RegExp('(' + escapeRegExp(searchText) + ')', 'gi');

			$('#tbl_files tbody tr').each(function () {
				// File Name column = first td
				var fileCell = $(this).find('td').eq(0);

				// Find anchor/text inside first column
				fileCell.find('a, span, div').each(function () {
					var html = $(this).html();
					if (html) {
						$(this).html(html.replace(regex, '<span class="search-highlight">$1</span>'));
					}
				});
			});
		}

