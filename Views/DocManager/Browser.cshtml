		var jsondata;
		function LoadJstree() {
			var dataUrl = "/DocManager/GetFolders/";
			var select_node_id = localStorage['select_node'] || 'defaultValue';
			try {
				$.ajax({
					type: "Get",
					url: dataUrl,
					success: function (data) {
						var dataStrng = JSON.stringify(data);
						var Modified_data = dataStrng.replace(/Class/g, "class");
						jsondata = JSON.parse(Modified_data);

						// Mark all folder nodes as expandable so they show expand arrow
						// This allows folders with only files (no subfolders) to be expanded
								// Mark all folder nodes as expandable by adding a dummy loading node
						function markFoldersAsExpandable(nodes) {
							if (nodes && nodes.length > 0) {
								for (var i = 0; i < nodes.length; i++) {
									// If a folder has no children array, or empty children
									if (!nodes[i].children || nodes[i].children.length === 0) {
										// Add a temporary loading placeholder
										nodes[i].children = [{
											id: nodes[i].id + '_loading',
											text: 'Loading...',
											icon: 'fa fa-spinner fa-spin',
											state: { disabled: true }
										}];
									} else if (Array.isArray(nodes[i].children)) {
										// Recursively process subfolders
										markFoldersAsExpandable(nodes[i].children);
									}
								}
							}
						}
						markFoldersAsExpandable(jsondata);

						var nodelog = $('#jstree').jstree(
							{
								'core': {
									'data': jsondata,
									'check_callback': function (operation, node, parent, position, more) {
										// Check permission for drag-drop operations
										if (operation === 'move_node') {
											// Check if user has DOC_Dnd permission
											var hasDndPermission = @Json.Serialize(hasDndPermission);
											if (!hasDndPermission) {
												console.log('User does not have drag-drop permission');
												return false; // Prevent move
											}
                    
											// Prevent files from being dropped into files (only into folders)
											if (node.icon && node.icon.indexOf('fa-file') !== -1) {
												return parent.icon && parent.icon.indexOf('fa-folder') !== -1;
											}
										}
										return true;
									},
								},
								"search": {
									"case_sensitive": false,
									"show_only_matches": true,
									"show_only_matches_children": true,
									"search_callback": function (searchText, node) {
										var text = (node.text || "").toLowerCase().trim();
										searchText = (searchText || "").toLowerCase().trim();
										var searchType = ($("#searchType").val() || "contains").toLowerCase();

										if (searchType === "startswith") {
											return text.startsWith(searchText);
										}
										else if (searchType === "endswith") {
											return text.endsWith(searchText);
										}
										else {
											return text.indexOf(searchText) !== -1;
										}
									}
								},
								//"plugins": ["html_data", "contextmenu", "dnd", "search", "types"],
								  "plugins": @Json.Serialize(hasDndPermission ? 
									new[] { "html_data", "contextmenu", "dnd", "search", "types" } : 
									new[] { "html_data", "contextmenu", "search", "types" }),
								"contextmenu": {
									"items": function ($node) {
										console.log('np',$node);
										var textdata = $node.text;
										var isFile = $node.icon && $node.icon.indexOf('fa-file') !== -1;

										// Different context menu for files vs folders
										if (isFile) {
											// return {
											// 	"ViewFile": {
											// 		"label": "View File",
											// 		"action": function (obj) {
											// 			if ($node.original.data && $node.original.data.document_Dbkey) {
											// 				ViewDocument($node.original.data.document_Dbkey);
											// 			}
											// 		}
											// 	},
											// 	"RenameFile": {
											// 		"label": "Rename File",
											// 		"action": function (obj) {
											// 			if ($node.original.data && $node.original.data.document_Dbkey) {
											// 				RenameDoc($node.original.data.document_Dbkey);
											// 			}
											// 		}
											// 	},
											// 	"DeleteFile": {
											// 		"label": "Delete File",
											// 		"action": function (obj) {
											// 			DeleteFolder($node.id, "File");
											// 		}
											// 	}
											// };
											  return {}; 
										} else {
											// Existing folder context menu
											return {
												"UploadFile": {
													"label": "Upload File",
													"action": function (obj) {
														GetCreatepopUp_Doc($node.id, 0, "UploadFile");
													}
												},
												"CreateFloder": {
													"label": "Create Folder",
													"action": function (obj) {
														GetCreatepopUp_Doc($node.id, 0, "CreateFolder");
													}
												},
												"UpdateFolder": {
													"label": "Update Folder",
													"action": function (obj) {
														GetCreatepopUp_Doc($node.id, 1, "UpdateFolder");
													}
												},
												"Delete": {
													"label": "Delete Folder",
													"action": function (obj) {
														DeleteFolder($node.id, "Folder");
													}
												},
												"Access": {
													"label": "Access Config",
													"action": function (obj) {
														GetAccessConfigFolderWise($node.id);
													}
												},
											};
										}
									}
								}
							}).bind("move_node.jstree", function (e, data) {
								var noden = $('#jstree').jstree(true).get_node(data.node.parent);
								SaveJsonform(data.node.id, data.node.parent, data.node.text, noden.text);
								}).bind("open_node.jstree", function (e, data) {
							// Lazy load files when a folder is expanded
							var node = data.node;
								 // Skip loading files for Root node (ID = -1)
							if (node.id === '-1') {
								console.log('Root node expanded - folders only, no files at root level');
								return;
							}

							console.log('Folder opened:', node.id, node.text);

							// Check if this folder already has file children loaded
							var hasFileChildren = false;
							var hasLoadingPlaceholder = false;

							if (node.children && node.children.length > 0) {
								for (var i = 0; i < node.children.length; i++) {
									var childNode = $('#jstree').jstree(true).get_node(node.children[i]);
									// Check if it's a loading placeholder
									if (node.children[i].indexOf('_loading') !== -1) {
										hasLoadingPlaceholder = true;
									}
									// Check if any child is a file (files have the file icon classes)
									else if (childNode.icon && childNode.icon.indexOf('fa-file') !== -1) {
										hasFileChildren = true;
										break;
									}
								}
							}

							// Load files if not already loaded
							if (!hasFileChildren) {
								console.log('Loading files for folder:', node.id);
								$.ajax({
									url: '/DocManager/GetFolderChildren?folderId=' + node.id,
									type: 'GET',
									dataType: 'json',
									success: function (fileNodes) {
										console.log('Files loaded:', fileNodes.length, 'files');
										var tree = $('#jstree').jstree(true);

										// Remove loading placeholder if it exists
										if (node.children && node.children.length > 0) {
											for (var i = 0; i < node.children.length; i++) {
												var childId = node.children[i];
												if (childId.indexOf('_loading') !== -1) {
													tree.delete_node(childId);
													console.log('Removed loading placeholder');
													break;
												}
											}
										}

										// Add files to the tree
										if (fileNodes && fileNodes.length > 0) {
											$.each(fileNodes, function (index, fileNode) {
												tree.create_node(node, fileNode, 'last');
											});
											console.log('Files added to tree');
										} else {
											console.log('No files in this folder');
										}
									},
									error: function (xhr, status, error) {
										console.error('Error loading files:', error);
									}
								});
							} else {
								console.log('Files already loaded for this folder');
							}
							}).bind("select_node.jstree", function (e, data) {

										   // Check if node is a file or folder
								var isFile = false;

								// Method 1: Check icon (files have different icons)
								if (data.node.icon && (
									data.node.icon.includes('fa-file') ||
									data.node.icon.includes('file-pdf') ||
									data.node.icon.includes('file-excel') ||
									data.node.icon.includes('file-word') ||
									data.node.icon.includes('file-powerpoint')
								)) {
									isFile = true;
								}

								// Method 2: Check node data if available
								if (data.node.data && data.node.data.Item_type === 'File') {
									isFile = true;
								}

								// Only load files if it's a FOLDER
								if (!isFile) {
									localStorage['select_node'] = data.selected[0] + "#" + data.node.text;
									LoadFiles(data.selected[0], data.node.text);
								} 
							 
							}).on('loaded.jstree', function (e, data) {
								$('#jstree').jstree('select_node', select_node_id.split("#")[0]);
								LoadFiles(select_node_id.split("#")[0], select_node_id.split("#")[1]);
							});
					}
				});
			} catch (e) {
				console.log("Begin catch")
				console.log(e.message);
			}
		}

