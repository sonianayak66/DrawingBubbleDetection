@using MPCRS.Utilities;
@{
	ViewData["Title"] = "Document Browser";
	var hasWritePermission = UserData.IsAuthorized(User, Constants.UserPermissions.DOC_Write);
}
<link href="~/lib/bootstrap/dist/css/bootstrap-icons.css" rel="stylesheet" />
<div class="row">
	<h4>Document Browser</h4>
	<div class="row mb-3">
		<div class="col-10 p-2 ">
			<input type="text" name="query" id="query" class="form-control"
				   autocorrect="off" autocomplete="off"
				   placeholder="Enter Search Phrase">
		</div>
		<div class="col-2 p-2 ">
			<button class="btn-close" id="btnResetSearch" type="button" aria-label="Close"></button>
			<button class="btn btn-secondary me-1 mb-1" id="btnSearch" type="button">Search</button>

		</div>
		<div class="collapse" id="searchResultPane">
			<table id="searchResultTree" class="table table-hover">
				<colgroup>
					<col width="30em"></col>
					<col width="30em"></col>
					<col width="30em"></col>
					<col width="30em"></col>
					<col width="30em"></col>
					<col width="30em"></col>
					<col width="30em"></col>
					<col width="30em"></col>
					<col width="30em"></col>
					<col width="30em"></col>

				</colgroup>
				<thead>
					<tr>
						<th style="display:none">Key</th>
						<th style="display:none">Folder</th>
						<th>Name</th>
						<th>Description</th>
						<th>Type</th>
						<th>Size</th>
						<th>Status</th>
						<th>Updated By</th>
						<th>Updated On</th>
						<th>Search Tags</th>

					</tr>
				</thead>
				<tbody>
					<tr>
						<td style="display:none" />
						<td style="display:none" />
						<td />
						<td />
						<td />
						<td />
						<td />
						<td />
						<td />
						<td />

					</tr>
				</tbody>
			</table>
		</div>

	</div>
	<br />
</div>

<div class="row">
	<div class="col-4">
		<div class="btn-toolbar" role="toolbar" aria-label="Toolbar with button groups">
			<div class="btn-group me-2 mb-2 btn-group-xs" role="group" aria-label="First group">
				<button class="btn btn-secondary btn-xs" type="button" id="createFolderbtn" onclick="CreateFolder('CreateFolder')"><i class="uil uil-folder-plus fs-1"></i></button>
				<button class="btn btn-secondary btn-xs" type="button" id="updateFolderbtn" onclick="CreateFolder('UpdateFolder')" disabled><i class="uil uil-edit fs-1"></i></button>
				<button class="btn btn-secondary btn-xs" type="button" id="uploadfilebtn" onclick="CreateFolder('UploadFile')" disabled><i class="uil uil-file-upload fs-1"></i></button>
				@{
					if (hasWritePermission)
					{
						<button class="btn btn-secondary btn-xs" type="button" id="accessconfigbtn" onclick="GetFolderAccessInfo()"><i class="uil uil-setting fs-1"></i></button>
					}
				}
				<button class="btn btn-secondary btn-xs" type="button" onclick="ReloadPage()"><i class="uil uil-refresh fs-1"></i></button>
			</div>
		</div>

		<div id="taxonTree" class="fancytree-fade-expander">

		</div>
	</div>
	<div class="col-8">
		<nav aria-label="breadcrumb">
			<ol class="breadcrumb mb-0">
			</ol>
		</nav>
		<hr />
		<div id="tmplInfoPane">
			<!-- Document Detail -->

		</div>

	</div>
</div>





@section scripts{
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}

	<script type="text/javascript">
		if (!$.browser) {
			console.warn("Monkey-patching jQuery.browser.msie to get BBQ working");
			var ua = navigator.userAgent.toLowerCase();
			$.browser = { msie: /msie/.test(ua) && !/opera/.test(ua) };
		}
	</script>
	<script src="~/fancytree/jquery.ba-bbq.min.js"></script>
	<script src="~/fancytree/handlebars.min.js"></script>
	<script src="~/fancytree/jquery.fancytree-all-deps.min.js"></script>
	<link href="~/fancytree/ui.fancytree.min.css" rel="stylesheet" />
	<link href="~/tree/style.css" rel="stylesheet" />
    <link href="~/tree/jquery.contextmenu.min.css" rel="stylesheet" />
	<script src="~/tree/jquery.contextmenu.min.js"></script>
	<script src="~/js/bootbox.all.min.js"></script>
	<script src="~/tree/taxonomy-browser.js" asp-append-version="true"></script>

	<script>
		function Approval(id) {
			var responseMsg = "Deleted Successfully.";
			return bootbox.confirm('Are you sure!.. You wanna Give Approval ?', function (result) {
				if (result) {
					$.ajax({
						url: "/DocManager/Approve",
						type: 'POST',
						datatype: JSON,
						data: { Document_Dbkey: id },
						success: function (data) {
							responseMsg = data.msg;
							if (data.success) {
								bootbox.alert(responseMsg
									, function () {
										window.location.reload();
									});
							}
							else {
								bootbox.alert(responseMsg
									, function () {
										window.location.reload();
									});
							}
							
						}
					});
				}
			});
		}

		function Rejecetion(id) {
			var responseMsg = "Deleted Successfully.";
			return bootbox.confirm('Are you sure!.. You wanna Reject the Approval ?', function (result) {
				if (result) {
					$.ajax({
						url: '/DocManager/Reject',
						type: 'POST',
						data: { Document_Dbkey: id },
						success: function (data) {
							responseMsg = data.msg;
							if (data.success) {
								bootbox.alert(responseMsg
									, function () {
										window.location.reload();
									});
							}
							else {
								bootbox.alert(responseMsg
									, function () {
										window.location.reload();
									});
							}
						}
					});
				}
			});
		}

		function Deletion(id) {
			var responseMsg = "Deleted Successfully.";                                                                                                                                                                                                                                                                                                                                                       
			return bootbox.confirm('Are you sure!.. You wanna Delete ?', function (result) {
				if (result) {
					$.ajax({
						url: '/DocManager/Delete',
						type: 'POST',
						data: { Document_Dbkey: id },
						success: function (data) {
							responseMsg = data.msg;
							if (data.success) {
								bootbox.alert(responseMsg
									, function () {
										window.location.href = '/DocManager/Index';
									});
							}
							else {
								bootbox.alert(responseMsg
									, function () {
										window.location.href = '/DocManager/Index';
									});
							}
						}
					});
				}
			});
		}


		function Rename(Document_Dbkey) {
			$.ajax({
				url: '/DocManager/Rename?Document_Dbkey=' + Document_Dbkey,
				type: 'GET',
				success: function (data) {
					bootbox.alert({
						message: data,
						title: "Edit",
						size: 'Small',
						buttons: {
							ok: {
								className: 'd-none'
							}
						}
					});
				}
			});
		}

		function Save()
		{
			var responseMsg="Saved Successfully.";
			var Document_Dbkey = $('#Document_Dbkey').val();
			var Refrence_Title = $('#Refrence_Title').val();
			var Description = $('#Description').val();
			var SearchTags = $('#SearchTags').val();
			var details = { Document_Dbkey: Document_Dbkey, Refrence_Title: Refrence_Title, Description: Description, SearchTags: SearchTags };
			$.ajax({
				type: 'POST',
				url: '/DocManager/Rename/',
				// contentType: 'application/json', 
				data: details,
				success: function (data) {
					responseMsg=data.msg;
					if(data.success)
					{
						bootbox.alert(responseMsg
							, function () {
								window.location.reload();
							});
					}
					else{
						bootbox.alert(responseMsg
							, function () {
								window.location.reload();
							});
					}
				}
			});

		}
		
	</script>
}






