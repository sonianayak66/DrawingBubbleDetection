                message: '<p class="text-center mb-0"><img src="/assets/img/searching_doc.gif" alt="Loading..." width="200" height="200"> <p class="text-center mb-0">Searching relevant documents..</p></p>',
                closeButton: false
            });
            if (!userInput) return;
            document.getElementById("responsebody").innerHTML = '';
            $('#responsebody').append('<p>' + userInput + '</p>');
            $.ajax({
                url: '/GenAI/GetDoc_Response?userPrompt=' + userInput,
                method: 'POST',
                contentType: 'application/json',
                success: function (data) {
                    bootbox.hideAll();
                    console.log(data);
                    response = CheckforNewLine(data);
                    $('#responsebody').append(response);
                },
                error: function (xhr, status, error) {
                    bootbox.hideAll();
                }
            });
        });

        function toggleCard() {
            const card = document.getElementById('responseHistory');
            const inputColumn = document.getElementById('responsebody');
            const iconContainer = document.getElementById('iconContainer');
            const icon = document.querySelector('.toggle-icon i');

            const isCollapsed = card.classList.toggle('collapsed');

            // Adjust icon based on the card state
            if (isCollapsed) {
                icon.classList.remove('fas', 'fa-arrow-right');
                icon.classList.add('fas', 'fa-arrow-left');
                iconContainer.style.display = 'block';
            } else {
                icon.classList.remove('fas', 'fa-arrow-left');
                icon.classList.add('fas', 'fa-arrow-right');
                iconContainer.style.display = 'none'; 
            }
        }

        var DocResponseList = [];
        function getDocResponseLogs() {
            $.ajax({
                type: "Get",
                url: "/GenAI/GetDocResponseLog",
                success: function (data) {
                    DocResponseList = JSON.parse(data);
                    generateTable();
                    //console.log(DocResponseList);
                }
            })
        }
        function generateTable() {
            var groupedLogs = getDateGroups(DocResponseList);
            let tableHtml = `<div class="card-header"><b>History</b></div><br />`;

            Object.entries(groupedLogs).forEach(([timeFrame, ids]) => {
                
                if (ids.length > 0) { 
                    var timeFrameDisplay = timeFrame.replace(/([a-z])([A-Z])/g, '$1 $2').replace(/(\d+)/g, ' $1 ').trim();
                    var formattedTimeFrame = timeFrameDisplay.charAt(0).toUpperCase() + timeFrameDisplay.slice(1);

                    tableHtml += `<div><b>${formattedTimeFrame}</b></div>`;

                    ids.forEach(id => { 
                        var questionData = DocResponseList.find(q => q.Id === id);
                        //console.log(questionData);
                        if (questionData) { // Check if questionData exists
                            const truncatedQuestion = truncateString(questionData.Question);
                           // tableHtml += `<div><a class="cursor-pointer" onclick="showResponseHistory('${encodeURIComponent(questionData)}')" title="${questionData.Question}">${truncatedQuestion}</a></div>`;
                            tableHtml += `<div><a class="cursor-pointer" onclick="showResponseHistory('${id}')" title="${questionData.Question}">${truncatedQuestion}</a></div>`;
                        }
                    });

                    tableHtml += `<br />`;
                }
            });

            document.getElementById('logsTable').innerHTML = tableHtml;
        }

        function getDateGroups(logs) {
            var today = new Date();
            today.setHours(0, 0, 0, 0); // Set time to midnight
            //console.log(logs);
            var groupedLogs = {
                today: [],
                yesterday: [],
                previous7Days: [],
                previous30Days: [],
                previous90Days: [],
                previous180Days: [],
                previous365Days: []
            };

            logs.forEach(log => {
                var updatedOn = new Date(log.UpdatedOn);
                updatedOn.setHours(0, 0, 0, 0); // Set log time to midnight

                var diffDays = Math.floor((today - updatedOn) / (1000 * 60 * 60 * 24));

                if (diffDays === 0) {
                    groupedLogs.today.push(log.Id);
                } else if (diffDays === 1) {
                    groupedLogs.yesterday.push(log.Id);
                } else if (diffDays <= 7) {
                    groupedLogs.previous7Days.push(log.Id);
                } else if (diffDays <= 30) {
                    groupedLogs.previous30Days.push(log.Id);
                } else if (diffDays <= 90) {
                    groupedLogs.previous90Days.push(log.Id);
                }else if (diffDays <= 180) {
                    groupedLogs.previous90Days.push(log.Id);
                } else if (diffDays <= 365) {
                    groupedLogs.previous365Days.push(log.Id);
                }
            });
            //console.log(groupedLogs);
            return groupedLogs;
        }
       

        function showResponseHistory(questionID) {
            //console.log(questionID);
            var questionData = DocResponseList.find(q => q.Id == questionID);
            response = CheckforNewLine(questionData.SqlQuery);
           
            if (questionData) {

                //console.log(response);
                document.getElementById("user-input").value = questionData.Question || '';
                document.getElementById("responsebody").innerHTML = response || questionData.SqlQuery || '';
            }
        }

        function CheckforNewLine(responseData) {
            var formatedResponse = responseData.replace(/\\n/g, '<br>');
            return formatedResponse;
        }

