        function filterthisTable() {
            $("#myInput").on("keyup", function () {
                var value = $(this).val().toLowerCase();
                $("#DeclarationTbl tr").filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });
        }
        function loadJSTree() {
            $('div#jstree').jstree({
                plugins: ["checkbox", "table", "search"],
                'core': {
                    'data': {
                        'url': '/GenAI/GetDocumentEmbeddingStaus',
                        'data': function (node) {
                            console.log(node);
                            return { 'id': node.id };
                        }
                    },
                    "check_callback": false
                },
                "table": {
                    columns: [
                        { width: "auto", header: "Folder", title: "_DATA_" },
                        { width: "200px", value: "totalFileCount", header: "No. of Files", valueClass: "spanclass" },
                        { width: "200px", value: "embeddedFileCount", header: "File Embedded", valueClass: "spanclass" },
                        // { width: "100", value: "status_In_VectorDB", header: "Status", valueClass: "spanclass" },
                        //  { width: "100", value: "vectorExecutionStartTime", header: "Embedding Start Time", valueClass: "spanclass" },
                        { width: "200px", value: "vectorExecutionEndTime", header: "Embedding End Time", valueClass: "spanclass" },
                        // Add other columns as needed
                    ],
                    resizable: true,      
                    fixed: true
                },
                "search": {
                    //"case_insensitive": true,
                    "show_only_matches": true,
                    //"show_only_matches_children": true
                },

            }).on("ready.jstree", function () {
                console.log("Tree is ready.");
                $('.jstree-table-cell').each(function () {
                    $(this).css('width', '150px'); // Adjust the width value as needed
                });
                // Use setTimeout to ensure the headers are rendered before adding classes
                setTimeout(function () {
                    $('div.jstree-table th').eq(1).addClass('header-file-count'); // 2nd header
                    $('div.jstree-table th').eq(2).addClass('header-file-embedded'); // 3rd header
                    $('div.jstree-table th').eq(3).addClass('header-embedding-end-time'); // 4th header
                }, 100); // Adjust the timeout as necessary
            });
