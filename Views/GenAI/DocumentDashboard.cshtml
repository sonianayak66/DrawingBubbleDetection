<link href="~/css/style.min.css" rel="stylesheet" />
<style>
    .scroll {
        /* // max-height: 500px; */
        max-height: 70vh;
        overflow-y: auto;
    }

    .Notupdated {
        color: black;
    }

    .accesscheckbox {
        width: 16px !important;
        height: 16px !important;
    }

    .jstree-default .jstree-anchor {
        line-height: 23px;
        height: 23px;
    }

    .jstree-table {
        table-layout: fixed; /* Use fixed layout for the table */
        width: 100%; /* Full width */
    }

        /* Ensure header columns do not change width */
        .jstree-table th {
            width: 150px !important; /* Use consistent width for headers, adjust as necessary */
            overflow: hidden; /* Prevent overflow */
            text-overflow: ellipsis; /* Add ellipsis for long text */
            white-space: nowrap; /* Prevent text wrapping */
        }

            /* Adjust specific header widths */
            .jstree-table th:nth-child(1) {
                width: 300px;
            }
            /* Folder column */
            .jstree-table th:nth-child(2) {
                width: 150px !important;
            }
            /* No. of Files column */
            .jstree-table th:nth-child(3) {
                width: 150px !important;
            }
            /* File Embedded column */
            .jstree-table th:nth-child(4) {
                width: 150px !important;
            }

    .jstree-table-header, .jstree-table-cell {
        width: 150px;
        /* Adjust this width as per requirement */
    }
</style>
<div>
    <div class="row">
        <div class="col-md-6">
