@{
    ViewData["Title"] = "Upload PDF";
}

<h2>Upload PDF for OCR</h2>

<form method="post" enctype="multipart/form-data" asp-action="UploadPdf">
    <div class="form-group">
        <input type="file" name="pdfFile" class="form-control" />
    </div>
    <div class="form-group">
        <button type="submit" class="btn btn-primary">Upload and Process</button>
    </div>
</form>

@if (ViewBag.ExtractedText != null)
{
    <div class="alert alert-danger">@ViewBag.ExtractedText</div>
}
