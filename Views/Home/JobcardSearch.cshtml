@{
    ViewData["Title"] = "Search Job Card";
}

<div class="row">
    <h2>Search result of Job Card - @ViewBag.JobCardNumber</h2>
    <hr />
    @{
        if (@ViewBag.JobCardNumber != "NOT FOUND")
        {
            <div class="col-md-12">
                <div class="row">
                    <div class="card">
                        <div class="card-body">
                            <partial name="../Home/_JobcardDetails.cshtml" model="@ViewBag.JobCardNumber" />
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="col-md-12">
                <h4>No data available for Job Card - @ViewBag.JobCardNumber</h4>
            </div>
        }
    }
</div>
