@model MPCRS.ViewModels.Master_RawmaterialVM
@using MPCRS.Utilities
@{
    var Permission_Write = UserData.IsAuthorized(User, Constants.UserPermissions.Raw_Materials_Write);
    var RawmaterialsTypeList = MPCRS.Utilities.Masters.GetMaster_General("Raw_Material_Type");
    var mat_uom_list = MPCRS.Utilities.Masters.GetMaster_General("UOM");
}

<div class="container-fluid px-0">
    <form id="CreateRawmaterial" method="post" class="needs-validation" novalidate="novalidate">
        <div class="row mb-3">
            <div class="col-md-6">
                <h4 class="mb-0">@(Model.RawmaterialGuid == null ? "Create " : "Edit ")Raw Material</h4>
            </div>
            <div class="col-md-6 text-end">
                @{
                    if (Permission_Write)
                    {
                        <button type="button" class="btn btn-primary" onclick="Save()">Save</button>
                        <button type="button" class="btn btn-secondary ms-2" onclick="$('.bootbox.modal').modal('hide')">Cancel</button>
                    }
                }
            </div>
        </div>
        <hr class="my-3" />
        <input asp-for="RawmaterialGuid" type="hidden" value="@Model.RawmaterialGuid" />
        <input asp-for="Raw_material_Dbkey" type="hidden" value="@Model.Raw_material_Dbkey" />
        <input asp-for="IsUsedInDemand" type="hidden" value="@Model.IsUsedInDemand" />
        @if (Model.IsUsedInDemand)
        {
            <div class="alert alert-warning mb-3" role="alert">
                <i class="fas fa-exclamation-triangle me-2"></i>
                <strong>Note:</strong> This material is used in a demand. Material Name, Type, and Dimensions cannot be modified.
            </div>
        }

        <div class="row g-3">
            <div class="col-md-12">
                <div class="form-floating">
                    <input class="form-control @(Model.IsUsedInDemand ? "bg-light" : "")" asp-for="Material_name" type="text" readonly="@Model.IsUsedInDemand">
                    <label asp-for="Material_name"></label>
                </div>
            </div>

            <div class="col-md-12">
                <div class="form-floating">
                    <select asp-for="RM_Type" class="form-select searchable @(Model.IsUsedInDemand ? "bg-light" : "")" asp-items="@RawmaterialsTypeList" disabled="@Model.IsUsedInDemand"></select>
                    <label asp-for="RM_Type"></label>
                    @if (Model.IsUsedInDemand)
                    {
                        <input type="hidden" asp-for="RM_Type" value="@Model.RM_Type" />
                    }
                </div>
            </div>

            <div class="col-md-6">
                <div class="form-floating">
                    <input class="form-control @(Model.IsUsedInDemand ? "bg-light" : "")" asp-for="Dia_mm" type="text" readonly="@Model.IsUsedInDemand">
                    <label asp-for="Dia_mm"></label>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-floating">
                    <input class="form-control @(Model.IsUsedInDemand ? "bg-light" : "")" asp-for="inner_Dia_mm" type="text" readonly="@Model.IsUsedInDemand">
                    <label asp-for="inner_Dia_mm"></label>
                </div>
            </div>

            <div class="col-md-6">
                <div class="form-floating">
                    <input class="form-control @(Model.IsUsedInDemand ? "bg-light" : "")" asp-for="Thick_mm" type="text" readonly="@Model.IsUsedInDemand">
                    <label asp-for="Thick_mm"></label>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-floating">
                    <select asp-for="RM_UOM" class="form-select searchable" asp-items="@mat_uom_list"></select>
                    <label asp-for="RM_UOM"></label>
                </div>
            </div>

            <div class="col-md-12">
                <div class="form-floating">
                    <input class="form-control" asp-for="Density" type="text">
                    <label asp-for="Density"></label>
                </div>
            </div>

            <div class="col-md-6">
                <div class="form-floating">
                    <input class="form-control" asp-for="RMQtyPerEngine" id="RMQtyPerEngine" type="number" step="0.01">
                    <label asp-for="RMQtyPerEngine"></label>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-floating">
                    <input class="form-control" asp-for="MinInventoryThreshold" type="number" step="0.01">
                    <label asp-for="MinInventoryThreshold"></label>
                </div>
            </div>
            

            <div class="col-md-12">
                <div class="form-floating">
                    <input class="form-control" asp-for="Remarks" type="text">
                    <label asp-for="Remarks"></label>
                </div>
            </div>

            <div class="col-md-12">
                <div class="form-check form-switch">
                    <input class="form-check-input" asp-for="is_active" name="is_active" type="checkbox" />
                    <label class="form-check-label" asp-for="is_active">is Active</label>
                </div>
            </div>
        </div>
    </form>
</div>

@{
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
}
<script>
    function Save() {
        if (!$('#CreateRawmaterial').valid()) {
            return false;
        }

        var data = $("#CreateRawmaterial").serialize();
        $.ajax({
            type: 'POST',
            url: '/Inventory/CreateRawmaterial',
            data: data,
            success: function (response) {
                if (response.success) {
                    // Close the current dialog
                    $('.bootbox.modal').modal('hide');

                    // Show success message and reload
                    bootbox.alert(response.msg, function () {
                        window.location.href = "/Inventory/RawMaterials";
                    });
                } else {
                    bootbox.alert(response.msg);
                }
            },
            error: function (xhr, status, error) {
                bootbox.alert('Error: ' + (xhr.responseJSON?.msg || error));
            }
        });
    }
</script>

