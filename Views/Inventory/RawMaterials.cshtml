@model List<MPCRS.ViewModels.Master_RawmaterialVM>
@using MPCRS.Utilities
@{
    ViewData["Title"] = "Raw Materials";
    //Layout = null;
    var Permission_Write = UserData.IsAuthorized(User, Constants.UserPermissions.Raw_Materials_Write);
    var Permission_read = UserData.IsAuthorized(User, Constants.UserPermissions.Raw_Materials_Read);

}
<div class="page-header mb-4">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h3 class="mb-0 fw-bold">
                    <i class="fas fa-boxes me-2"></i>Raw Materials
                </h3>
            </div>
            <div class="col-md-6 text-end">
                <a href="/Home" class="btn btn-outline-secondary me-2">
                    <i class="fas fa-arrow-left me-1"></i>Back
                </a>
                <button class="btn btn-primary" onclick="Create('')">
                    <i class="fas fa-plus me-1"></i>Create
                </button>
            </div>
        </div>
    </div>
</div>

 
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-sm align-middle mb-0" id="demandstbl">
            <thead class="table-light">
                <tr>
                    <th data-sortable="true" scope="col" class="text-nowrap">Raw Material Name</th>
                    <th data-sortable="true" scope="col" class="text-nowrap">Material Name</th>
                    <th data-sortable="true" scope="col" class="text-nowrap">Type</th>
                    <th data-sortable="true" scope="col" class="text-nowrap">Outer Dia</th>
                    <th data-sortable="true" scope="col" class="text-nowrap">Inner Dia</th>
                    @* <th data-sortable="true" scope="col">Height</th> *@
                    <th data-sortable="true" scope="col" class="text-nowrap">Thickness</th>
                    <th data-sortable="true" scope="col" class="text-nowrap">Density</th>
                    <th data-sortable="true" scope="col" class="text-nowrap">UOM</th>
                    <th data-sortable="true" scope="col" class="text-nowrap">Qty/Engine</th>
                    <th data-sortable="true" scope="col" class="text-nowrap">Active</th>
                    <th data-sortable="true" scope="col" class="text-nowrap">Remark</th>
                    <th class="text-nowrap">Action</th>
                </tr>
            </thead>
            <tbody>
