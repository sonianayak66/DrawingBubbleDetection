                                            <g id="SVGRepo_iconCarrier"> <title>grid-solid-solid</title> <g id="Layer_2" data-name="Layer 2"> <g id="invisible_box" data-name="invisible box"> <rect width="48" height="48" fill="none"></rect> </g> <g id="icons_Q2" data-name="icons Q2"> <path d="M44,26a2,2,0,0,0,0-4H38V14h6a2,2,0,0,0,0-4H38V4a2,2,0,0,0-4,0v6H26V4a2,2,0,0,0-4,0v6H14V4a2,2,0,0,0-4,0v6H4a2,2,0,0,0,0,4h6v8H4a2,2,0,0,0,0,4h6v8H4a2,2,0,0,0,0,4h6v6a2,2,0,0,0,4,0V38h8v6a2,2,0,0,0,4,0V38h8v6a2,2,0,0,0,4,0V38h6a2,2,0,0,0,0-4H38V26ZM34,14v8H26V14ZM14,14h8v8H14Zm0,20V26h8v8Zm20,0H26V26h8Z"></path> </g> </g> </g>
                                        </svg>
                                        @item.RM_Type
                                    }
                                    else
                                    {
                                        @item.RM_Type
                                    }
                                }
                            </td>
                            <td>@item.Dia_mm</td>
                            <td>@item.inner_Dia_mm</td>
                            @* <td>@item.height</td>*@
                            <td>@item.Thick_mm</td>
                            <td>@item.Density</td>
                            <td>@item.RM_UOM</td>
                            <td class="text-center" >
                                @if (item.RMQtyPerEngine.HasValue)
                                {
                                    <span class="badge bg-info">@item.RMQtyPerEngine.Value</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (item.is_active)
                                {
                                    <span class="badge bg-success">
                                        <i class="fas fa-check me-1"></i>Active
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">
                                        <i class="fas fa-times me-1"></i>Inactive
                                    </span>
                                }
                            </td>
                            <td><small class="text-muted">@item.Remarks</small></td>
                            <td>
                                <div class="font-sans-serif btn-reveal-trigger position-static">
                                    <a href="#" onclick="Create('@item.RawmaterialGuid')" >
                                        <i class="fas fa-edit me-1"></i>
                                    </a>
