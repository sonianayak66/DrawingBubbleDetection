@using MPCRS.Utilities;
@using System.Data;
@{
    ViewData["Title"] = "MPL Revision";
    var Permission_Buid_Write = UserData.IsAuthorized(User, Constants.UserPermissions.SOP_Write);
}
<link href="~/css/style.min.css" rel="stylesheet" />
<style>
    .jstree-node {
        font-size: 10pt;
    }

    .Isupdated {
        color: #0eb438
    }

    .IsInactivated {
        color: #e22111
    }

    .jstree-anchor, .nav-link {
        color: black;
        font-size: 12pt;
    }

    .soppartonly {
        color: #e67c29;
    }
</style>
<style>
    #MPLdatatables td {
        white-space: nowrap;
    }

    td {
        padding: 2px !important;
        font-size: small !important;
    }

    th {
        font-size: small !important;
    }

    body {
        font-size: small;
        background-color: white;
    }

    /* Center-align the buttons */
    .dataTables_wrapper .dataTables_filter {
        float: left;
    }

    .dataTables_wrapper .dataTables_length, .dataTables_wrapper .dataTables_filter, .dataTables_wrapper .dataTables_info, .dataTables_wrapper .dataTables_paginate {
        float: right;
    }

    /* Add margin between search box and buttons */
    .dataTables_wrapper .dataTables_filter {
        margin-right: 20px;
    }

    .table {
        --phoenix-table-striped-bg: white;
    }


    .buttons-html5 {
        padding: 0.25rem 0.5rem; /* Adjust padding to make the button smaller */
        font-size: 0.675rem; /* Adjust font size to make the text smaller */
        line-height: 1.5;
    }

    /* Custom styles for smaller paging dropdown */

    .dataTables_length select {
        padding: 0.225rem 0.35rem; /* Adjust padding to make the dropdown smaller */
        font-size: 0.65rem; /* Adjust font size to make the text in the dropdown smaller */
    }

    .form-control-sm {
        min-height: calc(1.39em + 0.65rem + 2px);
        padding: 0.175rem 0.35rem;
        font-size: 0.6rem;
        border-radius: 0.375rem;
    }

</style>
<input type="hidden" value="@ViewBag.BaselineEngineKey" id="BaseLineEngineDbkey" />
<input type="hidden" value="RevisionManagement" id="MPLView" />

<div class="row">
    <div class="col-md-6">
        <h3>MPL - Revision Management</h3>
    </div>
</div>
<hr />
<div class="col-md-12">
    <div>
        <input class="search-input form-control" placeholder="Search......." />
    </div>
    <div style="max-height:500px!important;overflow-y:scroll" class="card">
        <div id="mpljstree">

        </div>
    </div>
</div>




@section Scripts{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/jstree.min.js" asp-append-version="true"></script>
    <script src="~/mpi/MPL.js" asp-append-version="true"></script>

    <script>
        $(function () {
            LoadMplJstree();
        });
    </script>

}
