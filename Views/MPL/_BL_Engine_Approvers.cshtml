@model IEnumerable<MPCRS.ViewModels.BL_Engine_Approvers>

<table class="table table-sm table-bordered table-condensed" id="Signatures">
    <thead>
        <tr>
            <th style="width:5%">
                SL No
            </th>
            <th style="width:20%">
                Module
            </th>
            <th colspan="2" class="text-center" style="width:35%">
                Prepared By
            </th>
            <th style="width:40%">
               Signature
            </th>
        </tr>
    </thead>
    <tbody>
        @{
  
            foreach (var item in Model.Where(x=>x.ModuleName != "All").Select((x, i) => new { Data = x, Index = i }))
            {
                <tr>
                     <td style="padding-left:4px!important">@(item.Index+1)</td>
                     <td style="padding-left:4px!important">@item.Data.ModuleName</td>
                     <td style="padding-left:4px!important">@item.Data.Person_Name</td>
                     <td style="padding-left:4px!important">@item.Data.Designation</td>
                    <td></td>
                </tr>
                
            }
        }

    </tbody>
</table>