@model IEnumerable<MPCRS.ViewModels.MPLReportData>
@using MPCRS.Utilities;
@{
    Layout = null;
    var approverList = MPGlobals.ConvertDataTable<MPCRS.ViewModels.BL_Engine_Approvers>(MPGlobals.GetDataForDatalist("[dbo].[Get_BL_Engine_Approvers]"));
    var MPL_Report_Write = UserData.IsAuthorized(User, Constants.UserPermissions.MPL_Report_Write);
}

@{

    try
    {

        var itemsmodel = Model.Where(x => x.IsParent != "yes" && x.ReportGroupIdentifier != null && x.ReportGroupIdentifier != "_0").Select(x => x.ReportGroupIdentifier).Distinct().OrderBy(x => x);

        List<MPCRS.ViewModels.MPLReportData> groups = new List<MPCRS.ViewModels.MPLReportData>();

        foreach (var group in itemsmodel)
        {
            MPCRS.ViewModels.MPLReportData orderitem = new MPCRS.ViewModels.MPLReportData();
            orderitem.ReportGroupIdentifier = group;
            orderitem.ReportDisplayOrder = 0;
            if (group.Contains("Direct") == false)
            {
                int thisParent = int.Parse(group.Split('_')[group.Split('_').Length - 1]);
                orderitem.ReportDisplayOrder = Model.Where(x => x.Engine_Part_Dbkey == thisParent).Select(x => x.ReportDisplayOrder).FirstOrDefault();
            }
            groups.Add(orderitem);
        }


        foreach (var item1 in groups.OrderBy(x => x.ReportDisplayOrder))
        { 
            int reducer = 0;
            int MaXlevel = Model.Where(x => x.ReportGroupIdentifier == item1.ReportGroupIdentifier).Select(x => x.Level).Max();
            string PreviousGroup = "";
            string PageHeading = "PW00000 - DIRECT PARTS";
            string filterParents = "Yes";
            string headingMainAssembly = "PW00000";
            bool filterDirctParts = true;
            string additionalClasses = Model.Where(x => x.Draw_part_no == "PW00000").Select(x => (x.Collaborators)).FirstOrDefault();
            if (!string.IsNullOrEmpty(additionalClasses))
            {
                additionalClasses = additionalClasses.Replace(' ', '-').Replace(',', ' ');
            }

            if (item1.ReportGroupIdentifier.Contains("Direct") == false)
            {
                filterDirctParts = false;
                MaXlevel = MaXlevel - 1;
                reducer = 1;
                filterParents = "No";
                int AssemblyParentID = int.Parse(item1.ReportGroupIdentifier.Split('_')[item1.ReportGroupIdentifier.Split('_').Length - 1]);
                PageHeading = Model.Where(x => x.Engine_Part_Dbkey == AssemblyParentID).Select(x => (x.Draw_part_no + " - " + x.Description)).FirstOrDefault();
                headingMainAssembly = Model.Where(x => x.Engine_Part_Dbkey == AssemblyParentID).Select(x => (x.Draw_part_no)).FirstOrDefault();

                string collaborators = Model.Where(x => x.Engine_Part_Dbkey == AssemblyParentID).Select(x => (x.Collaborators)).FirstOrDefault();
                additionalClasses = collaborators == null ? string.Empty : collaborators;
                if (!string.IsNullOrEmpty(additionalClasses))
                {
                    additionalClasses = additionalClasses.Replace(' ', '-').Replace(',', ' ');
                }

            }
            additionalClasses = additionalClasses + " Collabs ";

            <table class="table table-condensed table-sm @additionalClasses @item1.ReportGroupIdentifier.Trim().Replace(' ', '_')" id="@headingMainAssembly" style="width:100%;font-size:12px!important;border:none">
                <thead>
                    <tr style="border:none">
                        <th style="border:none" class="text-center text-capitalize" colspan="@(MaXlevel + 9)">
                            <h3>@PageHeading</h3>
                            <div>
                                @{
                                    for (int d = 1; d <= MaXlevel; d++)
                                    {
                                        <input class="larger displayctrl noPrint" onclick="ManageComponentDisplay(this);" type="checkbox" checked id="@(headingMainAssembly+"Level"+d)" />
                                        <label class="noPrint" for="@(headingMainAssembly+"Level"+d)" style="margin-right:10px">@("L" + d)</label>
                                    }
                                }

                                @{
                                    if (MPL_Report_Write)
                                    {
                                        <button style="margin-left:50px!important" class="btn btn-sm btn-primary noPrint" onclick="SaveAssemblyDisplyOrder('@headingMainAssembly')">Save</button>
                                    }
                                }
                             
                                <a href="#index" style="margin-left:10px!important" class="btn btn-sm btn-primary noPrint">Index</a>
                            </div>


                        </th>
                    </tr>
                    <tr>
                        <th colspan="@MaXlevel" class="text-center">Drawing No</th>
                        <th>Description</th>
                        <th>Part/Assy</th>
                        <th>Rev</th>
                        <th>Qty</th>
                        <th>Material</th>
                        <th>Module Resp</th>
                        <th class="PartComments">Comments</th>
                        <th class="ManufacturingComments">Manufacturing Comments</th>
                        <th class="noPrint writeaccess">Collaborators</th>
                        <th class="MfgStatus">Mfg Status</th>
                        <th class="noPrint writeaccess">Part Disp Order</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        string parentID = String.Empty;
                        if (item1.ReportGroupIdentifier.Contains("Direct"))
                        {
                            parentID = Model.Where(x => x.Draw_part_no == "PW00000").Select(x => x.Engine_Part_Dbkey).FirstOrDefault().ToString();
                        }
                        else
                        {
                            parentID = item1.ReportGroupIdentifier.Split('_')[item1.ReportGroupIdentifier.Split('_').Length - 1];
                        }

                        int parentPartID = int.Parse(parentID.Trim());
                        MPCRS.ViewModels.MPLReportData mainParent = Model.Where(x => x.Engine_Part_Dbkey == parentPartID).FirstOrDefault();
                        mainParent.MaxLevel = MaXlevel;
                        mainParent.MainAssesmblyHeading = headingMainAssembly;
                        mainParent.reducer = reducer; 
                        <partial name="_rowItem" model="mainParent" />

                        List<MPCRS.ViewModels.MPLReportData> childLevel1 = new List<MPCRS.ViewModels.MPLReportData>();

                        if (filterDirctParts)
                        {
                            childLevel1 = MPGlobals.GetDirectPartsMPL(Model.Where(x => x.ReportGroupIdentifier == item1.ReportGroupIdentifier).ToList(), parentPartID);
                        }
                        else
                        {
                            //  childLevel1 = MPGlobals.GetAllChildren(Model.Where(x => x.ReportGroupIdentifier == item1).ToList(),parentPartID);
                            childLevel1 = MPGlobals.GetAllChildrenMPL(Model.ToList(), parentPartID);
                        }

                    }

                    @foreach (var item in childLevel1.OrderBy(x => x.Reporting_Parent).ThenBy(x => x.ReportDisplayOrder).ThenBy(x => x.Draw_part_no))
                    {
                        item.MaxLevel = MaXlevel;
                        item.MainAssesmblyHeading = headingMainAssembly;
                        item.reducer = reducer; 
                        <partial name="_rowItem" model="item" />
                        
                        if (item.IsParent == "Yes")
                        {
                            List<MPCRS.ViewModels.MPLReportData> childLevel2 = MPGlobals.GetAllChildrenMPL(Model.ToList(), item.Engine_Part_Dbkey);
                            foreach (var child2 in childLevel2.OrderBy(x => x.Reporting_Parent).ThenBy(x => x.ReportDisplayOrder))
                            {
                                child2.MaxLevel = MaXlevel;
                                child2.MainAssesmblyHeading = headingMainAssembly;
                                child2.reducer = reducer; 
                                <partial name="_rowItem" model="child2" />                                

                                if (child2.IsParent == "Yes")
                                {
                                    List<MPCRS.ViewModels.MPLReportData> childLevel3 = MPGlobals.GetAllChildrenMPL(Model.ToList(), child2.Engine_Part_Dbkey);
                                    foreach (var child3 in childLevel3.OrderBy(x => x.Reporting_Parent).ThenBy(x => x.ReportDisplayOrder))
                                    {
                                        child3.MaxLevel = MaXlevel;
                                        child3.MainAssesmblyHeading = headingMainAssembly;
                                        child3.reducer = reducer;                            
                                        <partial name="_rowItem" model="child3" />
                                        
                                        if (child3.IsParent == "Yes")
                                        {
                                            List<MPCRS.ViewModels.MPLReportData> childLevel4 = MPGlobals.GetAllChildrenMPL(Model.ToList(), child3.Engine_Part_Dbkey);
                                            foreach (var child4 in childLevel4.OrderBy(x => x.Reporting_Parent).ThenBy(x => x.ReportDisplayOrder))
                                            {
                                                child4.MaxLevel = MaXlevel;
                                                child4.MainAssesmblyHeading = headingMainAssembly;
                                                child4.reducer = reducer;                                             
                                                <partial name="_rowItem" model="child4" />
                                                if (child4.IsParent == "Yes")
                                                {
                                                    List<MPCRS.ViewModels.MPLReportData> childLevel5 = MPGlobals.GetAllChildrenMPL(Model.ToList(), child4.Engine_Part_Dbkey);
                                                    foreach (var child5 in childLevel5.OrderBy(x => x.Reporting_Parent).ThenBy(x => x.ReportDisplayOrder))
                                                    {
                                                        child5.MaxLevel = MaXlevel;
                                                        child5.MainAssesmblyHeading = headingMainAssembly;
                                                        child5.reducer = reducer;
                                                        <partial name="_rowItem" model="child5" />
                                                        if (child5.IsParent == "Yes")
                                                        {
                                                            List<MPCRS.ViewModels.MPLReportData> childLevel6 = MPGlobals.GetAllChildrenMPL(Model.ToList(), child5.Engine_Part_Dbkey);
                                                            foreach (var child6 in childLevel6.OrderBy(x => x.Reporting_Parent).ThenBy(x => x.ReportDisplayOrder))
                                                            {
                                                                child6.MaxLevel = MaXlevel;
                                                                child6.MainAssesmblyHeading = headingMainAssembly;
                                                                child6.reducer = reducer;
                                                                <partial name="_rowItem" model="child6" />
                                                                if (child6.IsParent == "Yes")
                                                                {
                                                                    List<MPCRS.ViewModels.MPLReportData> childLevel7 = MPGlobals.GetAllChildrenMPL(Model.ToList(), child6.Engine_Part_Dbkey);
                                                                    foreach (var child7 in childLevel7.OrderBy(x => x.Reporting_Parent).ThenBy(x => x.ReportDisplayOrder))
                                                                    {
                                                                        child7.MaxLevel = MaXlevel;
                                                                        child7.MainAssesmblyHeading = headingMainAssembly;
                                                                        child7.reducer = reducer;
                                                                        <partial name="_rowItem" model="child7" />
                                                                    }
                                                                }
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                </tbody>
                <tfoot style="align-items: baseline !important" class="noPrint">
                    <tr style="min-height:85px!important; align-items:baseline!important">
                        <th colspan="@(MaXlevel+7)">
                            <div style="min-height: 85px !important; align-items: baseline !important;" class="row">
                                @{
                                    List<string> responsibilites = Model.Where(x => x.ReportGroupIdentifier == item1.ReportGroupIdentifier && x.PartModuleRes != "" && x.PartModuleRes != null).Select(x => x.PartModuleRes).Distinct().ToList();
                                    try
                                    {
                                        var divider = 100.00 / (responsibilites.Count());
                                        foreach (var responsibility in responsibilites)
                                        {
                                            <div class="text-center" style="width:@(divider+"%"); float: left; font-weight:bold; margin-top:55px!important;margin-bottom:8px!important">
                                                @*  @responsibility*@
                                            </div>
                                        }
                                    }
                                    catch (Exception)
                                    {

                                    }

                                }
                            </div>
                        </th>

                    </tr>
                </tfoot>
            </table>
            <div class="pagebreak Collabs @item1.ReportGroupIdentifier.Trim().Replace(' ', '_') @mainParent.Collaborators.Trim().Replace(',', ' ')">
                @*[@item1.ReportGroupIdentifier.Trim().Replace(' ', '_')]
    [@mainParent.Collaborators.Trim().Replace(',', '_')]*@

            </div>
        }
    }
    catch (Exception ex)
    {

        <span>@ex.Message</span>
        <span>@ex.StackTrace</span>
    }


}

