@{
    ViewData["Title"] = "Forging Receipt Summary";
}


<div class="page-header">
    <div class="col-12">
        <div class="row">
            <div class="col-sm-11">
                <h3>Forging Receipt History</h3>
            </div>
            <div class="col-sm-1 pull-right">
                <a href="/Home" style="margin-right:4px" class="btn btn-secondary float-end ">Back</a>
            </div>
        </div>
    </div>
</div>
 

<div class="col-md-12 col-sm-12 col-lg-12">
    <table class="table table-bordered table-condensed table-sm" id="MatIssueHis">
        <thead>
            <tr>
                <th>Receipt No</th>
                @*<th>Receipt Date</th>*@
                <th>Part Name</th>
                <th>Raw Material</th>
                <th>GTRE Draw. No</th>
                <th>Vendor Draw. No</th>
                <th>Order Qty</th>
                <th>Receipt Qty</th>
                <th>Balance</th>
                <th></th>
                <th></th>
    @*            <th></th>
                <th></th>*@

            </tr>
        </thead>

    </table>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/mpi/materialissue.js" asp-append-version="true"></script>
    <script>
        $(function () {
            GetForgingReceipts();
        });
    </script>

}