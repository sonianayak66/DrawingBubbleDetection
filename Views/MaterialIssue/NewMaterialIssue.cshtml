<script>
	var rawMaterialListJson = @Html.Raw(Json.Serialize(MaterialList)); 


	$(document).ready(function () {

		$('.decimal').keyup(function () {
			var val = $(this).val();
			if (isNaN(val)) {
				val = val.replace(/[^0-9\.]/g, '');
				if (val.split('.').length > 2)
					val = val.replace(/\.+$/, "");
			}
			$(this).val(val);
		});

		var PartDbKey = document.getElementById("PartDbKey").value;
		var IssueDbkey = document.getElementById("Issue_Dbkey").value;
		var PartDetail = document.getElementById("PartDetail").value;
		if (PartDbKey != 0) {
			var itemsinput = document.getElementsByClassName("Drawing_no");
			for (var i = 0; i < itemsinput.length; i++) {
				itemsinput[i].value = PartDetail;
			}

			for (var i = 0; i < 1; i++) {
				addRow();
			}

		} else {
			if (IssueDbkey == 0) {
			}
		}
		if (IssueDbkey != 0) {
		UploadMaterialIssueDocument(IssueDbkey, 'Edit');
		}

		initAllEngineDropdowns(document);

	});



</script>

<script>
	function bindEngineMultiSelect(row) {
		var select = row.querySelector('.engine-select');
		if (!select) return;

		var hidden = row.querySelector('.EngineLevel');
		if (!hidden) return;

		var current = (hidden.value || '')
			.split(',')
			.map(function (x) { return x.trim(); })
			.filter(function (x) { return x; });

		if ($(select).hasClass('select2-hidden-accessible')) {
			$(select).select2('destroy');
		}

		$(select).select2({
			placeholder: $(select).data('placeholder') || 'Select engine(s)',
			width: '100%',
			allowClear: true,
			closeOnSelect: false,
			dropdownParent: $('.bootbox.modal.show').length
				? $('.bootbox.modal.show')
				: $(document.body)
		});

		$(select).val(current).trigger('change');

		$(select).off('change.engine').on('change.engine', function () {
			var values = $(this).val() || [];
			hidden.value = values.join(',');
		});
	}

	function initAllEngineDropdowns(container) {
		$(container).find('.engine-select').each(function () {
			var row = $(this).closest('tr');

			// skip hidden template row
			if (row.attr('id') === 'newRowTemplate') return;

			bindEngineMultiSelect(row[0]);
		});
	}
</script>

