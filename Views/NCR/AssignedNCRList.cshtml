@using MPCRS.Utilities
@using Newtonsoft.Json
@using System.Data
@model List<MPCRS.ViewModels.NCRAssignmentsVM>

@{
	ViewData["Title"] = "NCR Assignment List";
	if (@ViewBag.LayoutType == false)
	{
		Layout = null;

	}
	DataTable dt = MPGlobals.GetDataForDatatable($" select * from NonConformanceReport_Items");
	var NCR_Items = JsonConvert.DeserializeObject<List<NonConformanceReport_Item>>(JsonConvert.SerializeObject(dt));

}
<div class="row">
	<div class="col-6">
		<h4>NCR Assignments</h4>
	</div>
	<div class="col-6 d-flex justify-content-end align-items-center gap-2">
		<a href="/NCR/ModuleWiseNCRList" target="_blank" class="btn btn-outline-secondary btn-sm">
			<i class="uil uil-chart-bar me-1"></i>Module Wise Report
		</a>
		@{
			if (@ViewBag.LayoutType == false)
			{
				<input type="button" class="btn btn-success btn-sm" onclick="GetPopupToAssign('@Model.FirstOrDefault().NCRGUID')" value="Assign Module" />
			}
		}
	</div>
</div>
<hr />
<table class="table table-bordered" id="assignmnetListTbl">
	<thead>
		<tr>
			<th>NCR Number</th>
			<th>Part No </th>
			<th>Rev</th>
			<th>Received From/On</th>
			<th>Committee</th>
			<th>Status of Deviations</th>
			<th>Module</th>
			@*  <th>Assigned By/On</th> *@
			<th>Current Status</th>
			<th>Remarks</th>
			<th></th>
		</tr>
	</thead>
	<tbody>
		@foreach (var item in Model.GroupBy(x => x.ReferenceNumber).Select(x => x.First()).OrderByDescending(x => x.AssignedOn))
		{
			var filteredItems = NCR_Items.Where(x => x.NCRGuid == item.NCRGUID);
			bool forwardedToModule = filteredItems.All(item => !string.IsNullOrEmpty(item.Module_Status));
			bool forwardedToTAS = filteredItems.All(item => item.Module_Status == "Ended");
			bool forwardedToSTRESS = filteredItems.All(item => item.TAS_Status == "Ended");
			bool forwardedToCHAIR = filteredItems.All(item => item.Stress_Status == "Ended" && !string.IsNullOrEmpty(item.Chair_Status));

			bool forwardedToModule_Rework = filteredItems.Any(item => item.Module_Rework_Status == "Forwarded To Module");
			bool forwardedToTAS_Rework = filteredItems.Any(item => item.TAS_Rework_Status == "Forwarded To TAS");
			bool forwardedToSTRESS_Rework = filteredItems.Any(item => item.STRESS_Rework_Status == "Forwarded To STRESS");

			// MarkedAsComplete flags - normal cycle
			bool moduleMarkedComplete = filteredItems.Any() && filteredItems.All(i => i.Module_Status == "MarkedAsComplete");
			bool tasMarkedComplete = filteredItems.Any() && filteredItems.All(i => i.TAS_Status == "MarkedAsComplete");
			bool stressMarkedComplete = filteredItems.Any() && filteredItems.All(i => i.Stress_Status == "MarkedAsComplete");
			bool chairMarkedComplete = filteredItems.Any() && filteredItems.All(i => i.Chair_Status == "MarkedAsComplete");

			// MarkedAsComplete flags - rework cycle
			bool moduleReworkMarkedComplete = filteredItems.Any(i => i.Module_Rework_Status == "MarkedAsComplete");
			bool tasReworkMarkedComplete = filteredItems.Any(i => i.TAS_Rework_Status == "MarkedAsComplete");
			bool stressReworkMarkedComplete = filteredItems.Any(i => i.STRESS_Rework_Status == "MarkedAsComplete");

			bool closeNCR = item.CloseNCR == 1;

			<tr>
				<td class="p-2"><b>@item.ReferenceNumber</b></td>
				<td>
					<b>@item.Draw_part_no/@item.PartDescription   </b>
				</td>
				<td>@item.Revision</td>
				<td>
					@item.ReceivedFromString
					<br />
					<i>@(MPCRS.Utilities.MPGlobals.GetFormattedDate(item.ReceivedDate))</i>
				</td>
				<td>@item.ComitteeReferred</td>
				<td style="max-width:25%;">
					@{
						MPCRS.ViewModels.NCRSerialNoDataVM nCRSerialNo = new();
						nCRSerialNo.NCRGUID = item.NCRGUID;
						nCRSerialNo.NCRWorkflowGUID = item.NCRWorkflowGUID;
					}
					<partial name="../Ncr/ncritemstatus" model="@nCRSerialNo">
						@*    @{
                        if (item.SerialNumber != null)
                        {
                            foreach (var slno in item.SerialNumber.Split(','))
                            {
                                <span class="badge badge-phoenix badge-phoenix-primary fs--2 text-dark ">@slno</span>
                            }
                        }
                    } *@
				</td>
				<td class="p-2">@item.Module_Responsibilty_String</td>
				@*  <td>
                    @item.UserName<br /><i>@(MPCRS.Utilities.MPGlobals.GetFormattedDateTime(item.AssignedOn))</i>
                </td> *@
				@*    <td style="max-width:10%">
                    @{
                        if (closeNCR)
                        {
                            <p>Closed</p>
                        }
                        else if (forwardedToCHAIR)
                        {
                            <p>Forwarded To CHAIR</p>
                        }
                        else if (forwardedToSTRESS_Rework)
                        {
                            <p>Forwarded To STRESS for <br /> Rework/Trial Assembly remarks</p>
                        }
                        else if (forwardedToTAS_Rework)
                        {
                            <p>Forwarded To TAS for <br /> Rework/Trial Assembly remarks</p>
                        }
                        else if (forwardedToModule_Rework)
                        {
                            <p>Forwarded To Module for <br /> Rework/Trial Assembly remarks</p>
                        }
                        else if (forwardedToSTRESS)
                        {
                            <p>Forwarded To STRESS</p>
                        }
                        else if (forwardedToTAS)    
                        {
                            <p>Forwarded TO TAS</p>
                        }
                        else if(forwardedToModule)
                        {
                            <p>Forwarded To Module</p>
                        }
                    }
                 </td> *@

				<td style="max-width:10%">
					@{
						if (closeNCR)
						{
							<p>Closed</p>
						}
						else if (chairMarkedComplete)
						{
							<p class="text-success fw-bold">CHAIR - Marked As Complete</p>
						}
						else if (forwardedToCHAIR)
						{
							<p>Forwarded To CHAIR</p>
						}
						else if (stressReworkMarkedComplete)
						{
							<p class="text-success fw-bold">STRESS (Rework/Trial Assembly) - Marked As Complete</p>
						}
						else if (forwardedToSTRESS_Rework)
						{
							<p>Forwarded To STRESS for <br /> Rework/Trial Assembly remarks</p>
						}
						else if (tasReworkMarkedComplete)
						{
							<p class="text-success fw-bold">TAS (Rework/Trial Assembly) - Marked As Complete</p>
						}
						else if (forwardedToTAS_Rework)
						{
							<p>Forwarded To TAS for <br /> Rework/Trial Assembly remarks</p>
						}
						else if (moduleReworkMarkedComplete)
						{
							<p class="text-success fw-bold">Module (Rework/Trial Assembly) - Marked As Complete</p>
						}
						else if (forwardedToModule_Rework)
						{
							<p>Forwarded To Module for <br /> Rework/Trial Assembly remarks</p>
						}
						else if (stressMarkedComplete)
						{
							<p class="text-success fw-bold">STRESS - Marked As Complete</p>
						}
						else if (forwardedToSTRESS)
						{
							<p>Forwarded To STRESS</p>
						}
						else if (tasMarkedComplete)
						{
							<p class="text-success fw-bold">TAS - Marked As Complete</p>
						}
						else if (forwardedToTAS)
						{
							<p>Forwarded To TAS</p>
						}
						else if (moduleMarkedComplete)
						{
							<p class="text-success fw-bold">Module - Marked As Complete</p>
						}
						else if (forwardedToModule)
						{
							<p>Forwarded To Module</p>
						}
					}
				</td>

				<td>@item.Remarks</td>
				<td class="p-2">
					<a href="/NCR/AssignmentDetail?id=@item.NCRWorkflowGUID&NCRGuid=@item.NCRGUID">View</a>
					@* <a class="fas fa-trash-alt text-danger float-sm-right" onclick="ncrModuleDelete('@item.NCRGUID','@item.NCRWorkflowGUID')"></a> *@

				</td>
			</tr>
		}
	</tbody>
</table>

@section Scripts {
	<script src="~/mpi/ncr.js" asp-append-version="true"></script>
	<script>
		$(document).ready(function () {
			$("#assignmnetListTbl").DataTable({
				paging: false,
			   ordering:false,
				columnDefs: [
					{
						targets: 0, // Change this to the index of the column you want to set the max width for
						width: '10%', // Set your desired maximum width
					}
				]
			});
		});

	</script>
}




