				// 	$('#WorkflowLogTbl').DataTable({
				// 		paging: false,
				// 		"columnDefs": [
				// 			{
				// 				"targets": 0, // Index of the column with datetime
				// 				"type": 'datetime-custom'
				// 			}
				// 		]

				// 	});


				// 	const table = document.getElementById('itemsTbl');
				// 	const textareas = table.querySelectorAll('textarea.serialNoRemarks');


				// 	if (textareas.length <= 0) {
				// 		document.getElementById('ReferDeviationBtn').style.display = 'none';
				// 		document.getElementById('MarkAsCompleteBtn').style.display = 'none';
				// 	}

				// 	applyTinyMCEForRemarksArea(".serialNoRemarks");

				// });


				$(document).ready(function () {
			$.fn.dataTable.ext.type.order['datetime-custom-pre'] = function (d) {
				return new Date(d).getTime();
			};

			var reinitializeTimer = null;
			var initializedEditors = new Set(); // Track which textareas are already initialized

				  var itemsTable = $('#itemsTbl').DataTable({
					paging: false,
					ordering: false,
					deferRender: true,
					drawCallback: function(settings) {
						// Clear any existing timer
						clearTimeout(reinitializeTimer);
						// Set new timer - only runs if user stops searching for 200ms
						reinitializeTimer = setTimeout(function() {
							lazyInitializeTinyMCE();
						}, 200);
					}
				});

				// Add this code right after DataTable initialization
				// Hide loading overlay and show table with fade-in effect
				setTimeout(function() {
					$('#tableLoadingOverlay').addClass('hidden');
					$('#itemsTbl').css('opacity', '1');
				}, 100);

				// Also hide overlay after DataTable fully renders
				itemsTable.on('draw.dt', function() {
					setTimeout(function() {
						$('#tableLoadingOverlay').addClass('hidden');
						$('#itemsTbl').css('opacity', '1');
					}, 100);
				});

			$('#WorkflowLogTbl').DataTable({
				paging: false,
				"columnDefs": [
					{
						"targets": 0,
						"type": 'datetime-custom'
					}
				]
			});

			const table = document.getElementById('itemsTbl');
			const textareas = table.querySelectorAll('textarea.serialNoRemarks');

			if (textareas.length <= 0) {
				document.getElementById('ReferDeviationBtn').style.display = 'none';
				document.getElementById('MarkAsCompleteBtn').style.display = 'none';
			}

			// Initial lazy load
			lazyInitializeTinyMCE();

			// Intersection Observer for lazy loading TinyMCE
			function lazyInitializeTinyMCE() {
				const editableTextareas = document.querySelectorAll('textarea.serialNoRemarks:not(.tinymce-initialized)');

				if (editableTextareas.length === 0) return;

				// Create Intersection Observer
				const observer = new IntersectionObserver((entries) => {
					entries.forEach(entry => {
						if (entry.isIntersecting) {
							const textarea = entry.target;
							const textareaId = textarea.id;

							// Check if not already initialized
							if (!initializedEditors.has(textareaId) && !textarea.classList.contains('tinymce-initialized')) {
								initializeSingleEditor(textarea);
								observer.unobserve(textarea); // Stop observing once initialized
							}
						}
					});
				}, {
					root: null,
					rootMargin: '200px', // Start loading 200px before element comes into view
					threshold: 0.01
				});

				// Observe all uninitialized textareas
				editableTextareas.forEach(textarea => {
					observer.observe(textarea);
				});
			}

			// Function to initialize a single TinyMCE editor
			function initializeSingleEditor(textarea) {
				const textareaId = textarea.id;

				// Mark as initialized immediately to prevent double-initialization
				textarea.classList.add('tinymce-initialized');
				initializedEditors.add(textareaId);

				tinymce.init({
					target: textarea,
					height: 50,
					branding: false,
					toolbar: false,
					menubar: false,
					plugins: ' ',
					contextmenu: 'markForRework | markForTrialAssembly | Straightness | Dia | Flatness | Circularity | Cylindricity | Perpendicularity | Parallelism | Symmetry | TRunout | Concentricity | Angularity | Position | CRunout | PSurface | PLine | Datum | MMC | LMC | RFS | Degree',
					setup: function (editor) {
						editor.on('init', function () {
							const body = editor.getBody();
							body.style.lineHeight = '1.3';
							body.style.fontSize = '14px';
							body.style.padding = '2px 8px';
							body.style.margin = '0';
							body.style.paddingTop = '0';
						});

						// Add all your custom menu items here (same as before)
						editor.ui.registry.addMenuItem('markForRework', {
							text: 'Mark For Rework',
							onAction: function () {
								markForRework(editor, 1);
							}
						});

						editor.ui.registry.addMenuItem('markForTrialAssembly', {
							text: 'Mark For Trial Assembly',
							onAction: function () {
								markForTrialAssembly(editor, 2);
							}
						});

						editor.ui.registry.addMenuItem('Straightness', {
							text: 'Straightness : ⏤',
							onAction: function () {
								editor.insertContent('⏤');
							}
						});

