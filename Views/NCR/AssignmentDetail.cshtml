							 		item.Module_ReworkType == 2 || item.TAS_ReworkType == 2 || item.STRESS_ReworkType == 2 || item.PO_ReworkType == 2 ? "#BF40BF" : "");">
							<td> <spn style="padding-left:5px">@item.SlNo</spn></td>
							<td><b style="padding-left:5px">@item.Serial_No_in_Inspection_Rep</b></td>
