								<input data-field="NCRItemkey" type="hidden" asp-for="@item.NCRItemKey" />
								<input id="NCRWorkflowGUID" asp-for="@item.NCRWorkFlowGuid" hidden />
								<b style="padding-left:5px">@item.SerialNumber</b>
							</td>
