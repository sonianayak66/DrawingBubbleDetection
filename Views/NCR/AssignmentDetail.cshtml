@model MPCRS.ViewModels.AssignedNCRvm
@using MPCRS.ViewModels;
@using MPCRS.Utilities;
@using System.Security.Claims


@{
	var NCR_Status = Masters.GetMaster_General_SameValueAsText("NCR_Report_Status");
	var NCR_Module_User = UserData.IsAuthorized(User, Constants.UserPermissions.NCR_Module_User);
	var NCR_Assignments_Admin = UserData.IsAuthorized(User, Constants.UserPermissions.NCR_Assignments_Admin);
	var NCR_Assignments_Admin_Delete = UserData.IsAuthorized(User, Constants.UserPermissions.NCR_Assignments_Admin_Delete);
	var NCR_Assignments_Module_Delete = UserData.IsAuthorized(User, Constants.UserPermissions.NCR_Assignments_Module_Delete);
	var userguid = ViewBag.UserGuid;
	var userOldDBKey = ViewBag.userDBKey;
	bool allModuleRemarksUpdated = Model.NcrItems.All(item => !string.IsNullOrEmpty(item.Module_Remarks));
	bool allTASRemarksUpdated = Model.NcrItems.All(item => !string.IsNullOrEmpty(item.TAS_Remarks));
	bool allSTRESSRemarksUpdated = Model.NcrItems.All(item => !string.IsNullOrEmpty(item.Stress_Remarks));
	bool allCHAIRRemarksUpdated = Model.NcrItems.All(item => !string.IsNullOrEmpty(item.Chair_Remarks));
	//bool forwardedToTAS = Model.NcrItems.All(item => (item.TAS_Status == "Forwarded To TAS" || item.TAS_Status == "MarkedAsComplete" || item.TAS_Status == "Ended"));
	bool forwardedToTAS = Model.NcrItems.All(item => !string.IsNullOrEmpty(item.TAS_Status));
	//bool forwardedToSTRESS = Model.NcrItems.All(item => (item.Stress_Status == "Forwarded To STRESS" || item.Stress_Status == "MarkedAsComplete"));
	bool forwardedToSTRESS = Model.NcrItems.All(item => !string.IsNullOrEmpty(item.Stress_Status));
	bool forwardedToCHAIR = Model.NcrItems.All(item => !string.IsNullOrEmpty(item.Chair_Status));
	var Modules = Masters.GetMaster_General("Module_Responsibility", true);
	var TASmoduleId = Modules.Where(x => x.Text.ToLower().Contains("tas")).FirstOrDefault() == null ? "" : Modules.Where(x => x.Text.ToLower().Contains("tas")).FirstOrDefault().Value;
	var STRESSmoduleId = Modules.Where(x => x.Text.ToLower().Contains("stress")).FirstOrDefault() == null ? "" : Modules.Where(x => x.Text.ToLower().Contains("stress")).FirstOrDefault().Value;
	var CHAIRmoduleId = Modules.Where(x => x.Text.ToLower().Contains("chair")).FirstOrDefault() == null ? "" : Modules.Where(x => x.Text.ToLower().Contains("chair")).FirstOrDefault().Value;
	bool closeNCR = Model.AssignmentData.CloseNCR == 1;
	// bool MarkedForRework = Model.NcrItems.Any(x => (x.Rework_Status == 1 || x.Rework_Status == 2));
	bool MarkedForRework = Model.NcrItems.Any(x =>	x.Module_ReworkType == 1 || x.Module_ReworkType == 2 ||
													x.TAS_ReworkType == 1 || x.TAS_ReworkType == 2 ||
													x.STRESS_ReworkType == 1 || x.STRESS_ReworkType == 2 ||
													x.PO_ReworkType == 1 || x.PO_ReworkType == 2);
	//bool all_Module_Rework_Remarks_updated = Model.NcrItems.Where(x => (x.Rework_Status == 1 || x.Rework_Status == 2)).All(item => !string.IsNullOrEmpty(item.Module_Rework_Remarks)); 
	bool all_Module_Rework_Remarks_updated = Model.NcrItems.Where(x => x.Module_ReworkType == 1 || x.Module_ReworkType == 2 ||
																	x.TAS_ReworkType == 1 || x.TAS_ReworkType == 2 ||
																	x.STRESS_ReworkType == 1 || x.STRESS_ReworkType == 2 ||
																	x.PO_ReworkType == 1 || x.PO_ReworkType == 2)
																	.All(item => !string.IsNullOrEmpty(item.Module_Rework_Remarks));
	//bool all_TAS_Rework_Remarks_updated = Model.NcrItems.Where(x => (x.Rework_Status == 1 || x.Rework_Status == 2)).All(item => !string.IsNullOrEmpty(item.TAS_Rework_Remarks));
	bool all_TAS_Rework_Remarks_updated = Model.NcrItems.Where(x => x.Module_ReworkType == 1 || x.Module_ReworkType == 2 ||
																	x.TAS_ReworkType == 1 || x.TAS_ReworkType == 2 ||
																	x.STRESS_ReworkType == 1 || x.STRESS_ReworkType == 2 ||
																	x.PO_ReworkType == 1 || x.PO_ReworkType == 2)
																	.All(item => !string.IsNullOrEmpty(item.TAS_Rework_Remarks));
	//bool all_STRESS_Rework_Remarks_updated = Model.NcrItems.Where(x => (x.Rework_Status == 1)).All(item => !string.IsNullOrEmpty(item.STRESS_Rework_Remarks));
	bool all_STRESS_Rework_Remarks_updated = Model.NcrItems.Where(x => x.Module_ReworkType == 1 || x.TAS_ReworkType == 1 ||
																		x.STRESS_ReworkType == 1 || x.PO_ReworkType == 1)
																		.All(item => !string.IsNullOrEmpty(item.STRESS_Rework_Remarks));
	//bool forwardedToModule_Rework = Model.NcrItems.Where(x => (x.Rework_Status == 1 || x.Rework_Status == 2)).All(item => !string.IsNullOrEmpty(item.Module_Rework_Status));
	bool forwardedToModule_Rework = Model.NcrItems.Where(x => x.Module_ReworkType == 1 || x.Module_ReworkType == 2 ||
																x.TAS_ReworkType == 1 || x.TAS_ReworkType == 2 ||
																x.STRESS_ReworkType == 1 || x.STRESS_ReworkType == 2 ||
																x.PO_ReworkType == 1 || x.PO_ReworkType == 2)
																.All(item => !string.IsNullOrEmpty(item.Module_Rework_Status));
 	//bool forwardedToTAS_Rework = Model.NcrItems.Where(x => (x.Rework_Status == 1 || x.Rework_Status == 2)).All(item => !string.IsNullOrEmpty(item.TAS_Rework_Status));
	bool forwardedToTAS_Rework = Model.NcrItems.Where(x => x.Module_ReworkType == 1 || x.Module_ReworkType == 2 ||
																x.TAS_ReworkType == 1 || x.TAS_ReworkType == 2 ||
																x.STRESS_ReworkType == 1 || x.STRESS_ReworkType == 2 ||
																x.PO_ReworkType == 1 || x.PO_ReworkType == 2)
																.All(item => !string.IsNullOrEmpty(item.TAS_Rework_Status));
	//bool forwardedToSTRESS_Rework = Model.NcrItems.Where(x => (x.Rework_Status == 1 || x.Rework_Status == 2)).All(item => !string.IsNullOrEmpty(item.STRESS_Rework_Status));
	bool forwardedToSTRESS_Rework = Model.NcrItems.Where(x => x.Module_ReworkType == 1 || x.Module_ReworkType == 2 ||
																x.TAS_ReworkType == 1 || x.TAS_ReworkType == 2 ||
																x.STRESS_ReworkType == 1 || x.STRESS_ReworkType == 2 ||
																x.PO_ReworkType == 1 || x.PO_ReworkType == 2)
																.All(item => !string.IsNullOrEmpty(item.STRESS_Rework_Status));
 	//bool forwardedToCHAIR_Rework = Model.NcrItems.Where(x => (x.Rework_Status == 1 || x.Rework_Status == 2)).All(item => !string.IsNullOrEmpty(item.CHAIR_Rework_Status));
	bool forwardedToCHAIR_Rework = Model.NcrItems.Where(x => x.Module_ReworkType == 1 || x.Module_ReworkType == 2 ||
																x.TAS_ReworkType == 1 || x.TAS_ReworkType == 2 ||
																x.STRESS_ReworkType == 1 || x.STRESS_ReworkType == 2 ||
																x.PO_ReworkType == 1 || x.PO_ReworkType == 2)
																.All(item => !string.IsNullOrEmpty(item.CHAIR_Rework_Status));
	// bool onlyTrialAssembly =
	// 	Model.NcrItems.Any(x => x.Rework_Status == 2)   has trial assembly
	// 	&& !Model.NcrItems.Any(x => x.Rework_Status == 1); no rework
	bool onlyTrialAssembly = Model.NcrItems.Any(x =>x.Module_ReworkType == 2 || x.TAS_ReworkType == 2 ||x.STRESS_ReworkType == 2 || x.PO_ReworkType == 2)
						 && !Model.NcrItems.Any(x =>x.Module_ReworkType == 1 || x.TAS_ReworkType == 1 ||x.STRESS_ReworkType == 1 || x.PO_ReworkType == 1);
	
	var UserGuid = User.FindFirst(ClaimTypes.NameIdentifier).Value.ToString();

	// Helper function to check if item is marked for rework at ANY stage
	Func<NonConformanceReport_ItemVM, bool> IsMarkedForRework = (item) =>
		item.Module_ReworkType == 1 || item.TAS_ReworkType == 1 ||
		item.STRESS_ReworkType == 1 || item.PO_ReworkType == 1;

	// Helper function to check if item is marked for trial assembly at ANY stage
	Func<NonConformanceReport_ItemVM, bool> IsMarkedForTrialAssembly = (item) =>
		item.Module_ReworkType == 2 || item.TAS_ReworkType == 2 ||
		item.STRESS_ReworkType == 2 || item.PO_ReworkType == 2;

	// Helper function to check if item is marked for ANY rework type at ANY stage
	Func<NonConformanceReport_ItemVM, bool> IsMarkedForAnyRework = (item) =>
		IsMarkedForRework(item) || IsMarkedForTrialAssembly(item);
}

