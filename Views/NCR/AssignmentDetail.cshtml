<style>
	/* Clean Component Details Table */
	/* Clean Component Details Table */
	#ncrDetailsTbl {
		border: 1px solid #dee2e6;
		background-color: #fff;
		font-size: 12px;
		margin-bottom: 10px;
	}

		#ncrDetailsTbl td {
			padding: 5px 7px !important;
			border: 1px solid #dee2e6;
			vertical-align: middle;
			background-color: #fff;
		}

			#ncrDetailsTbl td:nth-child(odd) {
				font-weight: 600;
				color: #495057;
				width: 18%;
			}

			#ncrDetailsTbl td:nth-child(even) {
				color: #212529;
				width: 32%;
			}

		/* Header row */
		#ncrDetailsTbl tr:first-child td:first-child,
		#ncrDetailsTbl tr:first-child td:nth-child(3) {
			font-weight: 700;
			color: #212529;
		}

	.details-container {
		background-color: #fff;
		border: 1px solid #dee2e6;
		border-radius: 4px;
		padding: 0;
		margin-bottom: 20px;
	}

	/* Notes part*/

	.notes-section {
		background-color: #f8f9fa;
		padding: 15px;
		border-radius: 4px;
		border: 1px solid #dee2e6;
	}

	.notes-title {
		font-weight: 600;
		color: #212529;
		margin-bottom: 12px;
		font-size: 15px;
	}

	.note-item {
		display: flex;
		margin-bottom: 10px;
		align-items: flex-start;
	}

	.note-number {
		font-weight: 600;
		color: #495057;
		margin-right: 8px;
		min-width: 20px;
	}

	.note-text {
		flex: 1;
		font-size: 14px;
		line-height: 1.4;
		color: #495057;
	}


	/* Complete itemsTbl Styling */
	#itemsTbl {
		border: 1px solid #dee2e6;
		background-color: #fff;
		font-size: 14px;
	}

		/* Table Headers */
		#itemsTbl thead th {
			background-color: #f8f9fa;
			font-weight: 600;
			padding: 12px 8px;
			border: 1px solid #dee2e6;
			text-align: center;
			vertical-align: middle;
			color: #495057;
			font-size: 13px;
			line-height: 1.3;
		}

		/* Table Body Cells */
		#itemsTbl tbody td {
			padding: 8px;
			border: 1px solid #dee2e6;
			vertical-align: middle;
			background-color: #fff;
		}

		/* Readonly dimension display - direct HTML rendering */
		#itemsTbl tbody .readonly-dimension-display {
			padding: 8px;
			font-size: 14px;
			line-height: 1.4;
			color: #212529;
			font-family: inherit;
			min-height: 50px;
			word-wrap: break-word;
			overflow-wrap: break-word;
		}

			/* Ensure HTML content in readonly displays renders properly */
			#itemsTbl tbody .readonly-dimension-display p {
				margin: 0;
				padding: 0;
			}

			#itemsTbl tbody .readonly-dimension-display span {
				font-size: 14px;
				line-height: 1.4;
			}



		/* TinyMCE containers for readonly dimensions */
		#itemsTbl tbody td .readonly-dimension + .tox .tox-sidebar-wrap,
		#itemsTbl tbody td:has(.readonly-dimension) .tox .tox-sidebar-wrap {
			border: none !important;
			background: transparent !important;
			box-shadow: none !important;
			padding-left: 5px;
		}

		/* Editable textarea styling for remarks columns */
		#itemsTbl .serialNoRemarks,
		#itemsTbl .TASremarks,
		#itemsTbl .AfterMarksAsCompleteRemarks {
			border: 1px solid #ced4da !important;
			border-radius: 4px;
			padding: 8px;
			font-size: 14px;
			background-color: #fff;
			min-height: 60px;
			resize: vertical;
		}

			#itemsTbl .serialNoRemarks:focus,
			#itemsTbl .TASremarks:focus,
			#itemsTbl .AfterMarksAsCompleteRemarks:focus {
				border-color: #80bdff;
				outline: 0;
				box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
			}

			/* TinyMCE containers for editable remarks */
			#itemsTbl .serialNoRemarks + .symbolDropdown,
			#itemsTbl .TASremarks + .symbolDropdown,
			#itemsTbl .AfterMarksAsCompleteRemarks + .symbolDropdown {
				border: 1px solid #ced4da;
				border-radius: 4px;
				min-height: 60px;
			}

		#itemsTbl label {
			padding-left: 2px;
		}
</style>

<style>
	/* Loading Overlay Styles */
	.table-loading-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background-color: rgba(255, 255, 255, 0.95);
		display: flex;
		justify-content: center;
		align-items: center;
		z-index: 1000;
		border-radius: 4px;
	}

	.table-loading-spinner {
		text-align: center;
		color: #495057;
	}

		.table-loading-spinner .spinner-border {
			width: 3rem;
			height: 3rem;
			border-width: 0.3rem;
		}

		.table-loading-spinner p {
			font-size: 14px;
			font-weight: 500;
			color: #6c757d;
		}

	/* Hide overlay when table is ready */
	.table-loading-overlay.hidden {
		display: none;
	}
</style>


<div class="row">
	<div class="col-4">
		@{
			if (closeNCR != true)
			{
				<h4>NCR</h4>
			}
			else
			{
				<h4>NCR Closed</h4>
			}
		}
	</div>
</div>
<div class="row">

	<div class="col-12 pull-right  no-print " id="buttons-area">

		<a class="btn btn-secondary  btn-sm float-end" href="/NCR/AssignedNCRList">Back</a>
		@{
			if (closeNCR != true)
			{

				@if (NCR_Module_User && NCR_Assignments_Admin == false)
				{
					<input type="button" id="ReferDeviationBtn" class="btn btn-primary  btn-sm float-end" style="margin-right:10px;" value="Refer deviation to other module" onclick="TransferNCRModuleItem('@Model.NcrItems.FirstOrDefault().NCRGuid')" />
					<input type="button" id="MarkAsCompleteBtn" class="btn btn-success  btn-sm float-end" style="margin-right:10px;" value="Mark as complete" onclick="MarkUpdatingRemarksAsCompleted()" />
				}



				// rework forward buttons
				if (NCR_Assignments_Admin && MarkedForRework && allSTRESSRemarksUpdated)
				{
				 
					//if (all_STRESS_Rework_Remarks_updated && !forwardedToCHAIR)

					// if (all_STRESS_Rework_Remarks_updated && !forwardedToCHAIR && forwardedToSTRESS_Rework)
					// {
					// 	<input type="button" class="btn btn-primary  btn-sm float-end" style="margin-right:10px;" value="Complete rework/trial assembly cycle and forward to CAHIR" onclick="GetPopupToAssignModuleToNCR('@Model.NcrItems.FirstOrDefault().NCRGuid','@CHAIRmoduleId','CHAIR')" />
					// }
					// else if (!forwardedToSTRESS_Rework && all_TAS_Rework_Remarks_updated && !onlyTrialAssembly)
					// {
					// 	<input type="button" class="btn btn-primary  btn-sm float-end" style="margin-right:10px;" value="Forward to STRESS for rework/trial assembly Remark" onclick="GetPopupToAssignModuleToNCR('@Model.NcrItems.FirstOrDefault().NCRGuid','@STRESSmoduleId','STRESS')" />
					// }
					if (all_STRESS_Rework_Remarks_updated && !forwardedToCHAIR && forwardedToSTRESS_Rework)
					{
						<input type="button" class="btn btn-primary  btn-sm float-end" style="margin-right:10px;" value="Complete rework/trial assembly cycle and forward to CAHIR" onclick="GetPopupToAssignModuleToNCR('@Model.NcrItems.FirstOrDefault().NCRGuid','@CHAIRmoduleId','CHAIR')" />
					}
					else if (!forwardedToSTRESS_Rework && all_TAS_Rework_Remarks_updated && onlyTrialAssembly && forwardedToTAS_Rework)
					{
						<input type="button" class="btn btn-primary  btn-sm float-end" style="margin-right:10px;" value="Complete rework/trial assembly cycle and forward to CAHIR (Skip STRESS)" onclick="GetPopupToAssignModuleToNCR('@Model.NcrItems.FirstOrDefault().NCRGuid','@CHAIRmoduleId','CHAIR')" />
					}
					else if (!forwardedToSTRESS_Rework && all_TAS_Rework_Remarks_updated && !onlyTrialAssembly)
					{
						<input type="button" class="btn btn-primary  btn-sm float-end" style="margin-right:10px;" value="Forward to STRESS for rework/trial assembly Remark" onclick="GetPopupToAssignModuleToNCR('@Model.NcrItems.FirstOrDefault().NCRGuid','@STRESSmoduleId','STRESS')" />
					}
					else if (!forwardedToTAS_Rework && all_Module_Rework_Remarks_updated)
					{
						<input type="button" class="btn btn-primary  btn-sm float-end" style="margin-right:10px;" value="Forward to TAS for rework/trial assembly Remark" onclick="GetPopupToAssignModuleToNCR('@Model.NcrItems.FirstOrDefault().NCRGuid','@TASmoduleId','TAS')" />
					}
					else if (!forwardedToModule_Rework)
					{
						<input type="button" class="btn btn-primary  btn-sm float-end" style="margin-right:10px;" value="Forward to Module for rework/trial assembly Remark" onclick="GetPopupToAssignModuleToNCR('@Model.NcrItems.FirstOrDefault().NCRGuid',0)" />
					}
				}
				//normal forward buttons
				else
				{
					if (NCR_Assignments_Admin && allSTRESSRemarksUpdated && !forwardedToCHAIR && !MarkedForRework)
					{
						<input type="button" class="btn btn-primary  btn-sm float-end" style="margin-right:10px;" value="Forward to CHAIR" onclick="forwardNCRtoModule('@Model.NcrItems.FirstOrDefault().NCRGuid','@CHAIRmoduleId','CHAIR')" />
					}
					else if (NCR_Assignments_Admin && allTASRemarksUpdated && !forwardedToSTRESS)
					{
						<input type="button" class="btn btn-primary  btn-sm float-end" style="margin-right:10px;" value="Forward to STRESS" onclick="forwardNCRtoModule('@Model.NcrItems.FirstOrDefault().NCRGuid','@STRESSmoduleId','STRESS')" />
					}
					else if (NCR_Assignments_Admin && allModuleRemarksUpdated && !forwardedToTAS)
					{
						<input type="button" class="btn btn-primary  btn-sm float-end" style="margin-right:10px;" value="Forward to TAS" onclick="forwardNCRtoModule('@Model.NcrItems.FirstOrDefault().NCRGuid','@TASmoduleId','TAS')" />
					}
				}



				//print, delete, close
				if (NCR_Assignments_Admin)
				{
					<input type="button" class="btn btn-primary  btn-sm float-left" style="margin-right:10px;" onclick="printNCRReport('@Model.AssignmentData.NCRGUID')" value="Print Report" />

					@if (allCHAIRRemarksUpdated)
					{
						<input type="button" class="btn btn-success  btn-sm float-left" style="margin-right:10px;" value="Close NCR" onclick="CloseNCR('@Model.AssignmentData.NCRGUID')" />
					}
					@if (NCR_Assignments_Admin_Delete)
					{
						<input type="button" class="btn btn-danger btn-sm float-left" style="margin-right:10px;" value="Delete Assignment" onclick="ncrModuleDelete('@Model.AssignmentData.NCRGUID','@Model.AssignmentData.NCRWorkflowGUID')" />
					}
					// if (forwardedToCHAIR)
					// {
					// 	<input type="button" id="MarkSerialNoStatus" class="btn btn-success  btn-sm float-end" style="margin-right:10px;" value="Mark Serial No. status" onclick="MarkSerialNoStatus('@Model.NcrItems.FirstOrDefault().NCRGuid')" />

					// }
				}

			}
			else
			{

				if (NCR_Assignments_Admin == true)
				{
					<input type="button" class="btn btn-primary  btn-sm float-end" style="margin-right:10px;" onclick="printNCRReport('@Model.AssignmentData.NCRGUID')" value="Print Report" />
				}
			}

		}

	</div>
</div>


<hr class="no-print" />
