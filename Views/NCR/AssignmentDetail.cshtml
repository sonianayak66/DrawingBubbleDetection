														   data-stage="PO"
														   @(item.PO_ReworkType == 2 ? "checked" : "")
														   @(reworkCycleStarted ? "disabled" : "")
														   onclick="handleReworkCheckbox(this, 2)">
													<label class="form-check-label" for="trialAssembly-checkbox-@item.NCRItemKey">Trial Assembly</label>
												</div>
												<div class="form-check checkbox-sm">
													<input class="form-check-input accepted-checkbox"
														   type="checkbox"
														   id="accepted-checkbox-@item.NCRItemKey"
														   onclick="markAsAccepted(this, @item.NCRItemKey,'STFE_PO_Remark')">
													<label class="form-check-label" for="accepted-checkbox-@item.NCRItemKey">Accepted under concession</label>
												</div>
											</div>

											<textarea style="font-size:1rem;height:100%;" data-field="STFE_PO_Remark"
													  data-ncrItemKey="@item.NCRItemKey"
													  data-workFlowGuid="@item.NCRWorkFlowGuid"
													  data-NCRGuid="@item.NCRGuid"
													  class="form-control form-control-square serialNoRemarks"
													  onchange="autoSaveRemarks(this,@item.NCRItemKey)"
													  id="po-textarea-@item.NCRItemKey"
													  asp-for="@item.STFE_PO_Remark"></textarea>
											<div class="symbolDropdown"></div>
										</div>
									}
									else
									{ 
										if (item.PO_ReworkType == 1)

										{
											<i>Marked for rework</i>
											 
										}
										else if (item.PO_ReworkType == 2)
										{
											<i>Marked for Trial Assembly</i>
										 
										}
										<br />
										<label>@Html.Raw(item.STFE_PO_Remark)</label>
									}
								}
							</td>


							@if (NCR_Assignments_Module_Delete && !NCR_Assignments_Admin)
							{
								@if (item.AssignedBy == userOldDBKey && item.Workflow_Assignments_Status != "MarkedAsComplete")
								{
									<td style="text-align: center" class=" no-print">
										<input type="button" class="text-center btn btn-danger btn-small" onclick="ncrItemDelete('@item.NCRGuid','@item.NCRWorkFlowGuid', '@item.NCRItemKey')" value="Revert referred devaiation" />
									</td>
								}
								else
								{
									<td class=" no-print"></td>
								}
							}

						</tr>
					}
				}
			</tbody>

		</table>
	</div>

	@*Logs*@
	<hr />
	@{
		if (Model.workFlowLogs.Count > 0)
		{
			<div class="col-12 no-print">
				<h5>Activity Log</h5>
				<details>
					<summary>Show Logs</summary>
					<table class="table table-bordered table-condensed" id="WorkflowLogTbl">
						<thead>
							<tr>
								<th>Time stamp</th>
								<th>User</th>
								<th>Status</th>
								<th>Remarks</th>
								<th>Status Description</th>
							</tr>
						</thead>

						<tbody>
							@{
								foreach (var log in Model.workFlowLogs.OrderBy(X => X.UpdatedOn))
								{
									<tr>
										<td data-date="@log.UpdatedOn">@MPGlobals.GetFormattedDateTime(log.UpdatedOn)</td>
										<td>@log.UpdatedBy</td>
										<td>@log.Status</td>
										<td>@Html.Raw(log.Remarks)</td>
										<td>@Html.Raw(log.Status_Verbose)</td>
