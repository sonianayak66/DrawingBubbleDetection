										if (item.AssigneeUserGUIDs.Contains(userguid)
										&& !NCR_Assignments_Admin
										&& item.Module_Status == "Forwarded To MODULE"
										&& (item.TAS_Status != "Forwarded To TAS" || item.TAS_Status != "MarkedAsComplete")
										&& (item.Stress_Status != "Forwarded To STRESS" || item.Stress_Status != "MarkedAsComplete")
										&& (item.Chair_Status != "Forwarded To CHAIR" || item.Chair_Status != "MarkedAsComplete")
										&& item.Module_Rework_Status != "Forwarded To Module")
										{
											<div class="gd-t-container">
												<!-- Checkboxes - STAGE SPECIFIC (correct) -->
												<div>
													<div class="form-check checkbox-sm">
