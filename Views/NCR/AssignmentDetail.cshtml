													  data-NCRGuid="@item.NCRGuid"
													  class="form-control form-control-square AfterMarksAsCompleteRemarks"
													  onchange="updateRemarksAfterMarkAsComplete(this,@item.NCRItemKey)"
													  id="">
												</textarea>
												<div class="symbolDropdown"></div>
											</div>
										}
									}
									else if (item.Module_Remarks != null)
									{
										if (item.Module_ReworkType == 1)
										{
											<i>Marked for rework</i>
										}
										else if (item.Module_ReworkType == 2)
										{
											<i>Marked for Trial Assembly</i>
										}
										<br />
										<label>@Html.Raw(item.Module_Remarks)</label>
