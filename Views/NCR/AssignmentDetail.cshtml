	@*<div class="mb-3">
		<table class="table table-bordered" id="itemsTbl">*@
	<div class="table-responsive" style="position: relative;">
		<!-- Loading Overlay -->
		<div id="tableLoadingOverlay" class="table-loading-overlay">
			<div class="table-loading-spinner">
				<div class="spinner-border text-primary" role="status">
					<span class="visually-hidden">Loading...</span>
				</div>
				<p class="mt-2 mb-0">Loading assignment details...</p>
			</div>
		</div>

		<table class="table table-bordered" id="itemsTbl" style="opacity: 0; transition: opacity 0.3s ease;">
			<thead class="no-word-break">
				<tr>
					<th>SlNo.</th>
					<th style="width:5%">Serial no in Insp Rep</th>
					<th style="width:5%">Drg Zone</th>
					<th style="width:5%">Serial Number</th>
					<th style="width:10%">Drawing Dimension</th>
					<th style="width:10%">Actual Dimension</th>
					<th style="width:10%">Reason/Analysis</th>
					@if (MarkedForRework && Model.NcrItems.Any(x => !String.IsNullOrEmpty(x.Rework_Dimension)))
					{
						<th style="width:10%">Rework Dimension/Trial Assembly Remark</th>
					}

					@*<th style="width:5%" class=" no-print">Module Referred</th>
					<th>Engine</th>
					<th>Status</th>*@
					@if (forwardedToTAS)
					{
						<th style="width:10%">
							Effect of Deviation on Assembly Aero-thermal Design Performance
						</th>
					}
					else
					{
						<th style="width:10%">
							Effect of Deviation on Assembly Aero-thermal Design Performance
							<br />
							<small class="text-muted">*Leave blank to refer deviation to other module</small>
						</th>
					}

					@if (forwardedToTAS && (!forwardedToSTRESS))
					{
						<th style="width:10%">
							Effect of Deviation on Assembly
							<br />
							<small class="text-muted">*Leave blank to refer deviation to other module</small>
						</th>
					}
					else
					{
						<th style="width:10%">Effect of Deviation on Assembly</th>
					}


					@if (forwardedToSTRESS && (!forwardedToCHAIR))
					{
						<th style="width:10%">
							Effect of Deviation on Structural Integrity
							<br />
							<small class="text-muted">*Leave blank to refer deviation to other module</small>
						</th>
					}
					else
					{
						<th style="width:10%">Effect of Deviation on Structural Integrity</th>
					}

					<th style="width:10%">CHAIR Remarks </th>
					<th style="width:10%">Remarks (PO)</th>
					@if (NCR_Assignments_Module_Delete && !NCR_Assignments_Admin)
					{
						<th style="width:5%" class="no-print"></th>
					}

				</tr>
			</thead>
			<tbody id="tblbody">
				@{
					foreach (var item in Model.NcrItems)
					{
						// <tr style="color: @(item.Rework_Status == 1 ? "#EE4B2B" : item.Rework_Status == 2 ? "#BF40BF" : "");">
