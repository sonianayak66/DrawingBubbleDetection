							{
								if (item.Rework_Dimension != null)
								{
									<td><div class="readonly-dimension-display">@Html.Raw(item.Rework_Dimension)</div></td>
								}
								else
								{
									<td><label class="d-flex justify-content-center align-item-center" style="font-size:xx-large">-</label></td>
								}

							}


							@* Module Remarks *@
							<td>
								@{
									bool reworkCycleStarted = !string.IsNullOrEmpty(item.Module_Rework_Status)
									|| !string.IsNullOrEmpty(item.TAS_Rework_Status)
									|| !string.IsNullOrEmpty(item.STRESS_Rework_Status)
									|| !string.IsNullOrEmpty(item.CHAIR_Rework_Status);

