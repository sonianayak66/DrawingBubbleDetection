@using Newtonsoft.Json;
 
@{

    var dataTable = MPCRS.Utilities.MPGlobals.GetDataForDatatable("select * from [dbo].[NonConformanceReport] with(nolock)");
    List<NonConformanceReport> data = JsonConvert.DeserializeObject<List<NonConformanceReport>>(JsonConvert.SerializeObject(dataTable));

    int total = 0;
    int rejected = 0;
    int inProgressL1 = 0;
    int inProgressL2 = 0;
    int partiallyCleared = 0;
    int cleared = 0;

    if (data != null &&  data.Count > 0)
    {
        total = data.Count;
        rejected = data.Where(x => x.ReportStatus == "Rejected").Count();
        inProgressL1 = data.Where(x => x.ReportStatus == "In Process" && x.ComitteeReferred == "L1").Count();
        inProgressL2 = data.Where(x => x.ReportStatus == "In Process" && x.ComitteeReferred == "L2").Count();
        partiallyCleared = data.Where(x => x.ReportStatus == "Processed - Partially Cleared").Count();
        cleared = data.Where(x => x.ReportStatus == "Cleared").Count();
    }
     
    <div class="mb-5">
        <div class="card-body">
            <div class="row g-4 g-xl-1 g-xxl-3 justify-content-between">
                <div class="col-auto">
                    <div class="d--block d-inline-flex align-items-center  border-start ps-sm-5">

                        <div class="d-flex bg-primary-200 rounded flex-center me-3 mb-sm-3 mb-md-0 mb-xl-3 mb-xxl-0" style="width:32px; height:32px">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-archive" viewBox="0 0 16 16">
                                <path d="M0 2a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1v7.5a2.5 2.5 0 0 1-2.5 2.5h-9A2.5 2.5 0 0 1 1 12.5V5a1 1 0 0 1-1-1V2zm2 3v7.5A1.5 1.5 0 0 0 3.5 14h9a1.5 1.5 0 0 0 1.5-1.5V5H2zm13-3H1v2h14V2zM5 7.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5z" />
                            </svg>
                        </div>
                        <div>

                            <div class="badge bg-primary-100 text-dark text-sm">
                                <h5 class="fw-bold mb-1 ">Total Reports</h5>   
                                <h5 class="fw-bolder text-nowrap">@total</h5>
                            </div>  
                        </div>
                    </div>
                </div>
                <div class="col-auto">
                    <div class="d--block d-inline-flex align-items-center  border-start ps-sm-5">
                        <div class="d-flex bg-warning-200 rounded flex-center me-3 mb-sm-3 mb-md-0 mb-xl-3 mb-xxl-0" style="width:32px; height:32px">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16px" height="16px" fill="currentColor" class="bi bi-segmented-nav" viewBox="0 0 16 16">
                                <path d="M0 6a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v2a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V6zm6 3h4V5H6v4zm9-1V6a1 1 0 0 0-1-1h-3v4h3a1 1 0 0 0 1-1z" />
                            </svg>
                        </div>
                        <div>

                            <div class="badge bg-warning-100 text-dark">
                                <h5 class="fw-bold mb-1">In Progress</h5>

                            <div class="badge bg-warning-100 text-dark position-relative m-1">
                                
                                <h5>@inProgressL1</h5>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill mb-2 bg-dark">
                                    L1                                  
                                </span>
                            </div>

                            <div class="badge bg-warning-100 text-dark position-relative m-1">
                               
                                <h5>@inProgressL2</h5>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill mb-2 bg-dark">
                                    L2
                                </span>
                            </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-auto">
                    <div class="d--block d-inline-flex align-items-center  border-start ps-sm-5">
                        <div class="d-flex bg-success-200 rounded flex-center me-3 mb-sm-3 mb-md-0 mb-xl-3 mb-xxl-0" style="width:32px; height:32px; background-color:#e9d2ee!important">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16px" height="16px" fill="currentColor" class="bi bi-segmented-nav" viewBox="0 0 16 16">
                                <path d="M0 6a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v2a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V6zm6 6v4zm9-1V6a1 1 0 0 0-1-1h-3v4h3a1 1 0 0 0 1-1z" />
                            </svg>
                        </div>
                        <div>

                            <div class="badge bg-success-100 text-dark" style="background-color:#e9d2ee!important">
                                <h5 class="fw-bold mb-1">Processed - Partially Cleared</h5>  <h5 class="fw-bolder text-nowrap">@partiallyCleared</h5>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-auto">
                    <div class="d--block d-inline-flex align-items-center  border-start ps-sm-5">
                        <div class="d-flex bg-success-200 rounded flex-center me-3 mb-sm-3 mb-md-0 mb-xl-3 mb-xxl-0" style="width:32px; height:32px">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16px" height="16px" fill="currentColor" class="bi bi-journal-check" viewBox="0 0 16 16">
                                <path fill-rule="evenodd" d="M10.854 6.146a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 1 1 .708-.708L7.5 8.793l2.646-2.647a.5.5 0 0 1 .708 0z" />
                                <path d="M3 0h10a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2v-1h1v1a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H3a1 1 0 0 0-1 1v1H1V2a2 2 0 0 1 2-2z" />
                                <path d="M1 5v-.5a.5.5 0 0 1 1 0V5h.5a.5.5 0 0 1 0 1h-2a.5.5 0 0 1 0-1H1zm0 3v-.5a.5.5 0 0 1 1 0V8h.5a.5.5 0 0 1 0 1h-2a.5.5 0 0 1 0-1H1zm0 3v-.5a.5.5 0 0 1 1 0v.5h.5a.5.5 0 0 1 0 1h-2a.5.5 0 0 1 0-1H1z" />
                            </svg>
                        </div>
                        <div>
                          
                            <div class="badge bg-success-100 text-dark">
                                <h5 class="fw-bold mb-1">Cleared</h5>  <h5 class="fw-bolder text-nowrap">@cleared</h5>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-auto">
                    <div class="d--block d-inline-flex align-items-center  border-start ps-sm-5">
                        <div class="d-flex bg-danger-200 rounded flex-center me-3 mb-sm-3 mb-md-0 mb-xl-3 mb-xxl-0" style="width:32px; height:32px">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16px" height="16px" fill="currentColor" class="bi bi-x-octagon" viewBox="0 0 16 16">
                                <path d="M4.54.146A.5.5 0 0 1 4.893 0h6.214a.5.5 0 0 1 .353.146l4.394 4.394a.5.5 0 0 1 .146.353v6.214a.5.5 0 0 1-.146.353l-4.394 4.394a.5.5 0 0 1-.353.146H4.893a.5.5 0 0 1-.353-.146L.146 11.46A.5.5 0 0 1 0 11.107V4.893a.5.5 0 0 1 .146-.353L4.54.146zM5.1 1 1 5.1v5.8L5.1 15h5.8l4.1-4.1V5.1L10.9 1H5.1z" />
                                <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z" />
                            </svg>
                        </div>
                        <div>
                            
                            <div class="badge bg-danger-100 text-dark">
                                <h5 class="fw-bold mb-1">Rejected</h5> <h5 class="fw-bolder text-nowrap">@rejected</h5>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
      
}
