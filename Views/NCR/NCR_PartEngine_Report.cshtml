@model MPCRS.ViewModels.NCRPartEngineReportViewModel
@{
    ViewData["Title"] = "NCR Part-Engine Report";

    //@await Html.PartialAsync("_BackToReports") //Added

    var statusOverview = ViewBag.StatusOverview as MPCRS.ViewModels.NCRStatusOverviewVM ?? new MPCRS.ViewModels.NCRStatusOverviewVM();
    var engineDist = ViewBag.EngineDistribution as MPCRS.ViewModels.NCREngineDistributionVM ?? new MPCRS.ViewModels.NCREngineDistributionVM();
    var duplicateDeviations = ViewBag.DuplicateDeviations as List<MPCRS.ViewModels.DuplicateDeviationItem> ?? new List<MPCRS.ViewModels.DuplicateDeviationItem>();
    var duplicateGroupCount = duplicateDeviations.Select(x => x.DuplicateGroupId).Distinct().Count();

    var totalNCRs = statusOverview.ReportStatusCounts.Sum(x => x.NCRCount);
    var inProcessCount = statusOverview.ReportStatusCounts.FirstOrDefault(x => x.ReportStatus == "In Process")?.NCRCount ?? 0;
    var inWorkflowCount = statusOverview.WorkflowStageCounts.Where(x => x.WorkflowStage != "Not Yet Assigned").Sum(x => x.NCRCount);
    var notAssignedCount = statusOverview.WorkflowStageCounts.FirstOrDefault(x => x.WorkflowStage == "Not Yet Assigned")?.NCRCount ?? 0;

    var engines = engineDist.EngineStatusCounts.Select(x => x.Engine).Distinct().OrderBy(x => x).ToList();
}

<style>
    .report-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 10px;
    }

    .report-title {
        font-size: 18px;
        font-weight: 600;
        margin: 0;
        color: #2c3e50;
    }

    .nav-tabs {
        border-bottom: 2px solid #dee2e6;
    }

        .nav-tabs .nav-link {
            color: #495057;
            border: none;
            border-bottom: 3px solid transparent;
            padding: 8px 16px;
            font-weight: 500;
            font-size: 13px;
        }

            .nav-tabs .nav-link:hover {
                background-color: #f8f9fa;
            }

            .nav-tabs .nav-link.active {
                color: #2c6fbb;
                border-color: transparent transparent #2c6fbb;
            }

    .tab-content {
        padding: 12px 0 0 0;
    }

    .tab-badge {
        font-size: 10px;
        padding: 2px 6px;
        border-radius: 10px;
        margin-left: 4px;
    }

    .status-cards {
        display: flex;
        gap: 8px;
        margin-bottom: 14px;
        flex-wrap: wrap;
    }

    .status-card {
        flex: 1;
        min-width: 120px;
        padding: 10px 14px;
        border-radius: 6px;
        text-align: center;
        border: 1px solid #e0e0e0;
        cursor: pointer;
        transition: all 0.15s ease;
    }

        .status-card:hover {
            opacity: 0.85;
            box-shadow: 0 2px 6px rgba(0,0,0,0.15);
        }

    .status-card-label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 2px;
    }

    .status-card-count {
        font-size: 22px;
        font-weight: 700;
    }

    .sc-total {
        background: #2c3e50;
        color: #fff;
        cursor: default;
    }

        .sc-total:hover {
            opacity: 1;
            box-shadow: none;
        }

    .sc-inprocess {
        background: #fff3cd;
        color: #856404;
        border-color: #ffc107;
    }

    .sc-cleared {
        background: #d4edda;
        color: #155724;
        border-color: #28a745;
    }

    .sc-rejected {
        background: #f8d7da;
        color: #721c24;
        border-color: #dc3545;
    }

    .sc-partial {
        background: #e2e3f1;
        color: #383d6e;
        border-color: #6c6fc7;
    }

    .sc-other {
        background: #e9ecef;
        color: #495057;
    }

    .flow-section {
        margin-bottom: 14px;
    }

    .flow-section-title {
        font-size: 13px;
        font-weight: 600;
        color: #2c3e50;
        margin-bottom: 6px;
        padding-bottom: 4px;
        border-bottom: 1px solid #dee2e6;
    }

    .flow-tree {
        padding-left: 0;
        list-style: none;
        margin: 0;
    }

        .flow-tree .flow-branch {
            position: relative;
            padding-left: 20px;
            margin-bottom: 0;
        }

            .flow-tree .flow-branch::before {
                content: '';
                position: absolute;
                left: 6px;
                top: 0;
                bottom: 0;
                width: 1px;
                background: #ced4da;
            }

            .flow-tree .flow-branch:last-child::before {
                bottom: 50%;
            }

    .flow-node {
        display: flex;
        align-items: center;
        padding: 4px 10px;
        margin: 2px 0;
        border-radius: 4px;
        font-size: 12px;
        position: relative;
        gap: 8px;
    }

        .flow-node::before {
            content: '';
            position: absolute;
            left: -14px;
            top: 50%;
            width: 14px;
            height: 1px;
            background: #ced4da;
        }

    .flow-node-label {
        flex: 1;
        font-weight: 500;
    }

    .flow-node-count {
        font-weight: 700;
        font-size: 13px;
        min-width: 28px;
        text-align: center;
        background: rgba(0,0,0,0.08);
        border-radius: 4px;
        padding: 1px 6px;
    }

    .flow-node-bar {
        height: 6px;
        border-radius: 3px;
        min-width: 4px;
    }

    .fn-inprocess {
        background-color: #fff8e1;
    }

        .fn-inprocess .flow-node-bar {
            background: #ffc107;
        }

    .fn-workflow {
        background-color: #e3f2fd;
    }

        .fn-workflow .flow-node-bar {
            background: #2196f3;
        }

    .fn-notassigned {
        background-color: #fce4ec;
    }

        .fn-notassigned .flow-node-bar {
            background: #e91e63;
        }

    .fn-module {
        background-color: #e8f5e9;
    }

        .fn-module .flow-node-bar {
            background: #4caf50;
        }

    .fn-tas {
        background-color: #e0f7fa;
    }

        .fn-tas .flow-node-bar {
            background: #00bcd4;
        }

    .fn-stress {
        background-color: #f3e5f5;
    }

        .fn-stress .flow-node-bar {
            background: #9c27b0;
        }

    .fn-chair {
        background-color: #fff3e0;
    }

        .fn-chair .flow-node-bar {
            background: #ff9800;
        }

    .fn-rework {
        background-color: #ffebee;
    }

        .fn-rework .flow-node-bar {
            background: #f44336;
        }

    .fn-closed {
        background-color: #e8f5e9;
    }

        .fn-closed .flow-node-bar {
            background: #4caf50;
        }

    .fn-complete {
        background-color: #e1f5fe;
    }

        .fn-complete .flow-node-bar {
            background: #0288d1;
        }

    .drilldown-row {
        cursor: pointer;
    }

        .drilldown-row:hover {
            opacity: 0.85;
            box-shadow: 0 0 0 1px rgba(0,0,0,0.15);
            transition: all 0.15s ease;
        }

    .engine-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 10px;
    }

    .engine-card {
        border: 1px solid #dee2e6;
        border-radius: 6px;
        overflow: hidden;
        box-shadow: 0 1px 2px rgba(0,0,0,0.06);
    }

    .engine-card-header {
        background: #3a5a8c;
        color: #fff;
        padding: 5px 10px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 12px;
        font-weight: 600;
    }

    .engine-card-total {
        background: rgba(255,255,255,0.2);
        padding: 1px 8px;
        border-radius: 10px;
        font-size: 11px;
    }

    .engine-card-body {
        padding: 6px 10px;
    }

    .engine-status-row {
        display: flex;
        align-items: center;
        padding: 2px 0;
        font-size: 12px;
        border-bottom: 1px solid #f0f0f0;
        gap: 6px;
    }

        .engine-status-row:last-child {
            border-bottom: none;
        }

    .engine-status-label {
        flex: 1;
    }

    .engine-status-count {
        font-weight: 700;
        min-width: 24px;
        text-align: right;
    }

    .engine-workflow-indent {
        padding-left: 16px;
        font-size: 11px;
        color: #555;
    }

    .engine-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .dot-inprocess {
        background: #ffc107;
    }

    .dot-cleared {
        background: #28a745;
    }

    .dot-rejected {
        background: #dc3545;
    }

    .dot-partial {
        background: #6c6fc7;
    }

    .dot-workflow {
        background: #2196f3;
    }

    .dot-notassigned {
        background: #e91e63;
    }

    .dot-nostatus {
        background: #adb5bd;
    }

    .table-loading-overlay {
        position: relative;
    }

        .table-loading-overlay::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255,255,255,0.8);
            z-index: 10;
        }

        .table-loading-overlay::after {
            content: 'Loading...';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%,-50%);
            z-index: 11;
            font-size: 16px;
            font-weight: 600;
            color: #6c757d;
        }

    #partEngineReportTable {
        font-size: 12px;
    }

        #partEngineReportTable thead th {
            background-color: #3a5a8c;
            color: #fff;
            font-weight: 600;
            padding: 8px 6px;
            font-size: 12px;
            white-space: nowrap;
        }

        #partEngineReportTable tbody td {
            padding: 6px;
            vertical-align: top;
            line-height: 1.4;
            min-width: 120px;
            font-size: 11px;
        }

            #partEngineReportTable tbody td:first-child {
                min-width: 100px;
                white-space: nowrap;
            }

            #partEngineReportTable tbody td:nth-child(2) {
                min-width: 150px;
            }

    #duplicateDeviationsTable {
        font-size: 12px;
    }

        #duplicateDeviationsTable thead th {
            background-color: #5a3e3e;
            color: #fff;
            font-weight: 600;
            padding: 8px 6px;
            font-size: 12px;
        }

        #duplicateDeviationsTable tbody td {
            padding: 6px;
            vertical-align: top;
        }

    .dup-group-even {
        background-color: #fff8f0 !important;
    }

    .dup-group-odd {
        background-color: #f0f4ff !important;
    }

    .dup-count-badge {
        display: inline-block;
        background: #dc3545;
        color: #fff;
        font-size: 11px;
        font-weight: 600;
        padding: 2px 8px;
        border-radius: 10px;
    }

    .status-badge {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 500;
        white-space: nowrap;
    }

    .status-closed {
        background-color: #d4edda;
        color: #155724;
    }

    .status-inprocess {
        background-color: #fff3cd;
        color: #856404;
    }

    .status-forwarded {
        background-color: #d1ecf1;
        color: #0c5460;
    }

    .status-complete {
        background-color: #cce5ff;
        color: #004085;
    }

    .status-rework {
        background-color: #f8d7da;
        color: #721c24;
    }

    .dataTables_wrapper {
        margin: 0;
        padding: 0;
    }

        .dataTables_wrapper .dt-buttons {
            margin-bottom: 8px;
        }

    .dt-button {
        padding: 4px 12px !important;
        font-size: 12px !important;
    }

    @@media (max-width: 768px) {
        .status-cards {
            flex-direction: column;
        }

        .engine-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="report-header">
    <h4 class="report-title"><i class="fas fa-file-alt text-muted"></i> NCR Report</h4>
    <a class="btn btn-secondary btn-sm" href="/ncr/index"><i class="fas fa-arrow-left"></i> Back</a>
</div>

<ul class="nav nav-tabs" id="reportTabs" role="tablist">
    <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#statusOverview" type="button"><i class="fas fa-sitemap"></i> Status Overview</button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#engineDist" type="button"><i class="fas fa-cogs"></i> Engine Distribution</button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tableView" type="button"><i class="fas fa-table"></i> Table View</button></li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#duplicatesView" type="button">
            <i class="fas fa-copy"></i> Duplicates
            @if (duplicateGroupCount > 0)
            {
                <span class="badge bg-danger tab-badge">@duplicateGroupCount</span>
            }
        </button>
    </li>
</ul>

<div class="tab-content">

    <!-- TAB 1: STATUS OVERVIEW -->
    <div class="tab-pane fade show active" id="statusOverview">
        <div class="status-cards">
            <div class="status-card sc-total">
                <div class="status-card-label">Total Reports</div>
                <div class="status-card-count">@totalNCRs</div>
            </div>
            @foreach (var item in statusOverview.ReportStatusCounts)
            {
                var cardClass = "sc-other";
                var statusVal = item.ReportStatus ?? "No Status";
                if (statusVal == "In Process") cardClass = "sc-inprocess";
                else if (statusVal == "Cleared") cardClass = "sc-cleared";
                else if (statusVal == "Rejected") cardClass = "sc-rejected";
                else if (statusVal.Contains("Partially")) cardClass = "sc-partial";

                <div class="status-card @cardClass drilldown-row" data-stage="@statusVal" data-source="overview" data-type="status">
                    <div class="status-card-label">@statusVal</div>
                    <div class="status-card-count">@item.NCRCount</div>
                </div>
            }
        </div>

        @if (inProcessCount > 0)
        {
            <div class="flow-section">
                <div class="flow-section-title"><i class="fas fa-project-diagram"></i> In Process Breakdown (@inProcessCount NCRs)</div>
                <ul class="flow-tree">
                    @if (notAssignedCount > 0)
                    {
                        <li class="flow-branch">
                            <div class="flow-node fn-notassigned drilldown-row" data-stage="Not Yet Assigned" data-source="overview" data-type="workflow">
                                <span class="flow-node-label">Not Yet Assigned (no workflow started)</span>
                                <div class="flow-node-bar" style="width: @(inProcessCount > 0 ? (notAssignedCount * 100 / inProcessCount) : 0)%;"></div>
                                <span class="flow-node-count">@notAssignedCount</span>
                            </div>
                        </li>
                    }
                    @if (inWorkflowCount > 0)
                    {
                        <li class="flow-branch">
                            <div class="flow-node fn-workflow">
                                <span class="flow-node-label"><b>In Workflow</b></span>
                                <div class="flow-node-bar" style="width: @(inProcessCount > 0 ? (inWorkflowCount * 100 / inProcessCount) : 0)%;"></div>
                                <span class="flow-node-count">@inWorkflowCount</span>
                            </div>
                            <ul class="flow-tree" style="margin-top: 2px;">
                                @foreach (var stage in statusOverview.WorkflowStageCounts.Where(x => x.WorkflowStage != "Not Yet Assigned").OrderBy(x => x.StageStep))
                                {
                                    var nodeClass = "fn-module";
                                    var stageText = stage.WorkflowStage ?? "";
                                    if (stageText.Contains("TAS")) nodeClass = "fn-tas";
                                    else if (stageText.Contains("STRESS")) nodeClass = "fn-stress";
                                    else if (stageText.Contains("CHAIR")) nodeClass = "fn-chair";
                                    else if (stageText.Contains("Rework")) nodeClass = "fn-rework";
                                    else if (stageText.Contains("Marked As Complete")) nodeClass = "fn-complete";
                                    else if (stageText.Contains("Closed")) nodeClass = "fn-closed";

                                    <li class="flow-branch">
                                        <div class="flow-node @nodeClass drilldown-row" data-stage="@stage.WorkflowStage" data-source="overview" data-type="workflow">
                                            <span class="flow-node-label">@stage.WorkflowStage</span>
                                            <div class="flow-node-bar" style="width: @(inWorkflowCount > 0 ? (stage.NCRCount * 100 / inWorkflowCount) : 0)%;"></div>
                                            <span class="flow-node-count">@stage.NCRCount</span>
                                        </div>
                                    </li>
                                }
                            </ul>
                        </li>
                    }
                </ul>
            </div>
        }
    </div>

    <!-- TAB 2: ENGINE DISTRIBUTION -->
    <div class="tab-pane fade" id="engineDist">
        <div class="engine-grid">
            @foreach (var engine in engines)
            {
                var engineStatuses = engineDist.EngineStatusCounts.Where(x => x.Engine == engine).ToList();
                var engineTotal = engineStatuses.Sum(x => x.NCRCount);
                var engineWorkflow = engineDist.EngineWorkflowCounts.Where(x => x.Engine == engine).ToList();

                <div class="engine-card">
                    <div class="engine-card-header">
                        <span><i class="fas fa-cog"></i> @engine</span>
                        <span class="engine-card-total">@engineTotal NCRs</span>
                    </div>
                    <div class="engine-card-body">
                        @foreach (var status in engineStatuses)
                        {
                            var dotClass = "dot-inprocess";
                            var statusText = status.ReportStatus ?? "No Status";
                            if (statusText == "Cleared") dotClass = "dot-cleared";
                            else if (statusText == "Rejected") dotClass = "dot-rejected";
                            else if (statusText.Contains("Partially")) dotClass = "dot-partial";
                            else if (statusText == "No Status") dotClass = "dot-nostatus";

                            <div class="engine-status-row drilldown-row" data-stage="@statusText" data-source="engine" data-engine="@engine" data-type="status">
                                <span class="engine-dot @dotClass"></span>
                                <span class="engine-status-label">@statusText</span>
                                <span class="engine-status-count">@status.NCRCount</span>
                            </div>
                            @if ((statusText == "In Process" || statusText == "To be reached") && engineWorkflow.Any()) //Added
                            @* @if (statusText == "In Process" && engineWorkflow.Any()) *@
                            {
                                @foreach (var wf in engineWorkflow.OrderBy(x => x.StageStep))
                                {
                                    var wfDot = "dot-workflow";
                                    if (wf.WorkflowStage == "Not Yet Assigned") wfDot = "dot-notassigned";

                                    <div class="engine-status-row engine-workflow-indent drilldown-row" data-stage="@wf.WorkflowStage" data-source="engine" data-engine="@engine" data-type="workflow">
                                        <span class="engine-dot @wfDot"></span>
                                        <span class="engine-status-label">@wf.WorkflowStage</span>
                                        <span class="engine-status-count">@wf.NCRCount</span>
                                    </div>
                                }
                            }
                        }
                    </div>
                </div>
            }
        </div>
        @if (!engines.Any())
        {
            <div class="alert alert-info mt-2"><i class="fas fa-info-circle"></i> No engine mapping data available.</div>
        }
    </div>

    <!-- TAB 3: TABLE VIEW -->
    <div class="tab-pane fade" id="tableView">
        @if (Model.ReportData != null && Model.ReportData.Any())
        {
            <div class="table-responsive table-loading-overlay" id="tableWrapper">
                <table id="partEngineReportTable" class="table table-striped table-bordered table-hover" style="width:100%">
                    <thead><tr>@foreach (var header in Model.ColumnHeaders) {
                    <th>@header</th>
                }
</tr></thead>
                <tbody>
                    @foreach (var row in Model.ReportData)
                    {
                        <tr>@foreach (var header in Model.ColumnHeaders) {
                     
                                    <td>@Html.Raw(row[header].Replace(" | ", "<br/>"))</td>
                    }
</tr>
                                        }
                </tbody>
            </table>
        </div>
                }
                else
        {

            <div class="alert alert-info mt-2"><i class="fas fa-info-circle"></i> No data available.</div>
        }
    </div>

    <!-- TAB 4: DUPLICATE DEVIATIONS -->
    <div class="tab-pane fade" id="duplicatesView">
        @if (duplicateDeviations.Any())
        {
            <div class="alert mt-2 py-2" style="font-size:13px; background-color: #eaf4fb; border: 1px solid #b8d9f0; color: #1a5276;">
                @* <i class="fas fa-exclamation-triangle"></i> <b>@duplicateGroupCount duplicate deviation group(s)</b> found. *@
                <i class="fas fa-exclamation-triangle"></i> <b>@duplicateGroupCount duplicate deviation group(s)</b> found — NCRs are grouped as duplicates when they share the same <b>Part Number</b>, <b>Serial Number</b>, <b>Drawing Dimension</b>, and <b>Actual Dimension</b>.
            </div>
            <div class="table-responsive">
                <table id="duplicateDeviationsTable" class="table table-bordered table-hover" style="width:100%">
                    <thead><tr><th>Group</th><th>Part No</th><th>Description</th><th>Serial No</th><th>Drg Zone</th><th>Drawing Dimension</th><th>Actual Dimension</th><th>NCR Reference</th><th>Received Date</th><th>Current Status</th></tr></thead>
                    <tbody>
                        @foreach (var item in duplicateDeviations)
                        {
                            var groupClass = item.DuplicateGroupId % 2 == 0 ? "dup-group-even" : "dup-group-odd";
                            <tr class="@groupClass">
                                <td><span class="dup-count-badge">@item.DuplicateCount</span></td>
                                <td><b>@item.PartNo</b></td>
                                <td>@item.Description</td>
                                <td>@item.SerialNumber</td>
                                <td>@item.DrgZone</td>
                                <td>@item.DrawingDimension</td>
                                <td>@item.ActualDimension</td>
                                <td><a href="/NCR/NCR?NCRGuid=@item.NCRGuid" target="_blank">@item.NCRReference</a></td>
                                <td>@item.ReceivedDate?.ToString("dd-MMM-yyyy")</td>
                                <td>
                                    @{
                                        var dupStatusText = item.CurrentStatus ?? "No Status"; var statusBadge = "status-inprocess";
                                        if (dupStatusText.Contains("Closed")) statusBadge = "status-closed";
                                        else if (dupStatusText.Contains("Marked As Complete")) statusBadge = "status-complete";
                                        else if (dupStatusText.Contains("Forwarded") || dupStatusText.Contains("Fwd")) statusBadge = "status-forwarded";
                                        else if (dupStatusText.Contains("Rework")) statusBadge = "status-rework";
                                    }
                                    <span class="status-badge @statusBadge">@dupStatusText</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {

            <div class="alert alert-success mt-2"><i class="fas fa-check-circle"></i> No duplicate deviations found.</div>
        }
    </div>
</div>

<!-- Drill-down Modal -->
<div class="modal fade" id="drilldownModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header py-2" style="background:#3a5a8c; color:#fff;">
                <h6 class="modal-title" id="drilldownModalTitle">NCR List</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-2">
                <div id="drilldownLoading" class="text-center py-4" style="display:none;">
                    <div class="spinner-border spinner-border-sm text-primary"></div> Loading...
                </div>
                <div id="drilldownContent"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var tableInitialized = false;
            $('button[data-bs-target="#tableView"]').on('shown.bs.tab', function () {
                if (!tableInitialized) {
                    $('#partEngineReportTable').DataTable({ paging: true, dom: 'Bfrtip', buttons: ['excel'], scrollX: true, fixedColumns: { left: 2 },
                        initComplete: function () { $('#tableWrapper').removeClass('table-loading-overlay'); }
                    });
                    tableInitialized = true;
                }
            });

            var dupInitialized = false;
            $('button[data-bs-target="#duplicatesView"]').on('shown.bs.tab', function () {
                if (!dupInitialized && $('#duplicateDeviationsTable').length > 0) {
                    $('#duplicateDeviationsTable').DataTable({ paging: false, dom: 'Bfrtip', buttons: ['excel'], ordering: true, order: [[0, 'asc']] });
                    dupInitialized = true;
                }
            });

            // Drill-down handler
            $(document).on('click', '.drilldown-row', function () {
                var stage = $(this).data('stage');
                var source = $(this).data('source');
                var engine = $(this).data('engine') || '';
                var type = $(this).data('type') || 'workflow';

                $('#drilldownModalTitle').text(stage + (engine ? ' — ' + engine : ''));
                $('#drilldownLoading').show();
                $('#drilldownContent').html('');
                var modal = new bootstrap.Modal(document.getElementById('drilldownModal'));
                modal.show();

                $.ajax({
                    url: '/NCR/GetNCRsByWorkflowStage',
                    data: { stage: stage, source: source, engine: engine, type: type },
                    success: function (response) {
                        $('#drilldownLoading').hide();
                        if (response.success && response.data && response.data.length > 0) {
                            var html = '<table class="table table-sm table-bordered table-hover" style="font-size:12px;">';
                            html += '<thead><tr style="background:#f0f3f7;"><th>NCR Ref</th><th>Part No</th><th>Description</th><th>Module</th><th>Received Date</th><th>Status</th></tr></thead><tbody>';

                            response.data.forEach(function (ncr) {
                                var refNo = ncr.referenceNumber || ncr.ReferenceNumber || '-';
                                var partNo = ncr.draw_part_no || ncr.Draw_part_no || '-';
                                var desc = ncr.partDescription || ncr.PartDescription || '-';
                                var modName = ncr.moduleName || ncr.ModuleName || '-';
                                var recDate = ncr.receivedDate || ncr.ReceivedDate || '';
                                var wfStage = ncr.workflowStage || ncr.WorkflowStage || '-';
                                var guid = ncr.ncrGuid || ncr.NCRGuid || '';

                                if (recDate) {
                                    var d = new Date(recDate);
                                    recDate = d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
                                }

                                html += '<tr>';
                                html += '<td>' + refNo + '</td>';
                                html += '<td>' + partNo + '</td><td>' + desc + '</td><td>' + modName + '</td><td>' + recDate + '</td>';
                                html += '<td><span class="badge bg-secondary" style="font-size:11px;">' + wfStage + '</span></td>';
                                html += '</tr>';
                            });

                            html += '</tbody></table>';
                            html += '<div class="text-muted" style="font-size:11px;">Showing ' + response.data.length + ' NCR(s)</div>';
                            $('#drilldownContent').html(html);
                        } else {
                            $('#drilldownContent').html('<div class="alert alert-info py-2">No NCRs found.</div>');
                        }
                    },
                    error: function () {
                        $('#drilldownLoading').hide();
                        $('#drilldownContent').html('<div class="alert alert-danger py-2">Error loading data.</div>');
                    }
                });
            });
        });
    </script>
}
