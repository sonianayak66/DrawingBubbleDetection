 @model MPCRS.ViewModels.AssignedNCRvm
@using MPCRS.ViewModels;
@using MPCRS.Utilities;
@using System.Security.Claims

@{
	ViewData["Title"] = "NCR View - Read Only";
	var NCR_Status = Masters.GetMaster_General_SameValueAsText("NCR_Report_Status");
	var userguid = ViewBag.UserGuid;
	var userOldDBKey = ViewBag.userDBKey;
	bool closeNCR = Model.AssignmentData.CloseNCR == 1;
	var UserGuid = ViewBag.UserGuid;
	bool MarkedForRework = Model.NcrItems.Any(x => x.Rework_Status == 1 || x.Rework_Status == 2);
	// Helper function to check if item is marked for rework at ANY stage
	Func<NonConformanceReport_ItemVM, bool> IsMarkedForRework = (item) =>
		item.Module_ReworkType == 1 || item.TAS_ReworkType == 1 ||
		item.STRESS_ReworkType == 1 || item.PO_ReworkType == 1;

	// Helper function to check if item is marked for trial assembly at ANY stage
	Func<NonConformanceReport_ItemVM, bool> IsMarkedForTrialAssembly = (item) =>
		item.Module_ReworkType == 2 || item.TAS_ReworkType == 2 ||
		item.STRESS_ReworkType == 2 || item.PO_ReworkType == 2;
}

<style>
	/* Clean Component Details Table */
	#ncrDetailsTbl {
		border: 1px solid #dee2e6;
		background-color: #fff;
		font-size: 12px;
		margin-bottom: 10px;
	}

		#ncrDetailsTbl td {
			padding: 5px 7px !important;
			border: 1px solid #dee2e6;
			vertical-align: middle;
			background-color: #fff;
		}

			#ncrDetailsTbl td:nth-child(odd) {
				font-weight: 600;
				color: #495057;
				width: 18%;
			}

			#ncrDetailsTbl td:nth-child(even) {
				color: #212529;
				width: 32%;
			}

		/* Header row */
		#ncrDetailsTbl tr:first-child td:first-child,
		#ncrDetailsTbl tr:first-child td:nth-child(3) {
			font-weight: 700;
			color: #212529;
		}

	.details-container {
		background-color: #fff;
		border: 1px solid #dee2e6;
		border-radius: 4px;
		padding: 0;
		margin-bottom: 20px;
	}

	/* Notes section */
	.notes-section {
		background-color: #f8f9fa;
		padding: 15px;
		border-radius: 4px;
		border: 1px solid #dee2e6;
	}

	.notes-title {
		font-weight: 600;
		color: #212529;
		margin-bottom: 12px;
		font-size: 15px;
	}

	.note-item {
		display: flex;
		margin-bottom: 10px;
		align-items: flex-start;
	}

	.note-number {
		font-weight: 600;
		color: #495057;
		margin-right: 8px;
		min-width: 20px;
	}

	.note-text {
		color: #495057;
		line-height: 1.6;
	}

	#itemsTbl label {
		padding-left: 2px;
	}
</style>


<div class="row">
	<div class="col-4">
		@{
			if (closeNCR != true)
			{
				<h4>Non-Conformance Report</h4>
			}
			else
			{
				<h4>NCR Closed </h4>
			}
		}
	</div>
</div>
<div class="row">
	<div class="col-12 pull-right no-print" id="buttons-area">
		<a class="btn btn-secondary btn-sm float-end" href="/NCR/ReadOnlyNCRList">Back</a>
		<input type="button" class="btn btn-primary btn-sm float-end" style="margin-right:10px;" onclick="printNCRReport('@Model.AssignmentData.NCRGUID')" value="Print Report" />
	</div>
</div>

<hr class="no-print" />
<div class="row">
	<div class="col-8">
		<div class="details-container">
			<table class="table table-bordered table-condensed" id="ncrDetailsTbl">
				<tbody>
					<tr>
						<td colspan="2"><strong>Component Details:</strong></td>
						<td><strong>Material</strong></td>
						<td>@Model.AssignmentData.Raw_material_Name</td>
					</tr>
					<tr>
						<td><strong>Drawing No</strong></td>
						<td>@Model.AssignmentData.Draw_part_no</td>
						<td><strong>JobCard/Contract No</strong></td>
						<td>@Model.AssignmentData.JobCard</td>
					</tr>
					<tr>
						<td><strong>Revision</strong></td>
						<td>@Model.AssignmentData.Revision</td>
						<td><strong>Contractor</strong></td>
						<td>@Model.AssignmentData.ReceivedFromString</td>
					</tr>
					<tr>
						<td><strong>Nomenclature</strong></td>
						<td>@Model.AssignmentData.PartDescription</td>
						<td><strong>Stage/Final</strong></td>
						<td>@Model.AssignmentData.Stage_Final</td>
					</tr>
					<tr>
						<td><strong>Serial Number</strong></td>
						<td>@Model.AssignmentData.SerialNumber</td>
						<td><strong>Inspection Report No</strong></td>
						<td>@Model.AssignmentData.Inspection_Report_No</td>
					</tr>
					<tr>
						<td><strong>Quantity</strong></td>
						<td>@Model.AssignmentData.Qty</td>
						<td><strong>NCR No</strong></td>
						<td>@Model.AssignmentData.ReferenceNumber</td>
					</tr>
					<tr>
						<td><strong>DAR No.</strong></td>
						<td>@Model.AssignmentData.DARno</td>
						<td><strong>Module</strong></td>
						<td>@Model.AssignmentData.ModuleName</td>
					</tr>
				</tbody>
			</table>
		</div>
	</div>

	<div class="col-4 no-print">
		<h5>Attachments</h5>
		@{
			attachmentData attData = new attachmentData();
			attData.sourceAttachTable = "NonConformanceReport";
			attData.sourceAttachTableKey = Model.AssignmentData.NcrID;
			attData.deleteAccess = false;
			var attachmentData = MPGlobals.GetAttachmentsData(attData.sourceAttachTable, attData.sourceAttachTableKey);

			if (attachmentData.Count > 3)
			{
				<details>
					<summary>Show attachments</summary>
					<div id="Attachment-display" class="Attachment-display">
						<partial name="../Attachment/GetAttachments" model="@attData">
					</div>
				</details>
			}
			else
			{
				<div id="Attachment-display" class="Attachment-display">
					<partial name="../Attachment/GetAttachments" model="@attData">
				</div>
			}
		}

		<div class="notes-section">
			<p class="notes-title">Notes:</p>
			<div class="note-item">
				<span class="note-number">1.</span>
				<span class="note-text">
					<span style="display: inline-block; background-color: #EE4B2B; height: 14px; width: 14px; border: 1px solid #000; margin-right: 8px; vertical-align: middle;"></span>
					Colored rows indicate marked for rework
				</span>
			</div>
			<div class="note-item">
				<span class="note-number">2.</span>
				<span class="note-text">
					<span style="display: inline-block; background-color:#BF40BF; height: 14px; width: 14px; border: 1px solid #000; margin-right: 8px; vertical-align: middle;"></span>
					Colored rows indicate marked for Trial Assembly
				</span>
			</div>
		</div>
	</div>
</div>

<hr />
<div class="mb-3">
	<table class="table table-bordered" id="itemsTbl">
		<thead class="no-word-break">
			<tr>
				<th>SlNo.</th>
				<th style="width:5%">Serial no in Insp Rep</th>
				<th style="width:5%">Drg Zone</th>
				<th style="width:5%">Serial Number</th>
				<th style="width:10%">Drawing Dimension</th>
				<th style="width:10%">Actual Dimension</th>
				<th style="width:10%">Reason/Analysis</th>
				@if (MarkedForRework && Model.NcrItems.Any(x => !String.IsNullOrEmpty(x.Rework_Dimension)))
				{
					<th style="width:10%">Rework Dimension</th>
				}
				<th style="width:10%">Effect of Deviation on Assembly Aero-thermal Design Performance</th>
				<th style="width:10%">Effect of Deviation on Assembly</th>
				<th style="width:10%">Effect of Deviation on Structural Integrity</th>
				<th style="width:10%">CHAIR Remarks</th>
				<th style="width:10%">Remarks (PO)</th>
			</tr>
		</thead>
		<tbody id="tblbody">
			@{
				foreach (var item in Model.NcrItems)
				{
					// <tr style="color: @(item.Rework_Status == 1 ? "#EE4B2B" : item.Rework_Status == 2 ? "#BF40BF" : "black")">
					<tr style="color: @(item.Module_ReworkType == 1 || item.TAS_ReworkType == 1 || item.STRESS_ReworkType == 1 || item.PO_ReworkType == 1 ? "#EE4B2B" :
							 	   item.Module_ReworkType == 2 || item.TAS_ReworkType == 2 || item.STRESS_ReworkType == 2 || item.PO_ReworkType == 2 ? "#BF40BF" : "black")">
						<td style="padding:10px">@item.SlNo</td>
						<td style="padding:10px">@item.Serial_No_in_Inspection_Rep</td>
						<td style="padding:10px">@item.DrgZone</td>
						<td style="padding:10px">@item.SerialNumber</td>
						<td style="padding:10px">@Html.Raw(item.DrawingDimension)</td>
						<td style="padding:10px">@Html.Raw(item.ActualDimension)</td>
						<td style="padding:10px">@Html.Raw(item.Deviation_Reason_Analysis)</td>
						@if (MarkedForRework && Model.NcrItems.Any(x => !String.IsNullOrEmpty(x.Rework_Dimension)))
						{
							<td style="padding:10px">@Html.Raw(item.Rework_Dimension)</td>
						}

						@* Module Remarks - Read Only *@
						<td>
							@{
								if (item.Module_Remarks != null)
								{
									if (item.Module_ReworkType == 1)
									{
										<i>Marked for rework</i>
									}
									else if (item.Module_ReworkType == 2)
									{
										<i>Marked for Trial Assembly</i>
									}
									<br />
									<label>@Html.Raw(item.Module_Remarks)</label>
								}
								if (!string.IsNullOrEmpty(item.Module_Rework_Remarks))
								{
									<br />
									if (IsMarkedForRework(item))
									{
										<i>Rework Remark:</i>
									}
									else if (IsMarkedForTrialAssembly(item))
									{
										<i>Trial Assembly Remark:</i>
									}
									<br />
									<label>@Html.Raw(item.Module_Rework_Remarks)</label>
								}
							}
						</td>

						@* TAS Remarks - Read Only *@
						<td>
							@{
								if (item.TAS_Remarks != null)
								{
									if (item.TAS_ReworkType == 1)
									{
										<i>Marked for rework</i>
									}
									else if (item.TAS_ReworkType == 2)
									{
										<i>Marked for Trial Assembly</i>
									}
									<br />
									<label>@Html.Raw(item.TAS_Remarks)</label>
								}
								if (!string.IsNullOrEmpty(item.TAS_Rework_Remarks))
								{
									<br />
									if (IsMarkedForRework(item))
									{
										<i>Rework Remark:</i>
									}
									else if (IsMarkedForTrialAssembly(item))
									{
										<i>Trial Assembly Remark:</i>
									}
									<br />
									<label>@Html.Raw(item.TAS_Rework_Remarks)</label>
								}
							}
						</td>

						@* STRESS Remarks - Read Only *@
						<td>
							@{
								if (item.Stress_Remarks != null)
								{
									if (item.STRESS_ReworkType == 1)
									{
										<i>Marked for rework</i>
									}
									else if (item.STRESS_ReworkType == 2)
									{
										<i>Marked for Trial Assembly</i>
									}
									<br />
									<label>@Html.Raw(item.Stress_Remarks)</label>
								}
								if (!string.IsNullOrEmpty(item.STRESS_Rework_Remarks))
								{
									<br />
									if (IsMarkedForRework(item))
									{
										<i>Rework Remark:</i>
									}
									else if (IsMarkedForTrialAssembly(item))
									{
										<i>Trial Assembly Remark:</i>
									}
									<br />
									<label>@Html.Raw(item.STRESS_Rework_Remarks)</label>
								}
							}
						</td>

						@* CHAIR Remarks - Read Only *@
						<td>
							@{
								if (item.Chair_Remarks != null)
								{
									 
									<label>@Html.Raw(item.Chair_Remarks)</label>
								}
								if (!string.IsNullOrEmpty(item.CHAIR_Rework_Remarks) && (item.Rework_Status == 1 || item.Rework_Status == 2))
								{
									<br /> 
									<label>@Html.Raw(item.CHAIR_Rework_Remarks)</label>
								}
							}
						</td>

						@* PO Remarks - Read Only *@
						<td>
							@{
								if (item.STFE_PO_Remark != null)
								{
									<label>@Html.Raw(item.STFE_PO_Remark)</label>
								}
							}
						</td>
					</tr>
				}
			}
		</tbody>
	</table>
</div>

@* Activity Logs *@
<hr />
@{
	if (Model.workFlowLogs.Count > 0)
	{
		<div class="col-12 no-print">
			<h5>Activity Log</h5>
			<details>
				<summary>Show Logs</summary>
				<table class="table table-bordered table-condensed" id="WorkflowLogTbl">
					<thead>
						<tr>
							<th>Time stamp</th>
							<th>User</th>
							<th>Status</th>
							<th>Remarks</th>
							<th>Status Description</th>
						</tr>
					</thead>
					<tbody>
						@{
							foreach (var log in Model.workFlowLogs.OrderBy(X => X.UpdatedOn))
							{
								<tr>
									<td data-date="@log.UpdatedOn">@MPGlobals.GetFormattedDateTime(log.UpdatedOn)</td>
									<td>@log.UpdatedBy</td>
									<td>@log.Status</td>
									<td>@Html.Raw(log.Remarks)</td>
									<td>@Html.Raw(log.Status_Verbose)</td>
								</tr>
							}
						}
					</tbody>
				</table>
			</details>
		</div>
	}
}

@section Scripts {
	<script src="~/js/print.min.js"></script>
	<script src="~/mpi/ncr.js" asp-append-version="true"></script>
	<script>
		$(document).ready(function () {
			$.fn.dataTable.ext.type.order['datetime-custom-pre'] = function (d) {
				return new Date(d).getTime();
			};

			$('#WorkflowLogTbl').DataTable({
				paging: false,
				"columnDefs": [
					{
						"targets": 0,
						"type": 'datetime-custom'
					}
				]
			});

			$('#itemsTbl').DataTable({
				paging: false,
				ordering: false
			});
		});

		// Print NCR Report function
		function printNCRReport(ncrGuid) {
			window.open('/NCR/PrintNCRModule?NCRGuid=' + ncrGuid, '_blank');
		}
	</script>
}