@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    <input type="hidden" value="@ViewBag.accessExpired" id="accessStatus" />
    if (ViewBag.accessExpired == "true")
    {
        <div class="card">
            <div class="card-body text-center">
                <h3>Validity of this page has expired. Please contact STFE project office </h3>
                <hr>
                <a class="btn btn-primary" href="/Auth/Index">Back</a>
            </div>
        </div>
    }
}


@section scripts{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $(document).ready(function () {
            document.getElementById("navbarTop").innerHTML = "";
            if (document.getElementById("accessStatus").value != "true") {
                window.location.reload();
            }

        });
    </script>
}
