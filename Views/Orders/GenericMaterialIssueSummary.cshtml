@model List<MPCRS.ViewModels.GenericMaterialIssueSummary_VM>

@{
	Layout = null;
}
<style>
	td {
		padding-top: 8px !important;
		padding-bottom: 8px !important;
	}

	.partcol {
		width: 40% !important;
		padding-left: 10px !important;
	}

	.qtyCols {
		width: 15% !important;
		text-align: right;
		padding-right: 15px !important;
	}

</style>


<table class="table table-bordered table-hover" id="genericMaterialIssueSummaryTbl">
	<thead>
		<tr>
			<th class="partcol">PartName</th>
			<th class="qtyCols">Total Procured Qty</th>
			<th class="qtyCols">Issued Qty</th>
			<th class="qtyCols">Available Qty</th>
		</tr>
	</thead>
	<tbody>
		@{
			foreach(var item in Model)
			{
				<tr>
					<td class="partcol">
						<b>@item.Draw_part_no</b>-@item.Description
						@{
							if (item.IssuedQty > 0)
							{
								<a style="cursor:pointer" id="icon_Open-@item.Engine_Part_Dbkey" class="float-end" onclick="GetGenericMaterialIssue_Vendorwise(@item.Engine_Part_Dbkey, 'Open','@ViewBag.OrderType')">
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chevron-double-down" viewBox="0 0 16 16">
										<path fill-rule="evenodd" d="M1.646 6.646a.5.5 0 0 1 .708 0L8 12.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708" />
										<path fill-rule="evenodd" d="M1.646 2.646a.5.5 0 0 1 .708 0L8 8.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708" />
									</svg>
								</a>
								<a style="cursor:pointer; display:none" id="icon_Close-@item.Engine_Part_Dbkey" class="float-end" onclick="GetGenericMaterialIssue_Vendorwise(@item.Engine_Part_Dbkey, 'Close','@ViewBag.OrderType')">
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chevron-double-up" viewBox="0 0 16 16">
										<path fill-rule="evenodd" d="M7.646 2.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1-.708.708L8 3.707 2.354 9.354a.5.5 0 1 1-.708-.708z" />
										<path fill-rule="evenodd" d="M7.646 6.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1-.708.708L8 7.707l-5.646 5.647a.5.5 0 0 1-.708-.708z" />
									</svg>
								</a>
							}
						}
					</td>
					<td style="padding-right:15px; text-align:right;">@item.TotalQty</td>
					<td style="padding-right:15px; text-align:right; cursor:pointer;" onclick="GenericMaterialIssue_Split('@ViewBag.OrderType',@item.Engine_Part_Dbkey)"><span style="text-decoration:underline; color:darkblue"> @item.IssuedQty </span></td>
					<td style="padding-right:15px; text-align:right;">@item.RemaningQty</td>
				</tr>
				<tr style="display:none; padding:0px!important" id="Part-@item.Engine_Part_Dbkey">
					<td style="padding:0px!important" colspan="4">dfh</td>
				</tr>
			}
		}
	</tbody>
</table> 