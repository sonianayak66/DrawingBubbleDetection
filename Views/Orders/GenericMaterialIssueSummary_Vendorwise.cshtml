@model List<MPCRS.ViewModels.GenericMaterialIssueSummary_Vendorwise_VM>
@{
    Layout = null;

    if (Model.Count > 0)
    {
        <table class="table  table-bordered table-hover table-condensed table-primary p-0 m-0">
            <tbody>
                @{
                    var issueDetails = Model.First();
                    var totalQty = issueDetails.TotalQty;
                    var remainingQty = 0;
                    foreach (var item in Model)
                    {
                        remainingQty = totalQty - item.IssuedQty;
                        <tr>
                            <td class="partcol" style="min-width:350px!important"><b>@item.Vendor_Name</b> </td>
                            <td class="qtyCols">@totalQty</td>
                            <td class="qtyCols">@item.IssuedQty</td>
                            <td class="qtyCols">@remainingQty</td>
                        </tr>
                        totalQty = totalQty - item.IssuedQty;
                    }
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="col-12 text-center p-3">
            <h4>Order information unavailable</h4>
        </div>
    }
}
