			</div>*@
					@* <div class="tab-pane fade show" id="tab-detail" role="tabpanel" aria-labelledby="Detail-list-tab">*@
					<table class="table table-bordered  table-condensed table-sm" id="grneric-order-receipt-display" style="width:100%;border:1px!important;">
						<thead>
							<tr>
								<th>Receipt No/Date</th>
								<th>Part</th>
								<th>Vendor</th>
								<th>Vendor Drg. #</th>
								<th>Batch No & Heat No</th>
								<th>Qty Received</th>
								<th>Attachments</th>
								<th></th>
							</tr>
						</thead>
						<tbody id="casting_split_tbl_bdy">
							@{
								foreach (var item in Model.receiptSplitVMs)
								{
									<tr>
										<td>
											<b>@item.ReceiptNumber</b>
											<p class="p-0 m-0">@MPGlobals.GetFormattedDate(item.ReceiptDate)</p>
										</td>
										<td> 
										<b>  @item.PartName </b> 
										@((string.IsNullOrEmpty(item.Revision)) ? "" : " (Rev: " + item.Revision + ")") </td>
										<td><p >@item.Vendor_Name</p></td>
										<td>@item.VendorDrawingNo</td>
										<td><p>@item.BatchNumber</p> @item.HeatNumber</td>
										<td>
											<partial name="../Casting/CastingQtySplit.cshtml" model="@item.Id.ToString()">
												@{
													if (!string.IsNullOrEmpty(item.Remarks))
													{
														<p class="p-0 m-0"> <b>Remarks: </b> @item.Remarks</p>
													}
												}
										</td>
										<td>
											@{
												var data = new MPCRS.ViewModels.DetailedCastingDataVM();
												data.EnginePartDbkey = item.EnginePartDbkey;
												data.SplitId = item.Id;
												 <partial name="../Casting/CastingSplitDocChecklist.cshtml" model="data" />
											}
										</td>
										<td>
											@{
												if ((CastingWriteReceipts && ViewBag.Ordertype == "Casting") || (PyroWriteReceipts && ViewBag.Ordertype == "Pyro") || (ForgingWriteReceipts && ViewBag.Ordertype == "Forging"))
												{
													<i title="Edit Receipt" class="text-primary uil uil-edit fs-1" style="cursor:pointer" onclick="GetReceiptSplitModel(@item.CastingDbkey,@item.Id)"></i>
												}

												if ((CastingDeleteAccess && ViewBag.Ordertype == "Casting") || (PyroDeleteAccess && ViewBag.Ordertype == "Pyro") || (ForgingDeleteAccess && ViewBag.Ordertype == "Forging"))
												{
													<p  title="Delete Receipt" class="p-0 m-0"><i class="text-warning uil uil-trash fs-1" style="cursor:pointer" onclick="DeleteOrderComponents(this,@item.Id,'CastingReceiptsItemSplit')"></i></p>
												}
												if (receiptCommnetAccess)
												{
													<i title="Add Remarks" style="cursor:pointer" onclick="getCommentSection(@Model.castingDetailViewModel.CastingDbkey,@item.Id)" class="fas fa-comment-alt"></i>
												}
											}
										</td>
									</tr>

								}
							}
						</tbody>

					</table>
					@* </div>
			</div>*@
				</div>
			</div>
		}
	}

</div>


