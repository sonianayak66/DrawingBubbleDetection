@model List<MPCRS.ViewModels.OrderModuleUserMapping>
@{
    ViewData["Title"] = "Order Module Users";
}

<div class="row">
    <div class="col-md-10">
        <h4>Casting Orders - Access Management</h4>
    </div>
    <div class="col-md-2">
        <a class="btn btn-secondary btn-sm" href="/Orders/OrdersList?Ordertype=@ViewBag.Ordertype">Back</a>
    </div>
   
</div>
<hr />
<div class="row">
    <table class="table table-sm" id="OrderUsersMaps">
        <thead>
            <tr>
                <th>User</th>
                <th>Order Type</th>
                <th>MMG Order No.</th>
                <th>Desc</th>
                <th>Updated On</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @{
                foreach(var mappingdata in Model){
                        <tr>
                            <td>@mappingdata.UserName</td>
                            <th>@mappingdata.OrderType</th>
                            <td><a href="/Orders/OrderDetail?OrderType=@mappingdata.OrderType&Id=@mappingdata.castingGUID" target="_blank">@mappingdata.MMGOrderNumber</a></td>
                            <td>@mappingdata.DemandDesc</td> 
                            <td>@mappingdata.UpdateOn</td>
                            <td><a class="fa far fa-trash-alt text-danger fs-1" style="cursor:pointer" onclick="RemoveAccess(@mappingdata.Id)"></a></td>
                        </tr>
                }
            }
        </tbody>
    </table>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
 
    <script>
        $(document).ready(function () {

            $('#OrderUsersMaps').DataTable({
                rowGroup: {
                    dataSrc: 0 // Index of the "User" column
                },
                columnDefs: [
                    { targets: [0], visible: false }, // Hide the "User" column
                    { targets: [5], orderable: false } // Disable ordering for the delete icon column
                ],
                order: [[0, 'asc']],
                paging: false, // Disable pagination
                info: false,   // Remove "Showing x of y entries" info
            });
           
        });

        function RemoveAccess(Id) {
            bootbox.confirm({
                message: "Are you sure you want to remove this access?",
                buttons: {
                    confirm: {
                        label: 'Yes',
                        className: 'btn-success'
                    },
                    cancel: {
                        label: 'No',
                        className: 'btn-danger'
                    }
                },
                callback: function (result) {
                    if (result) {
                        $.ajax({
                            url: '/Orders/RemoveOrderModuleUserMapping', // Replace ControllerName with your actual controller
                            type: 'POST',
                            data: { id: Id }, // Pass the id to the server
                            success: function (response) {
                                if (response.success) {
                                    bootbox.alert("Removed Successfully", function () {
                                        location.reload();
                                    });
                                } else {
                                    alert('Failed to delete. Please try again.');
                                }
                            },
                            error: function () {
                                alert('An error occurred. Please try again.');
                            }
                        });
                    }
                }
            });
        

        }
    </script>

}