@model List<MPCRS.ViewModels.CastingOrderSummaryVM>
@{
    Layout = null;

    if(Model.Count > 0)
    {
        <table class="table  table-bordered table-hover table-condensed table-primary p-0 m-0">
            <tbody>
                @{
                    foreach (var item in Model.OrderBy(x => x.Draw_part_no))
                    {
                        <tr>
                            <td class="partcol" style="min-width:250px!important"><b>@item.Vendor_Name</b> </td>
                            <td class="qtyCols">-</td>
                            <td class="qtyCols" >@item.OrderQty</td>
                            <td class="qtyCols" >@item.TotalRecievedQty</td>
                            <td class="qtyCols" >@item.AcceptedQty</td>
                            <td class="qtyCols" >@item.RejectedQty</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="col-12 text-center p-3">
            <h4>Order information unavailable</h4>
       </div> 
    }
}
 


