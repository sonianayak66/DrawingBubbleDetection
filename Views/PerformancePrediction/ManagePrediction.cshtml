@model MPCRS.ViewModels.PerformancePredictionData
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    Layout = null;
}

<form method="post" asp-controller="ACSN" id="ACSN" asp-action="ManageItem" class="needs-validation" novalidate="novalidate">
    <div class="col-md-6">
        <h3>Engine Performance Predection</h3>
    </div>
    <input type="hidden" asp-for="predictionKey" />
    <input type="hidden" asp-for="predectionGUID" />
    <div class="col-12 offset-1">

        <div class="form-group row"> 
            <div class="col-8">
                <div class="form-floating mb-3">
                    <input class="form-control form-control-sm" asp-for="Title" placeholder="AA" />
                    <label asp-for="Title"></label>
                </div>
            </div>
        </div>

        <div class="form-group row">
            <div class="col-8">
                <div class="form-floating mb-3">
                    <input class="form-control form-control-sm" asp-for="Description" placeholder="AA" />
                    <label asp-for="Description"></label>
                </div>
            </div>
        </div>

        <div class="form-group row">
            <div class="col-8">
                <div class="form-floating mb-3">
                    <input type="file" class="form-control form-control-sm" asp-for="inputCSV" placeholder="AA" />
                    <label asp-for="inputCSV"></label>
                </div>
            </div>
        </div>

     
        <div class="mt-3">
            <button type="button" onclick="SavePredictionRequest()" class="btn btn-primary">Run Predection</button>
           @* <a class="btn btn-secondary" asp-action="Index">Back</a>*@
        </div>

    </div>
</form>