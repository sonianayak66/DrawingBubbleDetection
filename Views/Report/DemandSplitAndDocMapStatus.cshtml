<table class="table table-sm table-bordered" style="width:100%" id="demandstatustbl">
    <thead>
        <tr>
            @*<th>Project</th>*@
            <th>Demand No</th>
            <th>MMG No</th>
            <th>Item Type</th>
            <th>Receipt No</th>
            <th>Receipt Date</th>
            <th>Material</th>
            <th>Receipt Qty(A)</th>
            <th>Sum of Split Qty(B)</th>
            <th>Abs(A-B)</th>
            <th>Split Availability</th>
            <th>Doc Availability</th>
            <th>Doc Mapped</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @{
            foreach (var item in Model.demandItemQtyStatus)
            {
                <tr>
                    @*<td>@item.Project</td>*@
                    <td>@item.Demand_No</td>
                    <td>@item.MMG_File_No</td>
                    <td>@item.Item_Type</td>
                    <td>@item.Receipt_No</td>
                    <td>@MPGlobals.GetFormattedDate(@item.Receipt_Date)</td>
                    <td>@item.Item</td>
                    <td>@item.Receiving_inventory</td>
                    <td>@item.SumOfSplitQty</td>
                    <td>@item.QtyVariance</td>
                    <td>@item.SplitStatus</td>
                    <td>@item.DocAvaililty</td>
                    <td>@item.DocumentStatus</td>
                    <td>
                        @{
                            if (@item.Receipt_dbkey != null)
                            {
                                <button class="btn btn-sm btn-success" onclick="DemandReceiptDocumentReMapping(@item.Receipt_dbkey)">Map</button>
                            }
                        }
                    </td>
                </tr>
            }
        }
    </tbody>
</table>


@section Scripts {
    <script src="~/mpi/common.js"></script>
    <script>

        $(document).ready(function () {
            $('#demandstatustbl').DataTable({
                scrollY: 510,
                //data: RawmaterialsDataList,
                responsive: true,
                paging: false,

                dom: 'Bfrtip',
                buttons: [{
                    extend: 'excel',
                    title: 'Demand Data Entry Status',
                    exportOptions: {
                        columns: [0, 1, 2, 3, 4, 5, 6, 7, 8] //Your Colume value those you want
                    }
                }],

            });
        });


    </script>
}
