@model MPCRS.ViewModels.DemandEntryStatusModel
@using MPCRS.Utilities
@{
    ViewBag.Title = "InventoryReportDetail";
}
<style>

    table td {
        word-wrap: break-word;
        max-width: 400px;
    }

    #demandstatustbl td {
        white-space: inherit;
    }

</style>
<div class="page-header">
    <div class="col-12">
        <div class="row">
            <div class="col-md-10">
                <h4>Demand Data Entry Status</h4>
            </div>
            <div class="col-md-2 text-end">
                <a href="/Report/ProcurementReports" style="margin-left: 4px;" class="btn btn-secondary  btn-smaller float-end">Back</a>
            </div>
        </div>
    </div>
</div>

