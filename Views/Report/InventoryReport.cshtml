@{
    ViewBag.Title = "RawmaterialsInventory";
   // Layout = "~/Views/Shared/_LayoutPage.cshtml";
}
<style>
    #InventoryReportTable td {
        white-space: nowrap;
    }

    td {
        padding: 2px !important;
        font-size: small !important;
    }

    th {
        font-size: small !important;
    }

    body {
        font-size: small;
        background-color: white;
    }

    /* Center-align the buttons */
    .dataTables_wrapper .dataTables_filter {
        float: left;
    }

    .dataTables_wrapper .dataTables_length, .dataTables_wrapper .dataTables_filter, .dataTables_wrapper .dataTables_info, .dataTables_wrapper .dataTables_paginate {
        float: right;
    }

    /* Add margin between search box and buttons */
    .dataTables_wrapper .dataTables_filter {
        margin-right: 20px;
    }

    .table {
        --phoenix-table-striped-bg: white;
    }


    .buttons-html5 {
        padding: 0.25rem 0.5rem; /* Adjust padding to make the button smaller */
        font-size: 0.675rem; /* Adjust font size to make the text smaller */
        line-height: 1.5;
    }

    /* Custom styles for smaller paging dropdown */

    .dataTables_length select {
        padding: 0.225rem 0.35rem; /* Adjust padding to make the dropdown smaller */
        font-size: 0.65rem; /* Adjust font size to make the text in the dropdown smaller */
    }

    .form-control-sm {
        min-height: calc(1.39em + 0.65rem + 2px);
        padding: 0.175rem 0.35rem;
        font-size: 0.6rem;
        border-radius: 0.375rem;
    }

    .buttons-excel, .buttons-html5, .btn-smaller {
        padding: 0.25rem 0.5rem; /* Adjust padding to make the button smaller */
        font-size: 0.675rem; /* Adjust font size to make the text smaller */
        line-height: 1.5; /* Adjust line height for proper text alignment */
    }

    .content {
        min-height: 100vh;
        padding: calc(var(--phoenix-navbar-top-height) + 0.5rem) 1.5rem 6.375rem 1.5rem;
        /* padding-bottom: 6rem; */
    }

    #InventoryReportTable td:nth-child(1),
    #InventoryReportTable th:nth-child(1) {
        font-weight: bold;
    }

    .dt-right {
        text-align: right;
    }
</style>


<div class="page-header">
    <div class="col-12">
        <div class="row">
            <div class="col-md-10">
                <h4>Raw-Material Inventory</h4>
            </div>
            <div class="col-md-2 text-end">
                <a href="/Report/ProcurementReports" style="margin-left: 4px;" class="btn btn-secondary  btn-smaller float-end">Back</a>
            </div>
        </div>
    </div>
</div>
<hr />
<div class="col-md-12 col-sm-12 col-lg-12">
    <table id="InventoryReportTable" class="table table-hover table-bordered " style="width:100%">
        <thead>
            <tr>
                <th></th>
                <th>Material Name</th>
                @* <th>Material Type</th> *@
                <th>UOM</th>
             @*   <th>Outer Dia</th>
                <th>Thickness</th>*@
               @* <th>Height</th>*@
                <th>Total Received</th>
                <th>Total Issued</th>
                <th>Balance</th>
                @* <th></th> *@
            </tr>
        </thead>
    </table>
</div>


@section Scripts {

    <script>

        $(document).ready(function () {
            GetRawMaterialMaster();
        });

        var dataTable;
        function GetRawMaterialMaster() {

            try {
                dataTable.destroy();
            } catch (e) {
            }

            dataTable = $("#InventoryReportTable").DataTable({
                "ajax": {
                    "url": "/Report/GetRawmaterialsInventory?ForConsolidatedReport=1",
                    "type": "GET",
                    "dataSrc": "",
                    "datatype": "json"
                },
                dom: 'Bfrtip',
                scrollY: (window.innerHeight * 0.6),
                paging: false,
                autoWidth: true,
                buttons: [{
                    extend: 'excel',
                    title: 'Raw Material Inventory',
                    exportOptions: {
                        columns: [0, 1, 2, 3, 4] //Your Colume value those you want
                    }
                }],
                order: [ [3, "asc"], [4, "asc"]],
                responsive: true,
                paging: false,

                "columns": [
                    {
                        className: 'dt-control',
                        orderable: false,
                        data: null,
                        defaultContent: ''
                    },
                    { "data": "Material_name" },
                    // { "data": "RMType" },
                    { "data": "UOM" },
                    { "data": "TotalRecived", className: "dt-right" },
                    { "data": "TotalIssued", className: "dt-right" },
                    { "data": "Balance", className: "dt-right" },
                    // { "data": null }
                    ],

                // columnDefs: [{
                //     targets: [-1], render: function (a, b, data, d) {
                //         return "<a style='cursor:pointer' class='btn btn-primary btn-smaller' href='/Report/RawmaterialsInventoryDetail?Raw_material_Dbkey=" + data.Raw_material_Dbkey + "'>View Detail</a>"
                //     },
                //     "orderable": false,
                //     "paging": false,
                //     "ordering": false,

                // },
               //  ],
                "rowCallback": function (row, data, index) {

                    if (data.Balance <= 0) {
                        $('td', row).css('color', '#db5949');
                    }

                    //if (data.Receiving_inventory >= data.orderd) {
                    //    $('td', row).css('color', '#72b159');
                    //}


                },
            });

            $('.DT-search .form-control').attr('placeholder', 'Search...');
            $('.DT-search .form-control').attr('class', 'DT-search form-control');
            $('.DT-lf-right').attr('class', 'pull-left');
            $('.dataTables_length').attr('class', 'dataTables_length DT-lf-right');


            dataTable.on('click', 'td.dt-control', function (e) {
                let tr = e.target.closest('tr');
                let row = dataTable.row(tr);

                if (row.child.isShown()) {
                    // This row is already open - close it
                    row.child.hide();
                }
                else {
                    // Open this row
                    var daata = row.data();
                    $.ajax({
                        url: "/Report/GetRawmaterialsInventory?ForConsolidatedReport=0&Raw_material_Dbkey=" + daata.Raw_material_Dbkey,
                        type: "GET",
                        dataType: "json",
                        success: function (response) {
                            console.log(response);
                            var tableHtml = constructTable(response, daata.Raw_material_Dbkey); // Call function to construct the table HTML
                            row.child(tableHtml).show();
                        },
                        error: function (xhr, status, error) {
                            console.error(error);
                        }
                    });
                }
            });
        }

        function constructTable(data,id) {
            var tableHtml = '<table class="table table-bordered" width="100%" style="border-color: #96D4D4;">';
            // Construct table header
            tableHtml += '<thead><tr>';
            var columnsheaderOrder = ["Date", "Transaction","Order No.","Issued To","Issued For", "Qty", "Balance"];
            var columnsRowsOrder = ["Receipt_Date", "TransType", "MMGOrderNumber", "Vendor_Name", "IssuePurpose", "Qty", "RunningBalance"];
            $.each(columnsheaderOrder, function (index, key) {
                tableHtml += '<th>' + key + '</th>';
            });
            tableHtml += '</tr></thead>';

            // Construct table body
            tableHtml += '<tbody>';
            $.each(data, function (index, item) {
                console.log(index, item);
                tableHtml += '<tr>';
                $.each(columnsRowsOrder, function (index, key) {
                    tableHtml += '<td style="cursor:pointer;margin-left:15px;" onclick="ShowInventoryDetail(' + id + ')">' + '<span  style="margin-left:7px;">' + item[key] + '</span>' + '</td>';
                });
                tableHtml += '</tr>';
            });
            tableHtml += '</tbody>';

            tableHtml += '</table>';
            return tableHtml;
        }

        function ShowInventoryDetail(Id){
            $.ajax({
                url: "/Report/GetRawmaterialsInventoryDetail?ForConsolidatedReport=0&Raw_material_Dbkey=" + Id,
                type: "GET",
                dataType: "json",
                success: function (response) {
                 //   console.log(response);
                    var receiptDate = moment(response.Receipt_Date).format('DD-MMM-YYYY');
                    response.Receipt_Date = receiptDate;
                    //console.log(receiptDate);
                    var html = ConstructInventoryDetail(response);
                    bootbox.dialog({
                        title: 'Split Details',
                        message: html,
                        size: 'extra-large'
                    });
                },
                error: function (xhr, status, error) {
                    console.error(error);
                }
            });
        }

        function ConstructInventoryDetail(data) {
            var tableHtml = '<table class="table table-bordered" width="100%" style="border-color: #96D4D4;">';
            // Construct table header
            tableHtml += '<thead><tr>';
            var columnsheaderOrder = ["SL", "Material", "UOM", "MMG File No", "Receipt No", "Receipt Date", "Weight", "Heat No", "Transaction"];
            var columnsRowsOrder = ["NUMBER", "Raw_material_Name", "UOM", "MMG_File_No", "Receipt_No", "Receipt_Date", "Weight", "Heat_No", "TransactionType"];
            $.each(columnsheaderOrder, function (index, key) {
                tableHtml += '<th>' + key + '</th>';
            });
            tableHtml += '</tr></thead>';

            // Construct table body
            tableHtml += '<tbody>';
            $.each(data, function (index, item) {
                tableHtml += '<tr>';
                $.each(columnsRowsOrder, function (index, key) {
                    tableHtml += '<td>' + item[key] + '</td>';
                });
                tableHtml += '</tr>';
            });
            tableHtml += '</tbody>';

            tableHtml += '</table>';
            return tableHtml;
        }



    </script>
}