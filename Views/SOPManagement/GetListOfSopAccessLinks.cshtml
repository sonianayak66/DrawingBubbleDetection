@model List<MPCRS.ViewModels.SOPCustomAccessLink>
@{
    ViewData["Title"] = "GetListOfSopAccessLinks";
    Layout = null;
}
<style>

    .buttons-excel, .buttons-html5, .btn-smaller {
        padding: 0.25rem 0.5rem; /* Adjust padding to make the button smaller */
        font-size: 0.675rem; /* Adjust font size to make the text smaller */
        line-height: 1.5; /* Adjust line height for proper text alignment */
    }
</style>
@* <h2>GetListOfSopAccessLinks</h2> *@
<div class="page-header">
    <div class="col-12">
        <div class="row">
            <div class="col-md-10">
                <h3>Custom Access Links</h3>
            </div>
           
        </div>
    </div>
</div>
<hr />
<div>
    <table id="GetListOfSopAccessTable" class="table table-striped table-bordered " style="width:100%">
        <thead>
            <tr>
                <th>Sl No</th>
                <th>LinkTitle</th>
                <th>Remarks</th>
                <th>Link</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @{
                int i = 1;
                if (Model != null)
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@i</td>
                            <td>@item.LinkTitle</td>
                            <td>@item.Remarks</td>
                            <td>@item.Link <a class="btn btn-primary btn-smaller" onclick="SopLinkCopyToClipboard('@item.Link')">Copy</a></td>
                            <td><a class="btn btn-smaller btn-secondary" onclick="EditSopAccessLink('@item.LinkGuid')">Edit</a></td>
                        </tr>
                        i = i + 1;
                    }
                }
                else
                {
                    <tr>
                        <td>@i</td>
                        <td></td>
                        <td></td>
                        <td></td>
                        <td></td>
                    </tr>
                }

            }
        </tbody>
    </table>
</div>