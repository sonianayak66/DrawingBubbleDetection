		//         // Show or hide row based on the presence of the warning badge
		//         if (rowHasWarningBadge) {
		//             $(row).show();
		//         } else {
		//             $(row).hide();
		//         }
		//     });
		// });


		// $('#filter-shared').on('click', function () {
		//     dataTable.rows().every(function () {
		//         var row = this.node();
		//         var rowHasWarningBadge = false;

		//         // Check each cell in the row for the class 'badge-phoenix-warning'
		//         $(row).find('td').each(function () {
		//             if ($(this).find('.badge-phoenix-success').length > 0) {
		//                 rowHasWarningBadge = true;
