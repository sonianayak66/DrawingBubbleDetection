                console.log(args.content); // your content
                args.content = args.content.replace(/<b>\s*<td>([^td]+)<\/td>\s*<\/b>/gmi, "<td>$1</td>");
            }
        });

        function SubmitReport() {
            if (!$('#SOPreport').valid()) { return false }

         
           
            var details = { 
                    SectionHeader:  $('#SectionHeader').val(),
                    Id: $('#Id').val(),
                    DisplayOrder: $('#DisplayOrder').val(),
                    AccessibleUsers: $('#AccessibleUsers').val(),                  
                    PageBreakAfter: document.getElementById("PageBreakAfter").checked,
                    PageBreakBefore: document.getElementById("PageBreakBefore").checked,                  
                    TemplateSectionGuid: $('#TemplateSectionGuid').val(),
                    isActive: document.getElementById("isActive").checked
                //Body :tinymce.get("mytextarea").getContent(),

            };
           
            //var data = $("#SOPreport").serialize();
            //alert(details);
            $.ajax({
                type: 'POST',
                url: '/SOPReport/SaveTemplate',
                data: details,
                success: function (data) {
                    bootbox.alert(data.msg
                        , function () {
                            window.location.href = "/SOPReport/TemplateSections";
                        });
                },
                error: function (data) {
                    bootbox.alert(data.msg
                        , function () {
                            window.location.href = "/SOPReport/TemplateSections";
                        });
                }
            });
        }

