@model MPCRS.ViewModels.SOPReportTemplateVM
@using MPCRS.Utilities
@{
    ViewData["Title"] = "SOPReportTemplate";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var UsersList = MPCRS.Utilities.Masters.GetUsersList();
    var Permission_Write = UserData.IsAuthorized(User, Constants.UserPermissions.Sop_ReportTemplate_Write);
}

 

@*<link href="~/assets/summernote/summernote.min.css" rel="stylesheet" />*@


<form id="SOPreport" class="needs-validation" novalidate="novalidate">
<div class="col-12">
    <div class="row">
        <div class="col-sm-8">
            @{
                if (Model.Id==0)
                {
                    <h3>Create New Report Section</h3>
                }
                else
                {
                    <h3>Edit Section </h3>
                }
            }
        </div>
        
        <div class="col-6 col-sm-4 pull-right">
                <a class="btn btn-secondary float-end" href="/SOPReport/TemplateSections">Back</a>
            @{
                if (Permission_Write)
                {
                    <input type="button" class="btn btn-primary float-end" style="margin-right:10px;" value="Save" onclick="SubmitReport()" />
                }
            }
     
                
        </div>
    </div>
</div>
<hr/>
<div class="offset-2 col-12">
    
        <input class="form-control" asp-for="Id" type="hidden">
        <input class="form-control" asp-for="TemplateSectionGuid" type="hidden">
        
        <div class="col-12">

            <div class="form-group row">
                
                <div class="col-md-6">
                    <div class="form-floating mb-1">
                        <input class="form-control" asp-for="SectionHeader" type="text">
                        <label asp-for="SectionHeader"></label>
                    </div>
                </div>
            </div>
            <div class="form-group row">
                <div class="col-md-6">
                    <div class="form-floating mb-1">
                        
                        <input class="form-control" asp-for="DisplayOrder" type="number">
                        <label asp-for="DisplayOrder"></label>
                    </div>
                </div>
            </div>
            <div class="form-group row">
                <div class="col-md-6">
                    <label asp-for="AccessibleUsers" class="control-label">Accessible Users</label>
                    <select asp-for="AccessibleUsers" class="form-select form-select-sm multiselect userlist" multiple asp-items="@UsersList">
                    </select>
                </div>
            </div>
            <div class="form-group row">
                <div class="col-6">
                    <div class="form-floating mb-1">
                        <div class="form-check form-switch">
                            <input class="form-check-input" asp-for="PageBreakAfter" name="PageBreakAfter" type="checkbox" />
                            <label class="form-check-label" asp-for="PageBreakAfter">Page Break After</label>
                        </div>
                    </div>
                    <div class="form-floating mb-1">
                        <div class="form-check form-switch">
                            <input class="form-check-input" asp-for="PageBreakBefore" name="PageBreakBefore" type="checkbox" />
                            <label class="form-check-label" asp-for="PageBreakBefore">Page Break Before</label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="form-group row">
                <div class="col-6">
                    <div class="form-floating mb-1">
                        <div class="form-check form-switch">
                            <input class="form-check-input" asp-for="isActive" name="isActive" type="checkbox" />
                            <label class="form-check-label" asp-for="isActive">Is Active</label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="mb-3"style="display:none;">
                <label asp-for="Body"></label>
                <textarea asp-for="Body" id="mytextarea"></textarea>
            </div>
        </div>
</div>
</form>

@section scripts{
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}
@*    <script src="~/assets/summernote/summernote.min.js"></script>*@
 


