	<script>
		bootbox.setDefaults({
			centerVertical: true,
			scrollable: true
		});

		function getNavBarHeight() {
			return document.getElementById("navbarTop").clientHeight;
		}

		function UpdateNavHeading(text) {
			document.getElementById("nav-heading-element").innerText = text;
		}

		function highlightRow(row, tableId) {
			// Remove the 'highlight' class from all rows
			var tableRows = document.querySelectorAll('#' + tableId + ' tbody tr');
			tableRows.forEach(function (r) {
				if (r.classList.contains('highlight')) {
					r.style.backgroundColor = ''
				}
			});

			// Add the 'highlight' class to the clicked row
			row.classList.add('highlight');
			row.style.backgroundColor = "#ffcc85";
		}



	</script>


