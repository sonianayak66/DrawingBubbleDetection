			width: 100%;
		}

		.DrawingDimension {
			padding-right: 30px; /* Space for icon */
		}

		.symbolDropdown {
			position: absolute;
			display: none;
			border: 1px solid #ddd;
			background-color: #fff;
			max-height: 200px;
			width: 200px;
			overflow-y: auto;
			z-index: 1000;
