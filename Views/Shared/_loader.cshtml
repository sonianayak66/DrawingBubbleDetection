 
@{
    Layout = null;
}


<style>
    #loading {
        position: fixed;
        display: block;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        text-align: center;
        opacity: 0.7;
        background-color: #fff;
        z-index: var(--phoenix-modal-zindex);
    }

    #loading-image {
        position: absolute; 
        top: 49%;
        left: 49%;
        z-index: var(--phoenix-modal-zindex);
    }
</style>


<div id="loading"> 
    <div id="loading-image" class="spinner-border text-warning" role="status">
        <span class="visually-hidden">Loading...</span> 
    </div>
</div>

 