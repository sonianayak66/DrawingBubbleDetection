@using MPCRS.Utilities;

<style>
    .nav-bordered {
        border-bottom: 1px solid;
        border-color: var(--phoenix-border-color);
    }
</style>

<div class="row g-0 align-items-center">
    <div class="col-5 col-md-6">
        <h4 class="mb-0 text-1100 fw-bold fs-md-2">
            <span class="calendar-day d-block d-md-inline mb-1">User Management</span>
        </h4>
    </div>
    <div class="col-7 col-md-6 d-flex justify-content-end">
        <a href="/Home/Index" class="btn btn-secondary btn-sm float-end m-1" style="float:right;">Back</a>
    </div>
</div>

<div class="row">
    <div class="position-sticky mt-xl-4 col-2 col-12 col-sm-2" style="top: 120px;">
        <ul class="nav nav-vertical flex-column doc-nav" data-doc-nav="data-doc-nav">
            <li class="nav-item nav-bordered">
                <a class="nav-link" href="#example" onclick="GetUserList()">  <span class="uil uil-users-alt fs-2"></span> Users</a>
            </li>
            <li class="nav-item nav-bordered">
                <a class="nav-link" href="#sizing" onclick="GetRoles()"> <span class="uil uil-game-structure fs-2"></span> Roles</a>
            </li>        
             <li class="nav-item nav-bordered">
                <a class="nav-link" href="#example1" onclick="GetUserListInactive()">  <span class="uil uil-users-alt fs-2"></span>Inactive Users</a>
            </li>
            <li class="nav-item nav-bordered">
                <a class="nav-link" href="#bulkroles" onclick="GetBulkRoleAssignment()"> <span class="uil uil-shield-check fs-2"></span> Bulk Role Assignment</a>
            </li>
          @*  <li class="nav-item nav-bordered">
                <a class="nav-link" href="#sizing"> <span class="uil-user fs-2"></span> Persons</a>
            </li>*@
   @*         <li class="nav-item nav-bordered">
                <a class="nav-link" >AddRoles</a>
            </li>*@
        </ul>
    </div>
    <div class="col-12 col-sm-10" id="cardData">
       

    </div>
    
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    } 
    <script src="~/mpi/users.js" asp-append-version="true"></script>
 }
