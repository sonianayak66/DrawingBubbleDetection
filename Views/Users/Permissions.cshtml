@model List<MPCRS.ViewModels.Permissions>
@using MPCRS.Utilities;
@{
    Layout = null;
    var hasWritePermission = UserData.IsAuthorized(User, Constants.UserPermissions.User_RolesWrite);
}
 

<input type="hidden" value="@ViewBag.RoleId" id="RoleId" />

<div class="row align-items-center mb-2">
    <div class="form-floating col">
        <input type="text" id="search" onkeyup="SearchPermission(this)" class="form-control" placeholder="" />
        <label for="search">Search</label>
    </div>
    <div class="col-auto d-flex align-items-center gap-2">
        <div class="form-check form-switch mb-0" title="Show only assigned permissions">
            <input class="form-check-input" type="checkbox" id="assignedOnlyToggle" onchange="FilterAssignedPermissions(this)" />
            <label class="form-check-label" for="assignedOnlyToggle" style="font-size:small; white-space:nowrap;">Assigned only</label>
        </div>
        @if (hasWritePermission)
        {
            <button class="btn btn-primary btn-sm" onclick="SubmitRolePermisions()">Save</button>
        }
    </div>
</div>

<div style="max-height:calc(100vh - 280px); overflow-y:auto">
    <table class="table table-sm fs--1 mb-2" cellspacing="0" style="width:100%; font-size:small">
        <thead style="position:sticky; top:0; z-index:1; background:#fff;">
            <tr>
                <th colspan="2">
                    Permissions for  -  @ViewBag.RoleName
                </th>
                <th>

                </th>
            </tr>
            <tr>
                <th>
                    Module
                </th>
                <th>
                    Description
                </th>
                <th>
                    Access
                    <input type="checkbox" onchange="SelectAll(this)" style="width:16px!important;height:16px!important" />
                </th>
            </tr>
        </thead>
        <tbody id="tblpermissions">
            @{
                foreach (var item in Model)
                {
                    <tr data-module="@item.PermissionInfo.Module" data-description="@item.PermissionInfo.Description" data-permkey="@item.PermissionString">
                        <td>
                            @item.PermissionInfo.Module
                        </td>
                        <td>
                            @item.PermissionInfo.Description
                        </td>
                        <td>
                            <div class="form-check form-switch">
                                <input class="form-check-input Permission_Switch" id="@item.PermissionString" type="checkbox" @(item.selected ? "checked" : "") />
                                <label class="form-check-label" for="@item.PermissionString">Allow</label>
                            </div>
                        </td>
                    </tr>
                }
            }

        </tbody>

    </table>

</div>

