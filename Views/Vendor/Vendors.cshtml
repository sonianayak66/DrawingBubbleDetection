@model List<MPCRS.ViewModels.Vendors_VM>
@using MPCRS.Utilities
@{
    ViewData["Title"] = "Vendors";
    //Layout = null;
    var Permission_Write = UserData.IsAuthorized(User, Constants.UserPermissions.Vendors_Write);
    var Permission_read = UserData.IsAuthorized(User, Constants.UserPermissions.Vendors_Read);

}

<div class="page-header">
    <div class="col-12">
        <div class="row">
            <div class="col-sm-10">
                <h3>Vendors</h3>
            </div>
            <div class="col-sm-2 pull-right">
                <button class="btn btn-primary float-end" onclick="Create('')">Create</button>
                <a href="/Home" style="margin-right:4px" class="btn btn-secondary float-end ">Back</a>
            </div>
        </div>
    </div>
</div>
<hr />

<div class="col-md-12 col-sm-12 col-lg-12 divc">

    <table class="table table-bordered table-sm fs--1 mb-2" id="Vendorstbl">
        <thead>
            <tr>
                <th data-sortable="true" scope="col">Vendor ID </th>
                <th data-sortable="true" scope="col"> Name</th>
                <th data-sortable="true" scope="col"> Email</th>
                <th data-sortable="true" scope="col">Contact</th>
                <th data-sortable="true" scope="col">Address</th>
               
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @{
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Vendor_ID_User</td>
                        <td>@item.Vendor_Name</td>
                        <td>@item.Vendor_Email</td>
                        <td>@item.Vendor_Contact</td>
                        <td>@item.Vendor_Adress</td>
                        <td>
                            <a class="fas fa-user-edit" href="#" onclick="Create('@item.Vendor_Dbkey')">
                                edit
