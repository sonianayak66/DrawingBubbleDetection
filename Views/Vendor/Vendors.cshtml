                            </a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
@section scripts {
    <script type="text/javascript">

        var VendorsDataList = [];

        $(document).ready(function () {
            //getRawmaterialsData();
            dataTable = $("#Vendorstbl").DataTable({
                scrollY: 510,
               
                responsive: true,
                paging: false,

                dom: 'Bfrtip',
                stateSave: true,
                stateSaveCallback: function (settings, data) {
                    localStorage.setItem(
                        'DataTables_' + settings.sInstance,
                        JSON.stringify(data)
                    );
                },
                stateLoadCallback: function (settings) {
                    return JSON.parse(localStorage.getItem('DataTables_' + settings.sInstance));
                },
                buttons: [{
                    extend: 'excel',
                    title: 'Vendors',
                    exportOptions: {
                        columns: [0, 1, 2, 3, 4] //Your Colume value those you want
                    }
                }],
            });
        });
        function Create(ID) {
            $.ajax({
                url: '/Vendor/CreateVendor/?Id=' + ID,
               
                type: 'GET',
                success: function (data) {
                    bootbox.alert({
                        message: data,
                        size: 'large',
                        buttons: {
                            ok: {
                                className: 'd-none',
                                //callback: function () {
                                //    if (!$('#CreateRawmaterial').valid()) { return false }
                                //}
                            }
                        },
                      

                    });
                }
            });
        }

    </script>
}